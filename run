#!/usr/bin/env python3
import argparse, subprocess, os, sys, csv, webbrowser
from datetime import UTC, datetime
from pathlib import Path
from chart_program.instrument_detector import detect_instrument_type
from chart_program.chart_loader import COMMODITY_STOOQ_MAP
PROJECT_ROOT = Path(__file__).resolve().parent
SEARCH_OUTPUT_DIR = PROJECT_ROOT / "chart_program" / "data" / "search"
ALL_REPORT_DIR = PROJECT_ROOT / "chart_program" / "data" / "all_insturments_search"
ANSI_RESET="\033[0m"; ANSI_BOLD="\033[1m"; ANSI_CYAN="\033[36m"
GOLD_DOT = "🟡"
RED_DOT = "🔴"
GRAY_DOT = "⚪"

def _normalize_key(value: str) -> str: return "".join(ch for ch in (value or "").lower() if ch.isalnum())
def _match_in_dir(directory: Path, target: str) -> list[Path]:
    key=_normalize_key(target.replace('.py','')); exact=[p for p in directory.glob('*.py') if _normalize_key(p.stem)==key]
    return exact or [p for p in directory.glob('*.py') if _normalize_key(p.stem).startswith(key)]
def _resolve_existing_config_path(target: str) -> Path | None:
    groups=[PROJECT_ROOT/'configs'/'stocks',PROJECT_ROOT/'configs'/'forex',PROJECT_ROOT/'configs'/'commodities']; found=[]
    for d in groups:
        m=_match_in_dir(d,target)
        if m: found.append(m[0])
    return found[0] if len(found)==1 else None
def _instrument_type_from_path(path: Path | None) -> str | None:
    if not path: return None
    parts=[p.lower() for p in path.parts]
    return 'stock' if 'stocks' in parts else 'forex' if 'forex' in parts else 'commodity' if 'commodities' in parts else None
def _resolve_runner(instrument_type: str) -> str: return 'main_stock.py' if instrument_type=='stock' else 'main.py'
def _stooq_chart_url(ticker: str) -> str:
    raw=(ticker or '').strip().upper(); mapped=COMMODITY_STOOQ_MAP.get(raw)
    symbol='al.f' if raw=='ALUMINIUM' else 'hg.f' if raw=='COPPER' else (str(mapped).lower() if mapped else raw.lower())
    return f"https://stooq.pl/q/a2/?s={symbol}&i=d&t=c&a=ln&z=224&ft=20251204&l=234&d=1&ch=0&f=1&lt=56&r=0&o=1"

def _is_number_text(value: str) -> bool:
    txt = (value or "").strip().replace(",", "")
    if not txt:
        return False
    try:
        float(txt)
        return True
    except Exception:
        return False

def _format_row(cells: list[str], widths: list[int], right_align: list[bool] | None = None) -> str:
    out_cells: list[str] = []
    right_align = right_align or [False] * len(cells)
    for i, (cell, width) in enumerate(zip(cells, widths)):
        txt = str(cell)
        if len(txt) > width:
            txt = txt[: max(1, width - 1)] + "…"
        out_cells.append(txt.rjust(width) if right_align[i] else txt.ljust(width))
    return "│ " + " │ ".join(out_cells) + " │"

def _write_table(out, title: str, rows: list[dict[str, str]], columns: list[tuple[str, str]]) -> None:
    out.write(f"\n=== {title} ===\n")
    if not rows:
        out.write("Brak wyników.\n")
        return
    headers = [h for h, _ in columns]
    keys = [k for _, k in columns]
    widths = []
    for h, k in columns:
        w = max(len(h), max((len(str(r.get(k, ""))) for r in rows), default=0))
        if k == "stooq_link":
            w = min(max(w, 52), 80)
        widths.append(w)
    right_align = []
    for _, key in columns:
        sample = next((str(r.get(key, "")) for r in rows if str(r.get(key, "")).strip()), "")
        right_align.append(_is_number_text(sample))
    top = "┌" + "┬".join("─" * (w + 2) for w in widths) + "┐"
    sep = "├" + "┼".join("─" * (w + 2) for w in widths) + "┤"
    bottom = "└" + "┴".join("─" * (w + 2) for w in widths) + "┘"
    out.write(top + "\n")
    out.write(_format_row(headers, widths) + "\n")
    out.write(sep + "\n")
    for row in rows:
        out.write(_format_row([str(row.get(k, "")) for k in keys], widths, right_align=right_align) + "\n")
    out.write(bottom + "\n")

def _append_csv_section(fp: Path, title: str, csv_path: Path, links: set[str]) -> None:
    if not csv_path.exists(): return
    with csv_path.open(newline='', encoding='utf-8') as fh: rows=list(csv.DictReader(fh))
    with fp.open('a', encoding='utf-8') as out:
        for r in rows:
            t=r.get('ticker','').strip(); link=_stooq_chart_url(t) if t else ''
            if link:
                links.add(link)
                r["stooq_link"] = link
            else:
                r["stooq_link"] = ""

        if csv_path.name.endswith("_flips.csv"):
            for r in rows:
                retest_dates = [str(v).strip() for k, v in r.items() if str(k).startswith("retest_date_") and str(v).strip()]
                r["last_valid_retest_pattern_date"] = retest_dates[-1] if retest_dates else "-"
                last_pattern = [str(v).strip() for k, v in r.items() if str(k).startswith("formation_") and str(v).strip()]
                r["last_valid_retest_pattern_name"] = last_pattern[-1] if last_pattern else "-"
                r["jest_marker"] = f"{GRAY_DOT} above" if str(r.get("current_side", "")) == "above" else f"{RED_DOT} below"
            cols = [
                ("Ticker", "ticker"),
                ("Było", "previous_side"),
                ("Jest", "jest_marker"),
                ("Data wybicia", "flip_date"),
                ("Mies. od wybicia", "months_since_flip"),
                ("Retest status", "latest_retest_status"),
                ("Retest count", "valid_retests_count"),
                ("Last valid retest", "last_valid_retest_pattern_date"),
                ("Pattern", "last_valid_retest_pattern_name"),
                ("Link", "stooq_link"),
            ]
            rows = sorted(rows, key=lambda r: (str(r.get("current_side", "")) != "below", -float(str(r.get("months_since_flip", "0") or "0"))))
            _write_table(out, f"{title} / WYNIKI 2", rows, cols)
        elif csv_path.name.startswith("fibo_search_"):
            for r in rows:
                status = str(r.get("status", ""))
                if status == "valid_reversal":
                    r["status_marker"] = "🟢 valid_reversal"
                elif status == "reached_23_6_waiting_for_61_8":
                    r["status_marker"] = "🟡 waiting_for_61.8"
                else:
                    r["status_marker"] = f"🔴 {status}"
            cols = [
                ("Ticker", "ticker"),
                ("Dir", "direction"),
                ("Status", "status_marker"),
                ("Pattern", "reversal_pattern_name"),
                ("Incline start", "incline_start_date"),
                ("Incline end", "incline_end_date"),
                ("Touch 61.8", "first_61_8_touch_date"),
                ("Close", "current_close"),
                ("Link", "stooq_link"),
            ]
            _write_table(out, f"{title} / WYNIKI 1+2", rows, cols)
        else:
            for r in rows:
                side = str(r.get("side", ""))
                r["side_marker"] = f"{GRAY_DOT} above" if side == "above" else (f"{RED_DOT} below" if side == "below" else side)
            th10_vals = {str(r.get("threshold_10d_pln", "")).strip() for r in rows if str(r.get("threshold_10d_pln", "")).strip()}
            th20_vals = {str(r.get("threshold_20d_pln", "")).strip() for r in rows if str(r.get("threshold_20d_pln", "")).strip()}
            low20_desc = "Liczba dni (z ostatnich 20), gdy obrót był poniżej progu 20d."
            out.write("\n========== PROGI ==========\n\n")
            if len(th10_vals) == 1 and len(th20_vals) == 1:
                out.write(f"Th10d (min. średni obrót 10d, PLN) = {next(iter(th10_vals))}\n")
                out.write(f"Th20d (dolny próg dziennego obrotu, PLN) = {next(iter(th20_vals))}\n")
            out.write(f"{low20_desc}\n")
            cols = [
                ("Ticker", "ticker"),
                ("Pozycja", "side_marker"),
                ("Świece", "respect_days"),
                ("Mies.", "respect_months"),
                ("Start", "start_date"),
                ("Close", "close"),
                ("Link", "stooq_link"),
            ]
            is_stock_like = any("." in str(r.get("ticker", "")) or str(r.get("ticker", "")).isalpha() for r in rows)
            if is_stock_like:
                cols.insert(6, ("Avg10d PLN", "avg_turnover_10d_pln"))
                cols.insert(7, ("Low<Th20", "below_threshold_days_20d"))
            if is_stock_like and not (len(th10_vals) == 1 and len(th20_vals) == 1):
                cols.extend([("Th10d PLN", "threshold_10d_pln"), ("Th20d PLN", "threshold_20d_pln")])
            rows = sorted(rows, key=lambda r: (str(r.get("side", "")) != "below", -float(str(r.get("respect_months", "0") or "0"))))
            top3 = sorted([r for r in rows if str(r.get("avg_turnover_10d_pln", "")).strip()], key=lambda r: float(str(r.get("avg_turnover_10d_pln", "0")).replace(",", "")), reverse=True)[:3]
            top_keys = {r.get("ticker") for r in top3}
            for r in rows:
                if r.get("ticker") in top_keys:
                    r["avg_turnover_10d_pln"] = f"{GOLD_DOT} {r.get('avg_turnover_10d_pln')}"
            _write_table(out, f"{title} / WYNIKI 1", rows, cols)

def _is_ichimoku_csv(name: str) -> bool:
    return name.startswith("search_") and name.endswith(".csv")

def _is_fibo_csv(name: str) -> bool:
    return name.startswith("fibo_search_") and name.endswith(".csv")

def _run_batch_search(mode: str, batch: list[str]) -> int:
    from scanner_search import run_ichimoku_search, run_fibo_search
    runner = run_ichimoku_search if mode=='ichimoku' else run_fibo_search
    os.environ['STOCKHELPER_BATCH_MODE']='1'; os.environ['STOCKHELPER_DEFER_OPEN_LINKS']='1'
    report_dir = ALL_REPORT_DIR / ("ichimoku_searches" if mode == "ichimoku" else "fibo_searches")
    report_dir.mkdir(parents=True, exist_ok=True)
    for old in report_dir.glob("*.txt"):
        try:
            old.unlink()
        except Exception:
            pass
    report = report_dir / f"{mode}_all_latest.txt"
    report.write_text(f"{mode.upper()} ALL COMBO REPORT\n", encoding='utf-8')
    failures=0; all_links=set()
    for idx,scope in enumerate(batch,1):
        print(f"\n\033[1m\033[36m=== [{idx}/{len(batch)}] {mode.upper()} :: {scope.upper()} ===\033[0m")
        before_mtime = {p.name: p.stat().st_mtime for p in SEARCH_OUTPUT_DIR.glob("*.csv")}
        try: code=int(runner(scope))
        except Exception as exc: print(f"[batch] {mode} search failed for {scope}: {exc}"); code=1
        after = sorted(SEARCH_OUTPUT_DIR.glob("*.csv"), key=lambda p: p.stat().st_mtime)
        new = [p for p in after if p.name not in before_mtime or p.stat().st_mtime > before_mtime[p.name]]
        with report.open("a", encoding="utf-8") as out:
            out.write(f"\n\n========== {scope.upper()} ==========\n")
        normal = [p for p in new if not p.name.endswith("_flips.csv")]
        flips = [p for p in new if p.name.endswith("_flips.csv")]
        for p in normal + flips:
            if mode == 'ichimoku' and _is_ichimoku_csv(p.name):
                label = "WYNIKI 2" if p.name.endswith("_flips.csv") else "WYNIKI 1"
                _append_csv_section(report, f"{scope.upper()} :: {p.name} / {label}", p, all_links)
            if mode == 'fibo' and _is_fibo_csv(p.name):
                _append_csv_section(report, f"{scope.upper()} :: {p.name}", p, all_links)
        if code!=0: failures+=1
    print(f"\n[batch] combo report saved: {report}")
    if all_links:
        try: open_all=input('Czy otworzyć wszystkie linki? [y/N]: ').strip().lower()
        except EOFError: open_all='n'
        if open_all=='y':
            for l in sorted(all_links): webbrowser.open_new_tab(l)
    os.environ.pop('STOCKHELPER_BATCH_MODE',None); os.environ.pop('STOCKHELPER_DEFER_OPEN_LINKS',None)
    return 1 if failures else 0

def main()->int:
    parser=argparse.ArgumentParser(prog='run',description='Ultra-short launcher. -c opens chart_program.')
    parser.add_argument('-ichimoku_search','-search',dest='search_target'); parser.add_argument('-fibo_search',dest='fibo_search_target',nargs='?',const='single')
    parser.add_argument('-explain',dest='fibo_explain_target'); parser.add_argument('-d','--search-debug',action='store_true'); parser.add_argument('target',nargs='?')
    parser.add_argument('-c','--chart',action='store_true'); parser.add_argument('--debug-stooq',dest='debug_stooq'); parser.add_argument('-inspector','--inspector',action='store_true')
    args=parser.parse_args()
    if args.search_debug: os.environ['STOCKHELPER_STOOQ_DEBUG']='1'
    if args.debug_stooq:
        from utilities.stooq_playwright import debug_stooq_page
        raw = args.debug_stooq.strip(); upper_raw = raw.upper(); mapped = COMMODITY_STOOQ_MAP.get(upper_raw)
        if mapped: symbol_for_debug = str(mapped).lower()
        else:
            values = {str(v).lower() for v in COMMODITY_STOOQ_MAP.values()}
            symbol_for_debug = raw.lower() if raw.lower() in values else raw
        path = debug_stooq_page(symbol_for_debug, interactive_captcha=args.inspector)
        print(f"Stooq debug zapisany: {path}")
        return 0
    if args.search_target:
        if args.search_target.strip().lower()=='all': return _run_batch_search('ichimoku',['wig','dax','us100','forex','commodities'])
        from scanner_search import run_ichimoku_search; return run_ichimoku_search(args.search_target)
    if args.fibo_explain_target:
        from scanner_search import run_fibo_explain; return run_fibo_explain(args.fibo_search_target or 'single', args.fibo_explain_target)
    if args.fibo_search_target:
        if args.fibo_search_target.strip().lower()=='all': return _run_batch_search('fibo',['wig','dax','us100','forex','commodities'])
        from scanner_search import run_fibo_search; return run_fibo_search(args.fibo_search_target)
    target=(args.target or '').strip()
    if not target: parser.error('target is required unless -ichimoku_search is used')
    resolved_path=_resolve_existing_config_path(target)
    if args.chart:
        if resolved_path:
            cmd=[sys.executable,'-m','chart_program',resolved_path.stem,'--config',str(resolved_path)]
            instrument_type = _instrument_type_from_path(resolved_path)
            if instrument_type:
                cmd.extend(['--instrument', instrument_type])
        else:
            cmd=[sys.executable,'-m','chart_program',target]
    else:
        instrument_type=_instrument_type_from_path(resolved_path) or detect_instrument_type(target,None)
        if resolved_path is None: print(f'Instrument config not found: {target}.'); return 1
        cmd=[sys.executable,str(PROJECT_ROOT/_resolve_runner(instrument_type)),str(resolved_path)]
    return subprocess.call(cmd)
if __name__=='__main__': raise SystemExit(main())
