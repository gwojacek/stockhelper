    )
    html_parts.append("<div class='troj-hero'><h2>🌈🐱 Scanner workspace</h2><p>Use tabs to switch between the full allsearch report and embedded Trójpolówki watchlists.</p><div class='tabbar'><button class='btn tabbtn active' data-tab='allsearch' onclick=\"showReportTab('allsearch')\">ALLSEARCH REPORT</button><button class='btn tabbtn' data-tab='troj-fibo' onclick=\"showReportTab('troj-fibo')\">3P FIBO</button><button class='btn tabbtn' data-tab='troj-ichimoku' onclick=\"showReportTab('troj-ichimoku')\">3P ICHIMOKU</button><button class='btn tabbtn' data-tab='wedges' onclick=\"showReportTab('wedges')\">🔻 Kliny</button><button class='btn tabbtn' type='button' onclick=\"window.open('/journal-html','_blank')\">🧾 Open journal</button><button class='btn pdfbtn' type='button' title='Download PDF' onclick=\"downloadPdfReport()\">📄 PDF</button></div></div>")
    html_parts.append(search_toolbar_html)
    html_parts.append("<div id='tab-allsearch' class='tab-panel active'>")
    html_parts.append(_allsearch_top_choices())
    html_parts.append(_liquidity_legend_html())
    for mkt, mrows in by_market.items():
        html_parts.append(f"<div class='market' data-market-block='{html.escape(mkt)}'><h2>{html.escape(_scope_label(mkt.lower()))}</h2>")
        groups = [("WYNIKI 1 ICHIMOKU (poza chmurą, z warunkami płynności)", [x for x in mrows if x.scanner == "ICHIMOKU" and x.category == "position"]),
                  ("WYNIKI 2 ICHIMOKU (po flipie chmury: retest/pattern po wybiciu)", [x for x in mrows if x.scanner == "ICHIMOKU" and x.category == "retest_breakout"]),
                  ("WYNIKI FIBO #0 (3P steep incline)", [x for x in mrows if x.scanner == "FIBO" and x.category == "steep"]),
                  ("WYNIKI FIBO #1 (Waiting 23.6→61.8 and patterns)", [x for x in mrows if x.scanner == "FIBO" and x.category == "waiting"]),
                  ("WYNIKI FIBO #2 (valid pattern up to 2 weeks)", [x for x in mrows if x.scanner == "FIBO" and x.category == "valid"])]
        for gname, grows in groups:
            is_i1 = gname.startswith("WYNIKI 1 ICHIMOKU")
            is_i2 = gname.startswith("WYNIKI 2 ICHIMOKU")
            is_f0 = gname.startswith("WYNIKI FIBO #0")
            is_f1 = gname.startswith("WYNIKI FIBO #1")
            if is_i1:
