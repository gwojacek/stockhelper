@dataclass
class ScannerRow:
    market: str
    scanner: str
    category: str
    ticker: str
    status: str
    pattern: str = ""
    direction: str = ""
    dates: dict[str, str] = field(default_factory=dict)
    metrics: dict[str, str] = field(default_factory=dict)
    chart_url: str | None = None
    python_command: str | None = None
    priority: str = "LOW"

def _chart_command_for_row(row: ScannerRow) -> str:
    ticker = (row.ticker or "").strip()
    if not ticker:
        return ""
    ticker_cmd = ticker
    market = (row.market or "").upper()
    if market == "COMMODITIES" and ticker.upper() not in YAHOO_PRIMARY_COMMODITIES:
        mapped = COMMODITY_STOOQ_MAP.get(ticker.upper())
        if mapped:
            ticker_cmd = str(mapped).upper()
    elif market == "WIG" and "." not in ticker_cmd and len(ticker_cmd) <= 5:
        ticker_cmd = f"{ticker_cmd}.WA"
    instrument = "stock" if market in {"WIG", "DAX", "US100"} else ("forex" if market == "FOREX" else ("commodity" if market in {"COMMODITIES", "INDEXES"} else "stock"))
    if row.scanner == "ICHIMOKU":
        return f"python run -c {ticker_cmd} --ichimoku-mode on"
    if row.scanner == "WEDGE":
        cmd = f"python run -c {ticker_cmd}"
        for arg_name, key in [("--wedge-upper-start", "upper_start"), ("--wedge-upper-end", "upper_end"), ("--wedge-lower-start", "lower_start"), ("--wedge-lower-end", "lower_end")]:
            value = (row.metrics.get(key, "") or "").strip()
            if value:
                cmd += f" {arg_name} {value}"
        return cmd + " --wedge-lines --wedge-right"
    if row.scanner == "FIBO":
        incline = (row.dates.get("incline", "") or "").strip()
        if "->" in incline:
            start, end = [p.strip() for p in incline.split("->", 1)]
            if start and end:
                return f"python run -c {ticker_cmd} --ichimoku-mode off --fibo-lines 5 --fibo-anchor-start {start} --fibo-anchor-end {end} --fibo-right"
        return f"python run -c {ticker_cmd} --ichimoku-mode off --fibo-lines 5"
    return f"python run -c {ticker_cmd}"
def _section_banner(name: str, width: int = 84, fill: str = "=") -> str:
    label = f" {name.strip().upper()} "
    if len(label) >= width:
        return label
    left = (width - len(label)) // 2
    right = width - len(label) - left
    return f"{fill * left}{label}{fill * right}"

def _scope_label(scope: str) -> str:
    s = scope.upper()
    flags = {"WIG": "🇵🇱", "DAX": "🇩🇪", "US100": "🇺🇸", "FOREX": "💱", "COMMODITIES": "🛢️", "INDEXES": "📊"}
    return f"{flags.get(s, '📊')} {s}"

def _liquidity_legend_html() -> str:
    base = GDP_PPP_VALUE["PL"]
    multipliers = {
        "WIG/PL": GDP_PPP_VALUE["PL"] / base,
        "DAX/DE": GDP_PPP_VALUE["DE"] / base,
        "US100/US": GDP_PPP_VALUE["US"] / base,
    }
    def _fmt(v: float) -> str:
        return f"{v:,.0f}".replace(",", " ")
    fibo_examples = ", ".join([f"{k}: ×{m:.2f} = {_fmt(500000*m)} PLN" for k, m in multipliers.items()])
    ichi_examples = ", ".join([f"{k}: ×{m:.2f} = {_fmt(700000*m)} PLN" for k, m in multipliers.items()])
    low20_examples = ", ".join([f"{k}: ×{m:.2f} = {_fmt(300000*m)} PLN" for k, m in multipliers.items()])
    wig_f = _fmt(500000 * multipliers["WIG/PL"]); dax_f = _fmt(500000 * multipliers["DAX/DE"]); us_f = _fmt(500000 * multipliers["US100/US"])
    wig_i = _fmt(700000 * multipliers["WIG/PL"]); dax_i = _fmt(700000 * multipliers["DAX/DE"]); us_i = _fmt(700000 * multipliers["US100/US"])
    wig_l = _fmt(300000 * multipliers["WIG/PL"]); dax_l = _fmt(300000 * multipliers["DAX/DE"]); us_l = _fmt(300000 * multipliers["US100/US"])
    return (
