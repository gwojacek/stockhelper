    base = GDP_PPP_VALUE["PL"]
    multipliers = {
        "WIG/PL": GDP_PPP_VALUE["PL"] / base,
        "DAX/DE": GDP_PPP_VALUE["DE"] / base,
        "US100/US": GDP_PPP_VALUE["US"] / base,
    }
    def _fmt(v: float) -> str:
        return f"{v:,.0f}".replace(",", " ")
    fibo_examples = ", ".join([f"{k}: ×{m:.2f} = {_fmt(500000*m)} PLN" for k, m in multipliers.items()])
    ichi_examples = ", ".join([f"{k}: ×{m:.2f} = {_fmt(700000*m)} PLN" for k, m in multipliers.items()])
    low20_examples = ", ".join([f"{k}: ×{m:.2f} = {_fmt(300000*m)} PLN" for k, m in multipliers.items()])
    return (
        "Legenda (progi): "
        f"🟨 Fibo: próg płynności Th10d (ostatnie 10 świeczek) = bazowo 500000 PLN × mnożnik PKB kraju ({fibo_examples}). "
        f"☁️ Ichimoku: próg płynności = 700000 PLN × mnożnik PKB kraju ({ichi_examples}). "
        f"🧪 Low<Th20: liczba dni z ostatnich 20 poniżej progu 300000 PLN × mnożnik kraju ({low20_examples}) — nie może być więcej niż 2.\n"
    )

def _normalize_key(value: str) -> str: return "".join(ch for ch in (value or "").lower() if ch.isalnum())
def _match_in_dir(directory: Path, target: str) -> list[Path]:
    key=_normalize_key(target.replace('.py','')); exact=[p for p in directory.glob('*.py') if _normalize_key(p.stem)==key]
    return exact or [p for p in directory.glob('*.py') if _normalize_key(p.stem).startswith(key)]
def _resolve_existing_config_path(target: str) -> Path | None:
    groups=[PROJECT_ROOT/'configs'/'stocks',PROJECT_ROOT/'configs'/'forex',PROJECT_ROOT/'configs'/'commodities']; found=[]
    for d in groups:
        m=_match_in_dir(d,target)
        if m: found.append(m[0])
    return found[0] if len(found)==1 else None
def _instrument_type_from_path(path: Path | None) -> str | None:
    if not path: return None
    parts=[p.lower() for p in path.parts]
    return 'stock' if 'stocks' in parts else 'forex' if 'forex' in parts else 'commodity' if 'commodities' in parts else None
def _resolve_runner(instrument_type: str) -> str: return 'main_stock.py' if instrument_type=='stock' else 'main.py'
def _stooq_chart_url(ticker: str) -> str:
    raw=(ticker or '').strip().upper(); mapped=COMMODITY_STOOQ_MAP.get(raw)
    symbol='al.f' if raw=='ALUMINIUM' else 'hg.f' if raw=='COPPER' else (str(mapped).lower() if mapped else raw.lower())
    return f"https://stooq.pl/q/a2/?s={symbol}&i=d&t=c&a=ln&z=224&ft=20251204&l=234&d=1&ch=0&f=1&lt=56&r=0&o=1"

def _is_number_text(value: str) -> bool:
    txt = (value or "").strip().replace(",", "")
    if not txt:
        return False
    try:
        float(txt)
        return True
    except Exception:
        return False

def _format_row(cells: list[str], widths: list[int], right_align: list[bool] | None = None) -> str:
    out_cells: list[str] = []
    right_align = right_align or [False] * len(cells)
    for i, (cell, width) in enumerate(zip(cells, widths)):
        txt = str(cell)
        out_cells.append(txt.rjust(width) if right_align[i] else txt.ljust(width))
    return "│ " + " │ ".join(out_cells) + " │"

def _write_table(out, title: str, rows: list[dict[str, str]], columns: list[tuple[str, str]]) -> None:
    out.write(f"\n### {title}\n")
    if not rows:
        out.write("Brak wyników.\n")
        return
    headers = [h for h, _ in columns]
    keys = [k for _, k in columns]
    rows_data = []
    for row in rows:
        vals = [str(row.get(k, "")).replace("\n", " ") for k in keys]
        rows_data.append(vals)
    if tabulate is not None:
        out.write(tabulate(rows_data, headers=headers, tablefmt="github") + "\n")
    else:
        out.write("| " + " | ".join(headers) + " |\n")
        out.write("| " + " | ".join(["---"] * len(headers)) + " |\n")
        for vals in rows_data:
            out.write("| " + " | ".join(vals) + " |\n")

def _append_csv_section(fp: Path, section: str, csv_path: Path, links: set[str], csv_refs: list[Path]) -> None:
    if not csv_path.exists(): return
    with csv_path.open(newline='', encoding='utf-8') as fh: rows=list(csv.DictReader(fh))
    csv_refs.append(csv_path)
    with fp.open('a', encoding='utf-8') as out:
        for r in rows:
            t=r.get('ticker','').strip(); link=_stooq_chart_url(t) if t else ''
            if link:
                links.add(link)
                r["stooq_link"] = f"[stooq]({link})"
            else:
                r["stooq_link"] = ""

        if csv_path.name.endswith("_flips.csv"):
            for r in rows:
                retest_dates = [str(v).strip() for k, v in r.items() if str(k).startswith("retest_date_") and str(v).strip()]
                r["last_valid_retest_pattern_date"] = retest_dates[-1] if retest_dates else "-"
                last_pattern = [str(v).strip() for k, v in r.items() if str(k).startswith("formation_") and str(v).strip()]
                r["last_valid_retest_pattern_name"] = last_pattern[-1] if last_pattern else "-"
                r["jest_marker"] = f"{GRAY_DOT} above" if str(r.get("current_side", "")) == "above" else f"{RED_DOT} below"
            cols = [
                ("Ticker", "ticker"),
                ("Było", "previous_side"),
                ("Jest", "jest_marker"),
                ("Data wybicia", "flip_date"),
                ("Mies. od wybicia", "months_since_flip"),
                ("Retest status", "latest_retest_status"),
                ("Retest count", "valid_retests_count"),
                ("Last valid retest", "last_valid_retest_pattern_date"),
                ("Pattern", "last_valid_retest_pattern_name"),
                ("Link", "stooq_link"),
            ]
            rows = sorted(rows, key=lambda r: (str(r.get("current_side", "")) != "below", -float(str(r.get("months_since_flip", "0") or "0"))))
            title = "WYNIKI 2 ICHIMOKU (po flipie chmury: retest/pattern po wybiciu)" if section == "WYNIKI 2" else "WYNIKI 1 ICHIMOKU (poza chmurą, z warunkami płynności)"
            _write_table(out, title, rows, cols)
        elif csv_path.name.startswith("fibo_search_"):
            for r in rows:
                status = str(r.get("status", ""))
                if status == "valid_reversal":
                    r["status_marker"] = "🟢 valid_reversal"
                elif status == "reached_23_6_waiting_for_61_8":
                    r["status_marker"] = "🟡 waiting_for_61.8"
                else:
                    r["status_marker"] = f"🔴 {status}"
            for r in rows:
                r["incline"] = f"{r.get('incline_start_date','')}->{r.get('incline_end_date','')}"
                try:
                    ratio = float(str(r.get("incline_decline_duration_ratio", "0") or "0"))
                except Exception:
                    ratio = 0.0
                i_d = str(r.get("incline_duration_days", "0") or "0")
                d_d = str(r.get("decline_duration_days", "0") or "0")
                r["ratio_txt"] = f"{i_d}/{d_d} ({ratio:.2f}:1)"
                r["avg10turn"] = "-"
                try:
                    cur = float(str(r.get("current_close", "0") or "0"))
                    f23 = float(str(r.get("fib_23_6", "0") or "0"))
                    f61 = float(str(r.get("fib_61_8", "0") or "0"))
                    dist = abs(cur - f61)
                    band = max(abs(f23 - f61), 1e-9)
                    closeness = max(0.0, 1.0 - (dist / band))
                    marker = "🟢" if closeness >= 0.7 else ("🟡" if closeness >= 0.35 else "🔴")
                    r["near61"] = f"{marker} {closeness * 100:5.1f}%"
                except Exception:
                    r["near61"] = "-"
            cols_w1 = [
                ("Ticker", "ticker"),
                ("Dir", "direction"),
                ("Status", "status_marker"),
                ("Pattern", "reversal_pattern_name"),
                ("Incline", "incline"),
                ("Ratio(d)", "ratio_txt"),
                ("Touched_61.8_date", "first_61_8_touch_date"),
                ("Avg10Turn", "avg10turn"),
                ("Near61.8", "near61"),
                ("Link", "stooq_link"),
            ]
            cols_w2 = [
                ("Ticker", "ticker"),
                ("Dir", "direction"),
                ("Pattern", "reversal_pattern_name"),
                ("Incline", "incline"),
                ("Ratio(d)", "ratio_txt"),
                ("Touched_61.8_date", "first_61_8_touch_date"),
                ("Link", "stooq_link"),
            ]
            if csv_path.name.endswith("_w1.csv"):
                rows_w1 = rows
                rows_w2 = []
            elif csv_path.name.endswith("_w2.csv"):
                rows_w1 = []
                rows_w2 = rows
            else:
                rows_w1 = [r for r in rows if str(r.get("status", "")) == "reached_23_6_waiting_for_61_8"]
                rows_w2 = [r for r in rows if str(r.get("status", "")) == "valid_reversal"]
            def _dedupe(items):
                seen = set()
                out = []
                for it in items:
                    k = (it.get("ticker"), it.get("direction"), it.get("incline"))
                    if k in seen:
                        continue
                    seen.add(k)
                    out.append(it)
                return out
            rows_w1 = _dedupe(rows_w1)
            rows_w2 = _dedupe(rows_w2)
            if rows_w1:
                _write_table(out, "WYNIKI FIBO #1 (status waiting 23.6->61.8, bez starych valid_reversal)", rows_w1, cols_w1)
            if rows_w2:
                _write_table(out, "WYNIKI FIBO #2 (valid formation, last 4 months)", rows_w2, cols_w2)
        else:
            for r in rows:
                side = str(r.get("side", ""))
                r["side_marker"] = f"{GRAY_DOT} above" if side == "above" else (f"{RED_DOT} below" if side == "below" else side)
            th10_vals = {str(r.get("threshold_10d_pln", "")).strip() for r in rows if str(r.get("threshold_10d_pln", "")).strip()}
            th20_vals = {str(r.get("threshold_20d_pln", "")).strip() for r in rows if str(r.get("threshold_20d_pln", "")).strip()}
            low20_desc = "Liczba dni (z ostatnich 20), gdy obrót był poniżej progu 20d."
            # PROGI block is rendered by orchestration layer once per scope.
            cols = [
                ("Ticker", "ticker"),
                ("Pozycja", "side_marker"),
                ("Świece", "respect_days"),
                ("Mies.", "respect_months"),
                ("Start", "start_date"),
                ("Link", "stooq_link"),
            ]
            is_stock_like = any(str(r.get("avg_turnover_10d_pln", "")).strip() for r in rows)
            if is_stock_like:
                cols.insert(6, ("Avg10d PLN", "avg_turnover_10d_pln"))
                cols.insert(7, ("Low<Th20", "below_threshold_days_20d"))
            if is_stock_like and not (len(th10_vals) == 1 and len(th20_vals) == 1):
                cols.extend([("Th10d PLN", "threshold_10d_pln"), ("Th20d PLN", "threshold_20d_pln")])
            rows = sorted(rows, key=lambda r: (str(r.get("side", "")) != "below", -float(str(r.get("respect_months", "0") or "0"))))
            top3 = sorted([r for r in rows if str(r.get("avg_turnover_10d_pln", "")).strip()], key=lambda r: float(str(r.get("avg_turnover_10d_pln", "0")).replace(",", "")), reverse=True)[:3]
            top_keys = {r.get("ticker") for r in top3}
            for r in rows:
                if r.get("ticker") in top_keys:
                    r["avg_turnover_10d_pln"] = f"{GOLD_DOT} {r.get('avg_turnover_10d_pln')}"
            title = "WYNIKI 2 ICHIMOKU (po flipie chmury: retest/pattern po wybiciu)" if section == "WYNIKI 2" else "WYNIKI 1 ICHIMOKU (poza chmurą, z warunkami płynności)"
            _write_table(out, title, rows, cols)

def _extract_progi_from_csv(csv_path: Path) -> tuple[str | None, str | None]:
    if not csv_path.exists():
        return None, None
    with csv_path.open(newline="", encoding="utf-8") as fh:
        rows = list(csv.DictReader(fh))
    th10_vals = {str(r.get("threshold_10d_pln", "")).strip() for r in rows if str(r.get("threshold_10d_pln", "")).strip()}
    th20_vals = {str(r.get("threshold_20d_pln", "")).strip() for r in rows if str(r.get("threshold_20d_pln", "")).strip()}
    if len(th10_vals) == 1 and len(th20_vals) == 1:
        return next(iter(th10_vals)), next(iter(th20_vals))
    return None, None

def _is_ichimoku_csv(name: str) -> bool:
    return name.startswith("search_") and name.endswith(".csv")

def _is_fibo_csv(name: str) -> bool:
    return name.startswith("fibo_search_") and name.endswith(".csv")

def _latest_scope_md(prefix: str, scope: str) -> Path | None:
    keys = _scope_file_keys(scope)
    candidates: list[Path] = []
    for key in keys:
        search_dir = FIBO_SEARCH_OUTPUT_DIR if prefix.startswith("fibo") else ICHIMOKU_SEARCH_OUTPUT_DIR
        candidates.extend([p for p in search_dir.glob(f"{prefix}_{key}_*.md") if p.is_file()])
    if not candidates:
        return None
    return max(candidates, key=lambda p: p.stat().st_mtime)

def _scope_file_keys(scope: str) -> list[str]:
    key = (scope or "").strip().lower()
    aliases = {
        "us100": ["us100", "ndx100", "ndx", "nasdaq100"],
        "dax": ["dax", "dax40"],
        "wig": ["wig"],
        "forex": ["forex", "fx"],
        "commodities": ["commodities", "commodity"],
    }
    return aliases.get(key, [key])

def _allsearch_report_stem(scopes: list[str]) -> str:
    if not scopes:
        return "allsearch_latest"
    normalized = [s.strip().lower() for s in scopes if s.strip()]
    if normalized == ["wig", "dax", "us100", "forex", "commodities"] or normalized == ["all"]:
        return "allsearch_latest_all"
    if len(normalized) == 1:
        return f"allsearch_latest_{normalized[0]}"
    return "allsearch_latest_" + "_".join(normalized)

def _open_existing_allsearch_report(scope: str) -> int:
    normalized = (scope or "all").strip().lower()
    scopes = ["wig", "dax", "us100", "forex", "commodities"] if normalized == "all" else [normalized]
    stem = _allsearch_report_stem(scopes)
    report_html = ALL_REPORT_DIR / "allsearch" / f"{stem}.html"
    if not report_html.exists():
        print(f"[allsearch] report not found: {report_html}")
        return 1
    print(f"[allsearch] opening existing html report: {report_html}")
    _open_html_report(report_html)
    return 0

def _append_md_sections(report: Path, source_md: Path, header: str) -> None:
    if not source_md or not source_md.exists():
        return
    text = source_md.read_text(encoding="utf-8")
    with report.open("a", encoding="utf-8") as out:
        out.write("\n" + text.strip() + "\n")

def _enable_cache_only_if_recent(scope: str, hours: int = 6) -> bool:
    keys = _scope_file_keys(scope)
    candidates: list[Path] = []
    for key in keys:
        candidates += [p for p in ICHIMOKU_SEARCH_OUTPUT_DIR.glob(f"search_{key}_*.md") if p.is_file()]
        candidates += [p for p in FIBO_SEARCH_OUTPUT_DIR.glob(f"fibo_search_{key}_*.md") if p.is_file()]
    if not candidates:
        os.environ.pop("STOCKHELPER_CACHE_ONLY", None)
        return False
    latest = max(candidates, key=lambda p: p.stat().st_mtime)
    now_utc = datetime.now(UTC)
    latest_dt = datetime.fromtimestamp(latest.stat().st_mtime, UTC)
    age_h = (now_utc.timestamp() - latest.stat().st_mtime) / 3600.0
    # Extra guardrails:
    # 1) if a search finished in the last hour -> always use cache
    # 2) if a search was completed today after 18:00 UTC ("market closed") -> cache for the rest of day
    if age_h <= 1.0:
        os.environ["STOCKHELPER_CACHE_ONLY"] = "1"
        print(f"[cache-rule] {scope}: last search {age_h:.2f}h ago ({latest.name}) -> cache-only mode ON (<=1h)")
        return True
    if latest_dt.date() == now_utc.date() and latest_dt.hour >= 18:
        os.environ["STOCKHELPER_CACHE_ONLY"] = "1"
        print(
            f"[cache-rule] {scope}: last search today at {latest_dt.strftime('%H:%M UTC')} ({latest.name})"
            " -> cache-only mode ON (after 18:00)"
        )
        return True
    if age_h <= float(hours):
        os.environ["STOCKHELPER_CACHE_ONLY"] = "1"
        print(f"[cache-rule] {scope}: last search {age_h:.2f}h ago ({latest.name}) -> cache-only mode ON")
        return True
    os.environ.pop("STOCKHELPER_CACHE_ONLY", None)
    print(f"[cache-rule] {scope}: last search {age_h:.2f}h ago ({latest.name}) -> refresh mode ON")
    return False

def _safe_int(v: str, default: int = 0) -> int:
    try:
        return int(float(str(v or default).replace(",", "")))
    except Exception:
        return default

def _format_avg10d_value(value: str) -> str:
    txt = (value or "").strip()
    if not txt or txt == "-":
        return txt
    try:
        number = float(txt.replace(" ", "").replace(",", ""))
    except Exception:
        return txt
    return f"{number:,.0f}".replace(",", ".")

def _open_html_report(path: Path) -> None:
    report_url = _serve_report_locally(path)
    file_url = report_url or path.resolve().as_uri()
    chrome = shutil.which("google-chrome") or shutil.which("chromium") or shutil.which("chromium-browser")
    if chrome:
        try:
            print(f"[allsearch] opening report (blocking window): {path}")
            subprocess.call([chrome, "--new-window", "--app=" + file_url])
            return
        except Exception:
            pass
    firefox = shutil.which("firefox")
    if firefox:
        try:
            print(f"[allsearch] opening report (blocking window): {path}")
            subprocess.call([firefox, "--new-window", file_url])
            return
        except Exception:
            pass
    print(f"[allsearch] opening report via xdg-open: {file_url}")
    subprocess.call(["xdg-open", file_url])

def _serve_report_locally(path: Path) -> str | None:
    rel = path.resolve().relative_to(PROJECT_ROOT.resolve())
    report_url_path = "/".join(rel.parts)
    host = "127.0.0.1"
    candidate_ports = [8765, 8766, 8767, 8768, 8769]

    def _healthy(base_url: str) -> bool:
        try:
            with urlopen(base_url, timeout=0.6) as resp:
                return 200 <= int(getattr(resp, "status", 200)) < 500
        except Exception:
            return False

    for port in candidate_ports:
        base = f"http://{host}:{port}/"
        if _healthy(base):
            return f"http://{host}:{port}/{report_url_path}"
        try:
            subprocess.Popen(
                [
                    sys.executable,
                    str(PROJECT_ROOT / "utilities" / "report_server.py"),
                    "--root",
                    str(PROJECT_ROOT),
                    "--project-root",
                    str(PROJECT_ROOT),
                    "--host",
                    host,
                    "--port",
                    str(port),
                ],
                cwd=str(PROJECT_ROOT),
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
        except Exception:
            continue
        for _ in range(10):
            if _healthy(base):
                return f"http://{host}:{port}/{report_url_path}"
    return None

def _build_html_report(scopes: list[str], output_path: Path) -> None:
    def _parse_md_tables(md_path: Path) -> dict[str, list[dict[str, str]]]:
        out: dict[str, list[dict[str, str]]] = {}
        if not md_path.exists():
            return out
        lines = md_path.read_text(encoding="utf-8").splitlines()
        last_heading = ""
        i = 0
        while i < len(lines):
            line = lines[i].strip()
            if line.startswith("#"):
                last_heading = line.lstrip("#").strip()
            if i + 2 < len(lines) and lines[i].strip().startswith("|") and lines[i + 1].strip().startswith("|"):
                headers = [h.strip() for h in lines[i].strip().strip("|").split("|")]
                separator = [s.strip() for s in lines[i + 1].strip().strip("|").split("|")]
                if headers and separator and all(set(s) <= {"-", ":"} and s for s in separator):
                    rows: list[dict[str, str]] = []
                    j = i + 2
                    while j < len(lines) and lines[j].strip().startswith("|"):
                        vals = [v.strip() for v in lines[j].strip().strip("|").split("|")]
                        if len(vals) == len(headers):
                            rows.append({headers[k]: vals[k] for k in range(len(headers))})
                        j += 1
                    title = last_heading or "TABLE"
                    out.setdefault(title, []).extend(rows)
                    i = j
                    continue
            i += 1
        return out

    rows: list[ScannerRow] = []
    for scope in scopes:
        market = scope.upper()
        i_md = _latest_scope_md("search", scope)
        f_md = _latest_scope_md("fibo_search", scope)
        i_tables = _parse_md_tables(i_md) if i_md else {}
        f_tables = _parse_md_tables(f_md) if f_md else {}
        i_w2 = next((v for k, v in i_tables.items() if "WYNIKI 2" in k.upper()), [])
        i_w1 = next((v for k, v in i_tables.items() if k.upper().strip() == "WYNIKI" or "WYNIKI 1" in k.upper()), [])
        f_w2 = next((v for k, v in f_tables.items() if "WYNIKI FIBO #2" in k.upper()), [])
        f_w1 = next((v for k, v in f_tables.items() if "WYNIKI FIBO #1" in k.upper()), [])
        for r in i_w2:
            t = str(r.get("Ticker", "")).strip()
            rows.append(ScannerRow(
                market=market, scanner="ICHIMOKU", category="retest_breakout", ticker=t,
                status=str(r.get("Latest Retest status", "")), dates={"flip_date": str(r.get("Data wybicia", ""))},
                metrics={"months": str(r.get("Mies. od wybicia", "")), "retest_count": str(r.get("Retest count", "")), "latest_retest_date": str(r.get("Latest Retest date", "")), "latest_retest_pattern": str(r.get("Latest Retest pattern", ""))},
                chart_url=str(r.get("Link", "")), python_command=str(r.get("Python command", "")), priority="MEDIUM"
            ))
        for r in i_w1:
            t = str(r.get("Ticker", "")).strip()
            rows.append(ScannerRow(
                market=market, scanner="ICHIMOKU", category="position", ticker=t,
                status=str(r.get("Pozycja", "")), dates={"start_date": str(r.get("Start", ""))},
                metrics={"candles": str(r.get("Świece", "")), "months": str(r.get("Mies.", "")), "close": str(r.get("Close", "")), "avg10d": str(r.get("Avg10d PLN", "")), "low_th20": str(r.get("Low<Th20", "")), "latest_retest_count": str(r.get("Latest Retest count", "")), "latest_retest_date": str(r.get("Latest Retest date", "")), "latest_retest_pattern": str(r.get("Latest Retest pattern", ""))},
                chart_url=str(r.get("Link", "")), python_command=str(r.get("Python command", "")), priority="LOW"
            ))
        for r in f_w2:
            t = str(r.get("Ticker", "")).strip()
            rows.append(ScannerRow(
                market=market, scanner="FIBO", category="valid", ticker=t, status="valid_reversal",
                pattern=str(r.get("Pattern", "")), direction=str(r.get("Dir", "")),
                dates={"touch_61": str(r.get("Touched_61.8_date", "")), "incline": str(r.get("Incline", ""))},
                metrics={"ratio": str(r.get("Ratio(d)", ""))}, chart_url=str(r.get("Link", "")),
                python_command=str(r.get("Python command", "")), priority="HIGH"
            ))
        for r in f_w1:
            t = str(r.get("Ticker", "")).strip()
            rows.append(ScannerRow(
                market=market, scanner="FIBO", category="waiting", ticker=t, status=str(r.get("Status", "")),
                pattern=str(r.get("Pattern", "")), direction=str(r.get("Dir", "")),
                dates={"touch_61": str(r.get("Touched_61.8_date", "")), "incline": str(r.get("Incline", ""))},
                metrics={"ratio": str(r.get("Ratio(d)", ""))}, chart_url=str(r.get("Link", "")),
                python_command=str(r.get("Python command", "")), priority="MEDIUM"
            ))

        if i_tables or f_tables:
            continue

        ichimoku_csv: list[Path] = []
        fibo_csv: list[Path] = []
        for key in _scope_file_keys(scope):
            ichimoku_csv.extend(ICHIMOKU_SEARCH_OUTPUT_DIR.glob(f"search_{key}_*.csv"))
            fibo_csv.extend(FIBO_SEARCH_OUTPUT_DIR.glob(f"fibo_search_{key}_*.csv"))
        ichimoku_csv = sorted([p for p in ichimoku_csv if p.is_file()], key=lambda p: p.stat().st_mtime)
        fibo_csv = sorted([p for p in fibo_csv if p.is_file()], key=lambda p: p.stat().st_mtime)
        if ichimoku_csv:
            base = [p for p in ichimoku_csv if not p.name.endswith("_flips.csv")]
            flips = [p for p in ichimoku_csv if p.name.endswith("_flips.csv")]
            for p, cat in ([(flips[-1], "retest_breakout")] if flips else []) + ([(base[-1], "position")] if base else []):
                with p.open(newline="", encoding="utf-8") as fh:
                    for r in csv.DictReader(fh):
                        status = str(r.get("latest_retest_status") or r.get("side") or "")
                        prio = "HIGH" if "returned_to_cloud_waiting_for_pattern" in status else ("MEDIUM" if cat == "retest_breakout" else "LOW")
                        rows.append(ScannerRow(
                            market=market, scanner="ICHIMOKU", category=cat, ticker=str(r.get("ticker", "")),
                            status=status, dates={"start_date": str(r.get("start_date", "")), "flip_date": str(r.get("flip_date", ""))},
                            metrics={"candles": str(r.get("respect_days", "")), "months": str(r.get("respect_months", "")), "close": str(r.get("last_close", "")),
                                     "avg10d": str(r.get("avg_turnover_10d_pln", "")), "low_th20": str(r.get("below_threshold_days_20d", "")),
                                     "latest_retest_count": str(r.get("latest_retest_count", "")), "latest_retest_date": str(r.get("last_valid_retest_pattern_date", "")), "latest_retest_pattern": str(r.get("last_valid_retest_pattern_name", ""))},
                            chart_url=_stooq_chart_url(str(r.get("ticker", ""))),
                            python_command=f"python run -c {r.get('ticker','')}",
                            priority=prio))
        if fibo_csv:
            w2 = [p for p in fibo_csv if p.name.endswith("_w2.csv")]
            w1 = [p for p in fibo_csv if p.name.endswith("_w1.csv")]
            generic = [p for p in fibo_csv if not p.name.endswith("_w1.csv") and not p.name.endswith("_w2.csv")]
            ordered_files: list[tuple[Path, str]] = []
            if w2 or w1:
                if w2: ordered_files.append((w2[-1], "valid"))
                if w1: ordered_files.append((w1[-1], "waiting"))
            elif generic:
                ordered_files.append((generic[-1], "mixed"))
            for p, cat in ordered_files:
                with p.open(newline="", encoding="utf-8") as fh:
                    for r in csv.DictReader(fh):
                        st = str(r.get("status", ""))
                        actual_cat = "valid" if st == "valid_reversal" else ("waiting" if st == "reached_23_6_waiting_for_61_8" else cat)
                        rows.append(ScannerRow(
                            market=market, scanner="FIBO", category=actual_cat, ticker=str(r.get("ticker", "")),
                            status=st, pattern=str(r.get("reversal_pattern_name", "")), direction=str(r.get("direction", "")),
                            dates={"touch_61": str(r.get("first_61_8_touch_date", "")), "incline_start": str(r.get("incline_start_date", "")), "incline_end": str(r.get("incline_end_date", ""))},
                            metrics={"ratio": str(r.get("incline_decline_duration_ratio", ""))},
                            chart_url=_stooq_chart_url(str(r.get("ticker", ""))),
                            python_command=str(r.get("python_command", "")),
                            priority="HIGH" if actual_cat == "valid" else "MEDIUM"))
    def key(r: ScannerRow):
        cat_order = {"valid": 0, "retest_breakout": 1, "waiting": 2, "position": 3}
        date = r.dates.get("touch_61") or r.dates.get("flip_date") or r.dates.get("incline_end") or ""
        return (cat_order.get(r.category, 9), date)
    rows = sorted(rows, key=key, reverse=False)
    counts = {
        "ichimoku_active": sum(1 for r in rows if r.scanner == "ICHIMOKU"),
        "ichimoku_retests": sum(1 for r in rows if r.category == "retest_breakout"),
        "fibo_waiting": sum(1 for r in rows if r.scanner == "FIBO" and r.category == "waiting"),
        "fibo_valid": sum(1 for r in rows if r.scanner == "FIBO" and r.category == "valid"),
    }
    by_market = {s.upper(): [r for r in rows if r.market == s.upper()] for s in scopes}
    empty_markets = sum(1 for _, vals in by_market.items() if not vals)
    html_parts = ["<html><head><meta charset='utf-8'><title>StockHelper Scanner Report</title>",
                  "<style>body{font-family:Inter,Arial;margin:0 auto;max-width:1400px;padding:16px;background:#f6f8fb}.cards{display:flex;gap:12px;flex-wrap:wrap}.card{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:10px 14px}.market{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:12px;margin-top:16px}table{width:100%;border-collapse:collapse;font-size:13px;border:1px solid #cbd5e1}th{position:sticky;top:0;background:#f1f5f9}th,td{border:1px solid #e5e7eb;padding:6px;text-align:left}tr:nth-child(even){background:#fafafa}.num{text-align:right}.badge{padding:2px 8px;border-radius:8px;font-size:11px}.high{background:#dcfce7}.medium{background:#fef9c3}.low{background:#e2e8f0}.btn{padding:4px 8px;border:1px solid #cbd5e1;border-radius:6px;text-decoration:none;display:inline-block}.muted{color:#64748b}.subhead{margin:12px 0 6px;font-size:14px;color:#334155;background:#eef2ff;padding:6px 8px;border-left:3px solid #6366f1;border-radius:6px}.legend{background:#fff;border:1px dashed #94a3b8;border-radius:8px;padding:10px 12px}.iconbtn{margin-left:8px;border:none;background:transparent;cursor:pointer;font-size:16px;vertical-align:middle}</style>",
                  "</head><body>"]
    html_parts.append(f"<h1>StockHelper Scanner Report</h1><p>Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S %Z')}</p>")
    html_parts.append("<p class='muted'>🔗 <button class='iconbtn' title='Open all stooq links from all visible tables' onclick='openAllStooqLinks()'>🌐</button> Open all visible stooq chart links (may open many tabs). &nbsp; 📄 <button class='iconbtn' title='Download report as PDF (browser print dialog)' onclick='downloadPdfReport()'>⬇️ PDF</button></p>")
    html_parts.append("<div class='cards'>" + "".join([f"<div class='card'><b>{k.replace('_',' ').title()}</b><div>{v}</div></div>" for k,v in {**counts, 'markets_with_no_results': empty_markets}.items()]) + "</div>")
    html_parts.append(_liquidity_legend_html())
    html_parts.append("<p><input id='q' placeholder='Search ticker/status'> <select id='market'><option value=''>All markets</option>" + "".join([f"<option>{m}</option>" for m in by_market]) + "</select></p>")
    for mkt, mrows in by_market.items():
        html_parts.append(f"<div class='market' data-market-block='{html.escape(mkt)}'><h2>{html.escape(_scope_label(mkt.lower()))}</h2>")
        groups = [("WYNIKI 1 ICHIMOKU (poza chmurą, z warunkami płynności)", [x for x in mrows if x.scanner == "ICHIMOKU" and x.category == "position"]),
                  ("WYNIKI 2 ICHIMOKU (po flipie chmury: retest/pattern po wybiciu)", [x for x in mrows if x.scanner == "ICHIMOKU" and x.category == "retest_breakout"]),
                  ("WYNIKI FIBO #1 (status waiting 23.6->61.8, bez starych valid_reversal)", [x for x in mrows if x.scanner == "FIBO" and x.category == "waiting"]),
                  ("WYNIKI FIBO #2 (valid formation, last 4 months)", [x for x in mrows if x.scanner == "FIBO" and x.category == "valid"])]
        for gname, grows in groups:
            is_i1 = gname.startswith("WYNIKI 1 ICHIMOKU")
            is_i2 = gname.startswith("WYNIKI 2 ICHIMOKU")
            is_f1 = gname.startswith("WYNIKI FIBO #1")
            if is_i1:
                thead = "<tr><th>Ticker</th><th>Pozycja</th><th>Świece</th><th>Mies.</th><th>Start</th><th>Close</th><th>Avg10d PLN</th><th>Low&lt;Th20</th><th>Latest Retest count</th><th>Latest Retest date</th><th>Latest Retest pattern</th><th>Open stooq chart</th><th>stockhelper_chart</th></tr>"
            elif is_i2:
                thead = "<tr><th>Ticker</th><th>Latest Retest status</th><th>Data wybicia</th><th>Mies. od wybicia</th><th>Retest count</th><th>Latest Retest date</th><th>Latest Retest pattern</th><th>Open stooq chart</th><th>stockhelper_chart</th></tr>"
            elif is_f1:
                thead = "<tr><th>Ticker</th><th>Dir</th><th>Status</th><th>Pattern</th><th>Incline</th><th>Ratio(d)</th><th>Touched_61.8_date</th><th>Open stooq chart</th><th>stockhelper_chart</th></tr>"
            else:
                thead = "<tr><th>Ticker</th><th>Dir</th><th>Pattern</th><th>Incline</th><th>Ratio(d)</th><th>Touched_61.8_date</th><th>Open stooq chart</th><th>stockhelper_chart</th></tr>"
            empty_cls = " empty-group" if not grows else ""
            html_parts.append(f"<div class='subhead{empty_cls}' data-empty='{1 if not grows else 0}'>{html.escape(gname)} ({len(grows)}) <button class='iconbtn' title='Open all stooq links from this table' onclick='openTableStooqLinks(this)'>🔗</button></div><div style='overflow:auto'>")
            if not grows:
                html_parts.append("<div class='muted empty-table-msg'>Brak wyników.</div></div>")
                continue
            html_parts.append(f"<table class='data'><thead>{thead}</thead><tbody>")
            for r in grows:
                cmd = html.escape(_chart_command_for_row(r))
                chart_btn = ('<a class="btn" href="'+html.escape(r.chart_url)+'" target="_blank" title="Open stooq chart">📈</a>' if r.chart_url else '')
                if is_i1:
                    avg10d_fmt = _format_avg10d_value(r.metrics.get("avg10d", ""))
                    html_parts.append(f"<tr data-market='{html.escape(r.market)}' data-scanner='{r.scanner}' data-status='{html.escape(r.status)}'><td><b>{html.escape(r.ticker)}</b></td><td>{html.escape(r.status)}</td><td>{html.escape(r.metrics.get('candles',''))}</td><td>{html.escape(r.metrics.get('months',''))}</td><td>{html.escape(r.dates.get('start_date',''))}</td><td>{html.escape(r.metrics.get('close',''))}</td><td>{html.escape(avg10d_fmt)}</td><td>{html.escape(r.metrics.get('low_th20',''))}</td><td>{html.escape(r.metrics.get('latest_retest_count',''))}</td><td>{html.escape(r.metrics.get('latest_retest_date',''))}</td><td>{html.escape(r.metrics.get('latest_retest_pattern',''))}</td><td>{chart_btn}</td><td><code>{cmd[:64]}</code> <button class='btn' onclick='runOrCopy(this)' data-cmd='{cmd}'>Run/Copy</button></td></tr>")
                elif is_i2:
                    html_parts.append(f"<tr data-market='{html.escape(r.market)}' data-scanner='{r.scanner}' data-status='{html.escape(r.status)}'><td><b>{html.escape(r.ticker)}</b></td><td>{html.escape(r.status)}</td><td>{html.escape(r.dates.get('flip_date',''))}</td><td>{html.escape(r.metrics.get('months',''))}</td><td>{html.escape(r.metrics.get('retest_count',''))}</td><td>{html.escape(r.metrics.get('latest_retest_date',''))}</td><td>{html.escape(r.metrics.get('latest_retest_pattern',''))}</td><td>{chart_btn}</td><td><code>{cmd[:64]}</code> <button class='btn' onclick='runOrCopy(this)' data-cmd='{cmd}'>Run/Copy</button></td></tr>")
                elif is_f1:
                    html_parts.append(f"<tr data-market='{html.escape(r.market)}' data-scanner='{r.scanner}' data-status='{html.escape(r.status)}'><td><b>{html.escape(r.ticker)}</b></td><td>{html.escape(r.direction)}</td><td>{html.escape(r.status)}</td><td>{html.escape(r.pattern)}</td><td>{html.escape(r.dates.get('incline',''))}</td><td>{html.escape(r.metrics.get('ratio',''))}</td><td>{html.escape(r.dates.get('touch_61',''))}</td><td>{chart_btn}</td><td><code>{cmd[:64]}</code> <button class='btn' onclick='runOrCopy(this)' data-cmd='{cmd}'>Run/Copy</button></td></tr>")
                else:
                    html_parts.append(f"<tr data-market='{html.escape(r.market)}' data-scanner='{r.scanner}' data-status='{html.escape(r.status)}'><td><b>{html.escape(r.ticker)}</b></td><td>{html.escape(r.direction)}</td><td>{html.escape(r.pattern)}</td><td>{html.escape(r.dates.get('incline',''))}</td><td>{html.escape(r.metrics.get('ratio',''))}</td><td>{html.escape(r.dates.get('touch_61',''))}</td><td>{chart_btn}</td><td><code>{cmd[:64]}</code> <button class='btn' onclick='runOrCopy(this)' data-cmd='{cmd}'>Run/Copy</button></td></tr>")
            html_parts.append("</tbody></table></div>")
        html_parts.append("</div>")
    html_parts.append("<script>function copyCmd(btn){navigator.clipboard.writeText(btn.dataset.cmd||'');btn.textContent='Copied';setTimeout(()=>btn.textContent='Run/Copy',1200);}async function runOrCopy(btn){const c=btn.dataset.cmd||'';if(c){try{await fetch('/run-command?command='+encodeURIComponent(c),{method:'POST'});btn.textContent='Executed';setTimeout(()=>btn.textContent='Run/Copy',1200);}catch(e){copyCmd(btn);}}else{copyCmd(btn);}}function _tableLinks(table){if(!table)return[];return [...table.querySelectorAll('tbody tr')].filter(r=>r.style.display!=='none').map(r=>r.querySelector('a[href*=\"stooq.pl\"]')?.href||'').filter(Boolean);}async function _openLinks(links){const uniq=[...new Set(links)];if(!uniq.length)return;try{const res=await fetch('/open-links',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({links:uniq})});const data=await res.json();alert('Opened '+(data.opened||0)+' link(s) using local StockHelper server.');}catch(e){alert('Failed to open links via local server.');}}function openTableStooqLinks(btn){const table=btn?.closest('.subhead')?.nextElementSibling?.querySelector('table.data');_openLinks(_tableLinks(table));}function openAllStooqLinks(){const links=[...document.querySelectorAll('table.data')].flatMap(t=>_tableLinks(t));_openLinks(links);}function downloadPdfReport(){const d=new Date();const iso=d.toISOString().slice(0,10);const oldTitle=document.title;document.title='stockhelper_report_'+iso;window.print();setTimeout(()=>{document.title=oldTitle;},250);}function num(v){const n=parseFloat((v||'').replace(/[^0-9+\\-.]/g,''));return Number.isFinite(n)?n:null;}function sortTable(table,col){const tb=table.tBodies[0];if(!tb)return;const rows=[...tb.rows];const asc=table.dataset.sortCol==String(col)?(table.dataset.sortDir!=='asc'):true;table.dataset.sortCol=String(col);table.dataset.sortDir=asc?'asc':'desc';rows.sort((a,b)=>{const av=(a.cells[col]?.innerText||'').trim();const bv=(b.cells[col]?.innerText||'').trim();const an=num(av),bn=num(bv);let cmp=0;if(an!==null&&bn!==null){cmp=an-bn;}else{cmp=av.localeCompare(bv,undefined,{numeric:true,sensitivity:'base'});}return asc?cmp:-cmp;});rows.forEach(r=>tb.appendChild(r));table.querySelectorAll('thead th').forEach((h,idx)=>{h.dataset.arrow=idx===col?(asc?'↑':'↓'):'↕';h.textContent=h.dataset.base+' '+h.dataset.arrow;});}const q=document.getElementById('q'),m=document.getElementById('market');function f(){const s=(q.value||'').toLowerCase();document.querySelectorAll('table.data tbody tr').forEach(r=>{const okText=r.innerText.toLowerCase().includes(s);const okM=!m.value||r.dataset.market===m.value;r.style.display=(okText&&okM)?'':'none';});document.querySelectorAll('.market[data-market-block]').forEach(b=>{const bm=b.dataset.marketBlock;const visibleBySelect=(!m.value||bm===m.value);const rows=[...b.querySelectorAll('table.data tbody tr')];const anyVisibleRow=rows.some(tr=>tr.style.display!=='none');const emptyGroups=[...b.querySelectorAll('.subhead[data-empty=\"1\"]')];const showEmptyGroups=!!m.value&&visibleBySelect;emptyGroups.forEach(el=>{const wrapper=el.nextElementSibling;el.style.display=showEmptyGroups?'':'none';if(wrapper)wrapper.style.display=showEmptyGroups?'':'none';});if(!visibleBySelect){b.style.display='';b.style.display='none';return;}if(m.value){b.style.display='';}else{b.style.display=anyVisibleRow?'':'none';}});}document.querySelectorAll('table.data').forEach(table=>{table.querySelectorAll('thead th').forEach((th,colIdx)=>{th.style.cursor='pointer';th.title='Sort';th.dataset.base=th.textContent.trim();th.dataset.arrow='↕';th.textContent=th.dataset.base+' '+th.dataset.arrow;th.addEventListener('click',()=>sortTable(table,colIdx));});});q.oninput=f;m.onchange=f;f();</script></body></html>")
    output_path.write_text("".join(html_parts), encoding="utf-8")

def _run_allsearch_combo(scopes: list[str]) -> int:
    report_dir = ALL_REPORT_DIR / "allsearch"
    report_dir.mkdir(parents=True, exist_ok=True)
    for old in report_dir.glob("*.txt"):
        try:
            old.unlink()
        except Exception:
            pass
    stem = _allsearch_report_stem(scopes)
    report = report_dir / f"{stem}.md"
    report_html = report_dir / f"{stem}.html"
    report.write_text(
        "ALLSEARCH COMBO REPORT\n\n"
        +
        _liquidity_legend_text(),
        encoding="utf-8",
    )

    failures = 0
    csv_refs: list[Path] = []
    all_links: set[str] = set()
    # Phase 1: run all Ichimoku scans first across all scopes.
    print(f"\n\033[1;32m------------------------------------------- ICHIMOKU -------------------------------------------\033[0m")
    code_i = _run_batch_search("ichimoku", scopes, ask_open_links=False)
    if code_i != 0:
        failures += 1

    # Phase 2: run all Fibo scans after all Ichimoku scans are complete.
    print(f"\n\033[1;33m---------------------------------------------- FIBO ----------------------------------------------\033[0m")
    code_f = _run_batch_search("fibo", scopes, ask_open_links=False)
    if code_f != 0:
        failures += 1

    ichimoku_md_by_scope: dict[str, Path | None] = {scope: _latest_scope_md("search", scope) for scope in scopes}
    fibo_md_by_scope: dict[str, Path | None] = {scope: _latest_scope_md("fibo_search", scope) for scope in scopes}

    # Final report sections: keep "table under table" grouped by scope.
    for scope in scopes:
        with report.open("a", encoding="utf-8") as out:
            out.write("\n\n" + _section_banner(f" {_scope_label(scope)} ", width=108, fill="■") + "\n")
            out.write("\n" + _section_banner(" ICHIMOKU ", width=96, fill="-") + "\n")
        md_i = ichimoku_md_by_scope.get(scope)
        if md_i:
            _append_md_sections(report, md_i, f"ICHIMOKU SOURCE ({md_i.name})")
        with report.open("a", encoding="utf-8") as out:
            out.write("\n" + _section_banner(" FIBO ", width=96, fill="-") + "\n")
        md_f = fibo_md_by_scope.get(scope)
        if md_f:
            _append_md_sections(report, md_f, f"FIBO SOURCE ({md_f.name})")

    with report.open("a", encoding="utf-8") as out:
        out.write(f"\n\nŹródło danych CSV instrumentów: {PROJECT_ROOT / 'data'}\n")
    _build_html_report(scopes, report_html)
    print(f"\n[allsearch] combo report saved: {report}")
    print(f"[allsearch] html report saved: {report_html}")
    reopen_scope = "all" if [s.lower() for s in scopes] == ["wig", "dax", "us100", "forex", "commodities"] else ",".join(scopes).lower()
    print(f"[allsearch] rerun command: python run -allsearch {reopen_scope}")
    print(f"[allsearch] reopen html command: python run --open-allsearch-report {reopen_scope}")
    _open_html_report(report_html)
    if all_links:
        try:
            open_all = input("Czy otworzyć wszystkie linki? [y/N]: ").strip().lower()
        except EOFError:
            open_all = "n"
        if open_all == "y":
            for l in sorted(all_links):
                webbrowser.open_new_tab(l)
    print(f"Źródło danych CSV instrumentów: {PROJECT_ROOT / 'data'}")
    return 1 if failures else 0

def _run_batch_search(mode: str, batch: list[str], ask_open_links: bool = True) -> int:
    from scanner_search import run_ichimoku_search, run_fibo_search
    runner = run_ichimoku_search if mode=='ichimoku' else run_fibo_search
    os.environ['STOCKHELPER_BATCH_MODE']='1'; os.environ['STOCKHELPER_DEFER_OPEN_LINKS']='1'
    report_dir = ALL_REPORT_DIR / ("ichimoku_searches" if mode == "ichimoku" else "fibo_searches")
    report_dir.mkdir(parents=True, exist_ok=True)
    for old in report_dir.glob("*.txt"):
        try:
            old.unlink()
        except Exception:
            pass
    report = report_dir / f"{mode}_all_latest.md"
    report.write_text(f"{mode.upper()} ALL COMBO REPORT\n", encoding='utf-8')
    failures=0; all_links=set(); csv_refs: list[Path] = []
    for idx,scope in enumerate(batch,1):
        print(f"\n\033[1m\033[36m=== [{idx}/{len(batch)}] {mode.upper()} :: {scope.upper()} ===\033[0m")
        _enable_cache_only_if_recent(scope, hours=6)
        csv_dir = ICHIMOKU_SEARCH_OUTPUT_DIR if mode=="ichimoku" else FIBO_SEARCH_OUTPUT_DIR
        before_mtime = {p.name: p.stat().st_mtime for p in csv_dir.glob("*.csv")}
        try: code=int(runner(scope))
        except Exception as exc: print(f"[batch] {mode} search failed for {scope}: {exc}"); code=1
        after = sorted(csv_dir.glob("*.csv"), key=lambda p: p.stat().st_mtime)
        new = [p for p in after if p.name not in before_mtime or p.stat().st_mtime > before_mtime[p.name]]
        with report.open("a", encoding="utf-8") as out:
            out.write(f"\n\n{_section_banner(f' {_scope_label(scope)} ', width=108, fill='■')}\n")
        normal = [p for p in new if not p.name.endswith("_flips.csv")]
        flips = [p for p in new if p.name.endswith("_flips.csv")]
        fibo_split_present = any(p.name.endswith("_w1.csv") or p.name.endswith("_w2.csv") for p in new)
        for p in normal + flips:
            if mode == 'ichimoku' and _is_ichimoku_csv(p.name):
                label = "WYNIKI 2" if p.name.endswith("_flips.csv") else "WYNIKI 1"
                _append_csv_section(report, label, p, all_links, csv_refs)
            if mode == 'fibo' and _is_fibo_csv(p.name):
                if fibo_split_present and not (p.name.endswith("_w1.csv") or p.name.endswith("_w2.csv")):
                    continue
                _append_csv_section(report, "FIBO", p, all_links, csv_refs)
        if code!=0: failures+=1
    with report.open("a", encoding="utf-8") as out:
        out.write(f"\n\nŹródło danych CSV instrumentów: {PROJECT_ROOT / 'data'}\n")
    print(f"\n[batch] combo report saved: {report}")
    if batch == ["wig", "dax", "us100", "forex", "commodities"]:
        print(f"[batch] reopen command: python run -{mode}_search all")
    elif len(batch) == 1:
        print(f"[batch] reopen command: python run -{mode}_search {batch[0]}")
    if ask_open_links and all_links:
        try: open_all=input('Czy otworzyć wszystkie linki? [y/N]: ').strip().lower()
        except EOFError: open_all='n'
        if open_all=='y':
            for l in sorted(all_links): webbrowser.open_new_tab(l)
    os.environ.pop('STOCKHELPER_BATCH_MODE',None); os.environ.pop('STOCKHELPER_DEFER_OPEN_LINKS',None)
    os.environ.pop('STOCKHELPER_CACHE_ONLY',None)
    return 1 if failures else 0

def main()->int:
    parser=argparse.ArgumentParser(prog='run',description='Ultra-short launcher. -c opens chart_program.')
    parser.add_argument('-ichimoku_search','-search',dest='search_target'); parser.add_argument('-fibo_search',dest='fibo_search_target',nargs='?',const='single')
    parser.add_argument('-allsearch', dest='allsearch_target', nargs='?', const='all', help='Run ichimoku+fibo combo batch report')
    parser.add_argument('-checkavg', dest='checkavg_target', nargs='?', help='Print Avg10d PLN liquidity metric for one instrument')
    parser.add_argument('--open-allsearch-report', dest='open_allsearch_report', nargs='?', const='all', help='Open existing allsearch HTML report via local server')
    parser.add_argument('-explain',dest='fibo_explain_target'); parser.add_argument('-d','--search-debug',action='store_true'); parser.add_argument('target',nargs='?')
    parser.add_argument('-c','--chart',action='store_true'); parser.add_argument('--debug-stooq',dest='debug_stooq'); parser.add_argument('-inspector','--inspector',action='store_true')
    parser.add_argument('--ichimoku-mode', choices=['on', 'off'], default='off')
    parser.add_argument('--fibo-lines', type=int, default=0)
    parser.add_argument('--fibo-anchor-start')
    parser.add_argument('--fibo-anchor-end')
    parser.add_argument('--fibo-right', action='store_true')
    parser.add_argument('--fetch-older-data', action='store_true', help='Fetch an additional older 364-day window before current oldest cached date.')
    parser.add_argument('--fetch-older-data-scope', choices=['all', 'commodities', 'stocks', 'forex'], default='all', help='Limit older-data fetch to one instrument group.')
    parser.add_argument('--xdist-worker-index', type=int, help='Optional explicit worker index (0-based) for --fetch-older-data sharding.')
    parser.add_argument('--xdist-worker-count', type=int, help='Optional explicit total worker count for --fetch-older-data sharding.')
    parser.add_argument('--fetch-workers', type=int, default=1, help='Local parallel workers for --fetch-older-data when xdist shard is not active.')
    args=parser.parse_args()
    if args.fetch_older_data:
        from chart_program.chart_loader import load_or_update_daily_data, COMMODITY_STOOQ_MAP
        import pandas as pd
        def _commodity_symbol_to_stooq_ticker(symbol: str) -> str:
            raw = (symbol or "").strip().upper()
            if not raw:
                return raw
            # Already stooq-like ticker in file naming style (e.g. CB_F).
            if raw.endswith("_F"):
                return raw.replace("_", ".")
            # Already stooq ticker with dot.
            if raw.endswith(".F"):
                return raw
            mapped = COMMODITY_STOOQ_MAP.get(raw)
            if mapped:
                return str(mapped).upper()
            return raw.replace("^", "")
        def _dedup_key(instrument: str, symbol: str) -> tuple[str, str]:
            s = (symbol or "").strip().upper()
            if instrument == "commodity":
                # Avoid duplicates like AEX.csv and ^AEX.csv and unify *.F ticker notation.
                s = s.replace("^", "").replace("_", ".")
            return instrument, s
        def _xdist_worker_slot() -> tuple[int, int] | None:
            if args.xdist_worker_index is not None and args.xdist_worker_count is not None:
                idx = int(args.xdist_worker_index)
                total = int(args.xdist_worker_count)
                if total > 0 and 0 <= idx < total:
                    return idx, total
                return None

            # pytest-xdist convention: PYTEST_XDIST_WORKER=gw0 and PYTEST_XDIST_WORKER_COUNT=<N>
            worker = (os.getenv("PYTEST_XDIST_WORKER") or os.getenv("XDIST_WORKER") or "").strip()
            total_raw = (os.getenv("PYTEST_XDIST_WORKER_COUNT") or os.getenv("XDIST_WORKER_COUNT") or "").strip()
            if not worker:
                return None
            m = re.fullmatch(r"gw(\d+)", worker)
            if not m:
                return None
            try:
                idx = int(m.group(1))
                total = int(total_raw) if total_raw else 0
            except Exception:
                return None
            if total <= 0:
                return None
            if idx < 0 or idx >= total:
                return None
            return idx, total
        targets: list[tuple[str, str, Path]] = []
        # Keep commodities first (UI/table issues happen there most often).
        groups = [("commodity", PROJECT_ROOT / "data" / "commodities"), ("stock", PROJECT_ROOT / "data" / "stocks"), ("forex", PROJECT_ROOT / "data" / "forex")]
        scope = (args.fetch_older_data_scope or "all").lower()
        if scope == "commodities":
            groups = [("commodity", PROJECT_ROOT / "data" / "commodities")]
        elif scope == "stocks":
            groups = [("stock", PROJECT_ROOT / "data" / "stocks")]
        elif scope == "forex":
            groups = [("forex", PROJECT_ROOT / "data" / "forex")]
        for instrument, folder in groups:
            if not folder.exists():
                continue
            for p in sorted(folder.glob("*.csv")):
                sym = p.stem.replace("_", ".").upper()
                if instrument == "commodity":
                    sym = _commodity_symbol_to_stooq_ticker(sym)
                targets.append((instrument, sym, p))
        deduped: dict[tuple[str, str], tuple[str, str, Path]] = {}
        for instrument, symbol, csv_path in targets:
            # Keep first discovered file as source of truth to avoid alias/duplicate csv paths.
            deduped.setdefault(_dedup_key(instrument, symbol), (instrument, symbol, csv_path))
        targets = sorted(deduped.values(), key=lambda t: (0 if t[0] == "commodity" else 1 if t[0] == "stock" else 2, t[1]))
        xslot = _xdist_worker_slot()
        if xslot:
            worker_idx, worker_total = xslot
            print(f"[fetch-older-data] xdist detected: workers_total={worker_total}, this_worker={worker_idx+1}")
            sharded = [t for i, t in enumerate(targets) if i % worker_total == worker_idx]
            print(f"[fetch-older-data] xdist shard active: worker={worker_idx+1}/{worker_total}, assigned={len(sharded)}/{len(targets)}")
            targets = sharded
        else:
            print(
                "[fetch-older-data] xdist not detected (single-worker mode). "
                f"PYTEST_XDIST_WORKER={os.getenv('PYTEST_XDIST_WORKER','')!r} "
                f"PYTEST_XDIST_WORKER_COUNT={os.getenv('PYTEST_XDIST_WORKER_COUNT','')!r} "
                f"XDIST_WORKER={os.getenv('XDIST_WORKER','')!r} "
                f"XDIST_WORKER_COUNT={os.getenv('XDIST_WORKER_COUNT','')!r}."
            )
            print("[fetch-older-data] Tip: run with pytest -n N or pass --xdist-worker-index/--xdist-worker-count explicitly.")
        if not targets:
            print("[fetch-older-data] No local CSV files found in data/* folders.")
            return 0
        local_workers = max(1, int(args.fetch_workers or 1))
        print(f"[fetch-older-data] Starting older-window fetch for {len(targets)} instruments (local_workers={local_workers}).")
        failures = 0
        data_dir_by_instrument = {
            "commodity": PROJECT_ROOT / "data" / "commodities",
            "stock": PROJECT_ROOT / "data" / "stocks",
            "forex": PROJECT_ROOT / "data" / "forex",
        }
        def _oldest_date_in_csv(path: Path) -> str:
            try:
                if not path.exists():
                    return "-"
                df = pd.read_csv(path)
                if "Date" not in df.columns or df.empty:
                    return "-"
                d = pd.to_datetime(df["Date"], errors="coerce").min()
                if pd.isna(d):
                    return "-"
                return d.date().isoformat()
            except Exception:
                return "-"
        two_years_ago = (pd.Timestamp.utcnow().normalize() - pd.Timedelta(days=730)).date()
        def _fetch_one(instrument: str, symbol: str, source_csv_path: Path) -> tuple[bool, str]:
            try:
                oldest_before = _oldest_date_in_csv(source_csv_path)
                aim_date = "-"
                if oldest_before != "-":
                    try:
                        oldest_before_date = pd.Timestamp(oldest_before).date()
                        if oldest_before_date <= two_years_ago:
                            return True, (
                                f"[fetch-older-data] skip {instrument}:{symbol} "
                                f"last_found_data={oldest_before} reason=already_have_2y_or_more"
                            )
                    except Exception:
                        pass
                if oldest_before != "-":
                    try:
                        aim_date = (pd.Timestamp(oldest_before) - pd.Timedelta(days=364)).date().isoformat()
                    except Exception:
                        aim_date = "-"
                df, csv_path, meta = load_or_update_daily_data(symbol=symbol, instrument_type=instrument, persist=True, fetch_older_data=True)
                return True, (
                    f"[fetch-older-data] ok {instrument}:{symbol} "
                    f"last_found_data={oldest_before} aim_date={aim_date} "
                    f"rows={len(df)} source={meta.get('source')} src_csv={source_csv_path} -> {csv_path}"
                )
            except Exception as exc:
                return False, f"[fetch-older-data] fail {instrument}:{symbol}: {exc}"
        fetch_timeout_s = max(15, int(os.getenv("STOCKHELPER_FETCH_ONE_TIMEOUT_S", "90")))
        if local_workers == 1:
            def _timeout_handler(_signum, _frame):
                raise TimeoutError("fetch_one_timeout")
            try:
                for instrument, symbol, source_csv_path in targets:
                    if hasattr(signal, "SIGALRM"):
                        prev = signal.signal(signal.SIGALRM, _timeout_handler)
                        signal.alarm(fetch_timeout_s)
                    try:
                        ok, line = _fetch_one(instrument, symbol, source_csv_path)
                    except TimeoutError:
                        ok, line = False, (
                            f"[fetch-older-data] fail {instrument}:{symbol}: timeout>{fetch_timeout_s}s "
                            f"(set STOCKHELPER_FETCH_ONE_TIMEOUT_S to adjust)"
                        )
                    finally:
                        if hasattr(signal, "SIGALRM"):
                            signal.alarm(0)
                            signal.signal(signal.SIGALRM, prev)
                    print(line)
                    if not ok:
                        failures += 1
            except KeyboardInterrupt:
                print("[fetch-older-data] Interrupted by user (Ctrl+C).")
                print("[fetch-older-data] Already written CSV updates are kept (no rollback).")
                return 130
        else:
            from concurrent.futures import ThreadPoolExecutor, as_completed
            try:
                with ThreadPoolExecutor(max_workers=min(local_workers, len(targets))) as ex:
                    fut_map = {
                        ex.submit(_fetch_one, instrument, symbol, source_csv_path): (instrument, symbol)
                        for instrument, symbol, source_csv_path in targets
                    }
                    for fut in as_completed(fut_map):
                        ok, line = fut.result()
                        print(line)
                        if not ok:
                            failures += 1
            except KeyboardInterrupt:
                print("[fetch-older-data] Interrupted by user (Ctrl+C).")
                print("[fetch-older-data] Already written CSV updates are kept (no rollback).")
                return 130
        exit_code = 1 if failures else 0
        print(f"[fetch-older-data] completed assigned={len(targets)} failures={failures} exit_code={exit_code}")
        _hard_exit(exit_code)
    if args.search_debug: os.environ['STOCKHELPER_STOOQ_DEBUG']='1'
    if args.open_allsearch_report is not None:
        return _open_existing_allsearch_report(args.open_allsearch_report)
    if args.debug_stooq:
        from utilities.stooq_playwright import debug_stooq_page
        raw = args.debug_stooq.strip(); upper_raw = raw.upper(); mapped = COMMODITY_STOOQ_MAP.get(upper_raw)
        if mapped: symbol_for_debug = str(mapped).lower()
        else:
            values = {str(v).lower() for v in COMMODITY_STOOQ_MAP.values()}
            symbol_for_debug = raw.lower() if raw.lower() in values else raw
        path = debug_stooq_page(symbol_for_debug, interactive_captcha=args.inspector)
        print(f"Stooq debug zapisany: {path}")
        return 0
    if args.search_target:
        if args.search_target.strip().lower()=='all': return _run_batch_search('ichimoku',['wig','dax','us100','forex','commodities'])
        _enable_cache_only_if_recent(args.search_target, hours=6)
        from scanner_search import run_ichimoku_search; return run_ichimoku_search(args.search_target)
    if args.checkavg_target:
        from scanner_search import run_checkavg; return run_checkavg(args.checkavg_target)
    if args.allsearch_target:
        normalized = args.allsearch_target.strip().lower()
        if normalized == "all":
            return _run_allsearch_combo(["wig", "dax", "us100", "forex", "commodities"])
        return _run_allsearch_combo([normalized])
    if args.fibo_explain_target:
        from scanner_search import run_fibo_explain; return run_fibo_explain(args.fibo_search_target or 'single', args.fibo_explain_target)
    if args.fibo_search_target:
        if args.fibo_search_target.strip().lower()=='all': return _run_batch_search('fibo',['wig','dax','us100','forex','commodities'])
        _enable_cache_only_if_recent(args.fibo_search_target, hours=6)
        from scanner_search import run_fibo_search; return run_fibo_search(args.fibo_search_target)
    target=(args.target or '').strip()
    if not target: parser.error('target is required unless -ichimoku_search is used')
    resolved_path=_resolve_existing_config_path(target)
    if args.chart:
        if resolved_path:
            cmd=[sys.executable,'-m','chart_program',resolved_path.stem,'--config',str(resolved_path)]
            instrument_type = _instrument_type_from_path(resolved_path)
            if instrument_type:
                cmd.extend(['--instrument', instrument_type])
        else:
            cmd=[sys.executable,'-m','chart_program',target]
        if args.ichimoku_mode:
            cmd.extend(['--ichimoku-mode', args.ichimoku_mode])
        if args.fibo_lines:
            cmd.extend(['--fibo-lines', str(args.fibo_lines)])
        if args.fibo_anchor_start:
            cmd.extend(['--fibo-anchor-start', args.fibo_anchor_start])
        if args.fibo_anchor_end:
            cmd.extend(['--fibo-anchor-end', args.fibo_anchor_end])
        if args.fibo_right:
            cmd.append('--fibo-right')
    else:
        instrument_type=_instrument_type_from_path(resolved_path) or detect_instrument_type(target,None)
        if resolved_path is None: print(f'Instrument config not found: {target}.'); return 1
        cmd=[sys.executable,str(PROJECT_ROOT/_resolve_runner(instrument_type)),str(resolved_path)]
    return subprocess.call(cmd)
if __name__=='__main__': raise SystemExit(main())
