#!/usr/bin/env python3
import argparse
import subprocess
import sys
from pathlib import Path

from chart_program.instrument_detector import detect_instrument_type

PROJECT_ROOT = Path(__file__).resolve().parent


def _normalize_key(value: str) -> str:
    return "".join(ch for ch in (value or "").lower() if ch.isalnum())


def _match_in_dir(directory: Path, target: str) -> list[Path]:
    key = _normalize_key(target.replace(".py", ""))
    exact = [p for p in directory.glob("*.py") if _normalize_key(p.stem) == key]
    if exact:
        return exact
    return [p for p in directory.glob("*.py") if _normalize_key(p.stem).startswith(key)]


def _detect_by_existing_config(target: str) -> str | None:
    groups = [
        ("stock", PROJECT_ROOT / "configs" / "stocks"),
        ("forex", PROJECT_ROOT / "configs" / "forex"),
        ("commodity", PROJECT_ROOT / "configs" / "commodities"),
    ]
    found: list[tuple[str, Path]] = []
    for instrument_type, directory in groups:
        matches = _match_in_dir(directory, target)
        if len(matches) == 1:
            found.append((instrument_type, matches[0]))
        elif len(matches) > 1:
            # ambiguous inside one class: still treat as found class and let downstream runner report specifics
            found.append((instrument_type, matches[0]))

    if len(found) == 1:
        return found[0][0]
    return None


def _resolve_runner(instrument_type: str) -> str:
    return "main_stock.py" if instrument_type == "stock" else "main.py"


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="run",
        description="Ultra-short launcher: auto-picks main_stock/main by symbol; -c opens chart_program.",
    )
    parser.add_argument("target", help="Config slug/symbol/pair, e.g. ena, eurusd_long, cocoa_short")
    parser.add_argument("-c", "--chart", action="store_true", help="Open chart program instead of direct analysis")
    args = parser.parse_args()

    target = args.target.strip()

    if args.chart:
        cmd = [sys.executable, "-m", "chart_program", target]
    else:
        instrument_type = _detect_by_existing_config(target) or detect_instrument_type(target, None)
        runner = _resolve_runner(instrument_type)
        cmd = [sys.executable, str(PROJECT_ROOT / runner), target]

    return subprocess.call(cmd)


if __name__ == "__main__":
    raise SystemExit(main())
