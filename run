#!/usr/bin/env python3
import argparse
import subprocess
import os
import sys
from pathlib import Path

from chart_program.instrument_detector import detect_instrument_type
from chart_program.chart_loader import COMMODITY_STOOQ_MAP

PROJECT_ROOT = Path(__file__).resolve().parent


def _normalize_key(value: str) -> str:
    return "".join(ch for ch in (value or "").lower() if ch.isalnum())


def _match_in_dir(directory: Path, target: str) -> list[Path]:
    key = _normalize_key(target.replace(".py", ""))
    exact = [p for p in directory.glob("*.py") if _normalize_key(p.stem) == key]
    if exact:
        return exact
    return [p for p in directory.glob("*.py") if _normalize_key(p.stem).startswith(key)]


def _resolve_existing_config_path(target: str) -> Path | None:
    groups = [
        PROJECT_ROOT / "configs" / "stocks",
        PROJECT_ROOT / "configs" / "forex",
        PROJECT_ROOT / "configs" / "commodities",
    ]
    found: list[Path] = []
    for directory in groups:
        matches = _match_in_dir(directory, target)
        if len(matches) == 1:
            found.append(matches[0])
        elif len(matches) > 1:
            found.append(matches[0])

    if len(found) == 1:
        return found[0]
    return None


def _instrument_type_from_path(path: Path | None) -> str | None:
    if not path:
        return None
    parts = [p.lower() for p in path.parts]
    if "stocks" in parts:
        return "stock"
    if "forex" in parts:
        return "forex"
    if "commodities" in parts:
        return "commodity"
    return None


def _resolve_runner(instrument_type: str) -> str:
    return "main_stock.py" if instrument_type == "stock" else "main.py"


def _run_batch_search(mode: str, batch: list[str]) -> int:
    failures = 0
    if mode == "ichimoku":
        from scanner_search import run_ichimoku_search as runner
    else:
        from scanner_search import run_fibo_search as runner

    labels = ", ".join(batch)
    print(f"[batch] {mode} search scope: {labels}")
    for idx, scope in enumerate(batch, start=1):
        print(f"\n\033[1m\033[36m=== [{idx}/{len(batch)}] {mode.upper()} :: {scope.upper()} ===\033[0m")
        try:
            code = int(runner(scope))
        except Exception as exc:
            print(f"[batch] {mode} search failed for {scope}: {exc}")
            code = 1
        if code != 0:
            failures += 1
    if failures:
        print(f"[batch] completed with failures: {failures}/{len(batch)}")
        return 1
    print(f"[batch] completed successfully: {len(batch)}/{len(batch)}")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(prog="run", description="Ultra-short launcher. -c opens chart_program.")
    parser.add_argument("-ichimoku_search", "-search", dest="search_target", help="Run ichimoku scanner for index/commodities/forex")
    parser.add_argument("-fibo_search", dest="fibo_search_target", nargs="?", const="single", help="Run fibonacci pullback scanner for index/commodities/forex")
    parser.add_argument("-explain", dest="fibo_explain_target", help="Explain fibo classification for a single symbol (auto-uses single scope when -fibo_search is omitted)")
    parser.add_argument("-d", "--search-debug", action="store_true", help="Verbose Stooq scraping logs for -ichimoku_search")
    parser.add_argument("target", nargs="?", help="Config slug/symbol/pair, e.g. ena, eurusd_long, cocoa_short")
    parser.add_argument("-c", "--chart", action="store_true", help="Open chart program instead of direct analysis")
    parser.add_argument("--debug-stooq", dest="debug_stooq", help="Dump Stooq page debug artifacts for symbol")
    parser.add_argument("-inspector", "--inspector", action="store_true", help="Enable interactive captcha inspector for Stooq")
    args = parser.parse_args()

    if args.search_debug:
        os.environ["STOCKHELPER_STOOQ_DEBUG"] = "1"

    if args.debug_stooq:
        from utilities.stooq_playwright import debug_stooq_page
        raw = args.debug_stooq.strip()
        upper_raw = raw.upper()
        mapped = COMMODITY_STOOQ_MAP.get(upper_raw)
        if mapped:
            symbol_for_debug = str(mapped).lower()
        else:
            values = {str(v).lower() for v in COMMODITY_STOOQ_MAP.values()}
            symbol_for_debug = raw.lower() if raw.lower() in values else raw
        path = debug_stooq_page(symbol_for_debug, interactive_captcha=args.inspector)
        print(f"Stooq debug zapisany: {path}")
        return 0

    if args.search_target:
        normalized = args.search_target.strip().lower()
        if normalized == "all":
            return _run_batch_search("ichimoku", ["wig", "dax", "us100", "forex", "commodities"])
        from scanner_search import run_ichimoku_search
        return run_ichimoku_search(args.search_target)
    if args.fibo_explain_target:
        from scanner_search import run_fibo_explain
        explain_scope = args.fibo_search_target or "single"
        return run_fibo_explain(explain_scope, args.fibo_explain_target)
    if args.fibo_search_target:
        normalized = args.fibo_search_target.strip().lower()
        if normalized == "all":
            return _run_batch_search("fibo", ["wig", "dax", "us100", "forex", "commodities"])
        from scanner_search import run_fibo_search
        return run_fibo_search(args.fibo_search_target)

    target = (args.target or "").strip()
    if not target:
        parser.error("target is required unless -ichimoku_search is used")
    resolved_path = _resolve_existing_config_path(target)

    if args.chart:
        if resolved_path:
            chart_target = resolved_path.stem
            cmd = [sys.executable, "-m", "chart_program", chart_target, "--config", str(resolved_path)]
            instrument_type = _instrument_type_from_path(resolved_path)
            if instrument_type:
                cmd.extend(["--instrument", instrument_type])
        else:
            cmd = [sys.executable, "-m", "chart_program", target]
    else:
        instrument_type = _instrument_type_from_path(resolved_path) or detect_instrument_type(target, None)
        if resolved_path is None:
            print(
                f"Instrument config not found: {target}. "
                f"Please use `python run -c {target}` and finish chart workflow, "
                "or create a config manually."
            )
            return 1
        runner = _resolve_runner(instrument_type)
        arg = str(resolved_path) if resolved_path else target
        cmd = [sys.executable, str(PROJECT_ROOT / runner), arg]

    return subprocess.call(cmd)


if __name__ == "__main__":
    raise SystemExit(main())
