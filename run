PROJECT_ROOT = Path(__file__).resolve().parent
SEARCH_OUTPUT_DIR = PROJECT_ROOT / "chart_program" / "data" / "search"
ICHIMOKU_SEARCH_OUTPUT_DIR = SEARCH_OUTPUT_DIR / "ichimoku"
FIBO_SEARCH_OUTPUT_DIR = SEARCH_OUTPUT_DIR / "fibo"
ALL_REPORT_DIR = PROJECT_ROOT / "chart_program" / "data" / "all_insturments_search"
ANSI_RESET="\033[0m"; ANSI_BOLD="\033[1m"; ANSI_CYAN="\033[36m"
GOLD_DOT = "🟨"
RED_DOT = "🔴"
GRAY_DOT = "⚪"


def _hard_exit(code: int) -> NoReturn:
    try:
        sys.stdout.flush()
        sys.stderr.flush()
    except Exception:
        pass
    os._exit(int(code))
GDP_PPP_VALUE = {
    "PL": 2120569,
    "US": 31821293,
    "DE": 6323531,
    "FR": 4657190,
    "CN": 43491520,
}
@dataclass
class ScannerRow:
    market: str
    scanner: str
    category: str
    ticker: str
    status: str
    pattern: str = ""
    direction: str = ""
    dates: dict[str, str] = field(default_factory=dict)
    metrics: dict[str, str] = field(default_factory=dict)
    chart_url: str | None = None
    python_command: str | None = None
    priority: str = "LOW"

def _chart_command_for_row(row: ScannerRow) -> str:
    ticker = (row.ticker or "").strip()
    if not ticker:
        return ""
    ticker_cmd = ticker
    market = (row.market or "").upper()
    if market == "COMMODITIES":
        mapped = COMMODITY_STOOQ_MAP.get(ticker.upper())
        if mapped:
            ticker_cmd = str(mapped).upper()
    instrument = "stock" if market in {"WIG", "DAX", "US100"} else ("forex" if market == "FOREX" else ("commodity" if market == "COMMODITIES" else "stock"))
    if row.scanner == "ICHIMOKU":
        return f"python run -c {ticker_cmd} --ichimoku-mode on"
    if row.scanner == "FIBO":
        incline = (row.dates.get("incline", "") or "").strip()
        if "->" in incline:
            start, end = [p.strip() for p in incline.split("->", 1)]
            if start and end:
                return f"python run -c {ticker_cmd} --ichimoku-mode off --fibo-lines 5 --fibo-anchor-start {start} --fibo-anchor-end {end} --fibo-right"
        return f"python run -c {ticker_cmd} --ichimoku-mode off --fibo-lines 5"
    return f"python run -c {ticker_cmd}"
def _section_banner(name: str, width: int = 84, fill: str = "=") -> str:
    label = f" {name.strip().upper()} "
    if len(label) >= width:
        return label
    left = (width - len(label)) // 2
    right = width - len(label) - left
    return f"{fill * left}{label}{fill * right}"

def _scope_label(scope: str) -> str:
    s = scope.upper()
    flags = {"WIG": "🇵🇱", "DAX": "🇩🇪", "US100": "🇺🇸", "FOREX": "💱", "COMMODITIES": "🛢️"}
    return f"{flags.get(s, '📊')} {s}"

def _liquidity_legend_html() -> str:
    base = GDP_PPP_VALUE["PL"]
    multipliers = {
        "WIG/PL": GDP_PPP_VALUE["PL"] / base,
        "DAX/DE": GDP_PPP_VALUE["DE"] / base,
        "US100/US": GDP_PPP_VALUE["US"] / base,
    }
    def _fmt(v: float) -> str:
        return f"{v:,.0f}".replace(",", " ")
    fibo_examples = ", ".join([f"{k}: ×{m:.2f} = {_fmt(500000*m)} PLN" for k, m in multipliers.items()])
    ichi_examples = ", ".join([f"{k}: ×{m:.2f} = {_fmt(700000*m)} PLN" for k, m in multipliers.items()])
    low20_examples = ", ".join([f"{k}: ×{m:.2f} = {_fmt(300000*m)} PLN" for k, m in multipliers.items()])
    return (
        "<div class='legend muted'><b>Legenda (progi)</b><br>"
        f"🟨 • Fibo: próg płynności Th10d (ostatnie 10 świeczek) = bazowo 500000 PLN × mnożnik PKB kraju ({fibo_examples}).<br>"
        f"☁️ • Ichimoku: próg płynności = 700000 PLN × mnożnik PKB kraju ({ichi_examples}).<br>"
        f"🧪 • Low&lt;Th20: liczba dni z ostatnich 20 poniżej progu 300000 PLN × mnożnik kraju ({low20_examples}) — nie może być więcej niż 2."
        "</div>"
    )

