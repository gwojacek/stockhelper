def _expected_scope_csv_paths(scope: str) -> list[Path]:
    try:
        from scanner_search import _get_members
        group, members, _source, exchange_suffix = _get_members(scope)
    except Exception:
        return []
    out: list[Path] = []
    for ticker in members:
        if group == "forex":
            instrument = "forex"
        elif group in {"commodities", "indexes"}:
            instrument = "commodity"
        elif group == "single":
            detected = detect_instrument_type(ticker, None)
            instrument = "commodity" if detected == "commodity" else ("forex" if detected == "forex" else "stock")
        else:
            instrument = "stock"
        symbol = ticker
        if instrument == "stock" and exchange_suffix and not ticker.endswith(exchange_suffix.upper()):
            symbol = f"{ticker}{exchange_suffix}"
        if instrument == "stock" and "." not in symbol and len(symbol) <= 5:
            symbol = f"{symbol}.WA"
        if instrument == "commodity" and group != "indexes" and ticker.upper() not in YAHOO_PRIMARY_COMMODITIES:
            symbol = str(COMMODITY_STOOQ_MAP.get(ticker.upper(), symbol)).upper()
        out.append(local_csv_path_for_symbol(symbol, instrument))
    return out


def _retry_missing_scope_csvs_once(scope: str) -> bool:
    paths = _expected_scope_csv_paths(scope)
    missing = [p for p in paths if not _csv_has_data(p)]
    if not missing:
        return True
    print(f"[batch] {scope}: retrying {len(missing)} missing CSV(s) once: {', '.join(p.name for p in missing[:8])}{' ...' if len(missing)>8 else ''}")
    try:
        from chart_program.chart_loader import load_or_update_daily_data
        for p in missing:
            parent = p.parent.name
            instrument = "commodity" if parent in {"commodities", "indexes"} else ("forex" if parent == "forex" else "stock")
            symbol = p.stem.replace("_", ".")
            load_or_update_daily_data(symbol=symbol, instrument_type=instrument, persist=True, fetch_older_data=False)
    except Exception as exc:
        print(f"[batch] {scope}: missing-CSV retry failed: {exc}")
    still_missing = [p for p in paths if not _csv_has_data(p)]
    if still_missing:
        print(f"[batch] {scope}: CSV cache still incomplete ({len(still_missing)} missing).")
        return False
    print(f"[batch] {scope}: missing CSV retry completed.")
    return True

def _run_allsearch_combo(scopes: list[str], force_cache_only: bool = False) -> int:
    report_dir = ALL_REPORT_DIR / "allsearch"
    report_dir.mkdir(parents=True, exist_ok=True)
    for old in report_dir.glob("*.txt"):
        try:
            old.unlink()
        except Exception:
            pass
    stem = _allsearch_report_stem(scopes)
    report = report_dir / f"{stem}.md"
    report_html = report_dir / f"{stem}.html"
    report.write_text(
        "ALLSEARCH COMBO REPORT\n\n"
        +
        _liquidity_legend_text(),
        encoding="utf-8",
    )

    failures = 0
    csv_refs: list[Path] = []
    all_links: set[str] = set()
    # Phase 1: run all Ichimoku scans first across all scopes.
    print(f"\n\033[1;32m------------------------------------------- ICHIMOKU -------------------------------------------\033[0m")
    code_i = _run_batch_search("ichimoku", scopes, ask_open_links=False, force_cache_only=force_cache_only, strict_cache_only=force_cache_only)
    if code_i != 0:
        print("[allsearch] Ichimoku phase failed/stopped; aborting without opening stale/partial HTML report.")
        return 1

    # Phase 2: run all Fibo scans after all Ichimoku scans are complete.
    print(f"\n\033[1;33m---------------------------------------------- FIBO ----------------------------------------------\033[0m")
    code_f = _run_batch_search("fibo", scopes, ask_open_links=False, force_cache_only=force_cache_only, strict_cache_only=force_cache_only)
    if code_f != 0:
        print("[allsearch] FIBO phase failed/stopped; aborting without opening stale/partial HTML report.")
        return 1

    ichimoku_md_by_scope: dict[str, Path | None] = {scope: _latest_scope_md("search", scope) for scope in scopes}
    fibo_md_by_scope: dict[str, Path | None] = {scope: _latest_scope_md("fibo_search", scope) for scope in scopes}

    # Final report sections: keep "table under table" grouped by scope.
    for scope in scopes:
        with report.open("a", encoding="utf-8") as out:
            out.write("\n\n" + _section_banner(f" {_scope_label(scope)} ", width=108, fill="■") + "\n")
            out.write("\n" + _section_banner(" ICHIMOKU ", width=96, fill="-") + "\n")
        md_i = ichimoku_md_by_scope.get(scope)
        if md_i:
            _append_md_sections(report, md_i, f"ICHIMOKU SOURCE ({md_i.name})")
        with report.open("a", encoding="utf-8") as out:
            out.write("\n" + _section_banner(" FIBO ", width=96, fill="-") + "\n")
        md_f = fibo_md_by_scope.get(scope)
        if md_f:
            _append_md_sections(report, md_f, f"FIBO SOURCE ({md_f.name})")

    with report.open("a", encoding="utf-8") as out:
        out.write(f"\n\nŹródło danych CSV instrumentów: {CSV_DATA_DIR}\n")
    allsearch_timestamp = datetime.now()
    troj_fibo, troj_ichimoku = _write_trojpolowki_reports(scopes, allsearch_timestamp)
    _build_html_report(scopes, report_html)
    print(f"\n[allsearch] combo report saved: {report}")
    print(f"[allsearch] Trójpolówki Fibo saved: {troj_fibo}")
    print(f"[allsearch] Trójpolówki Ichimoku saved: {troj_ichimoku}")
    print(f"[allsearch] html report saved: {report_html}")
    reopen_scope = "all" if [s.lower() for s in scopes] == DEFAULT_ALLSEARCH_SCOPES else ",".join(scopes).lower()
    print(f"[allsearch] rerun command: python run -allsearch {reopen_scope}")
    print(f"[allsearch] reopen html command: python run --open-allsearch-report {reopen_scope}")
    report_url = _open_html_report(report_html)
    keep_code = _wait_for_report_server(report_url)
    if keep_code:
        return keep_code
    if all_links:
        try:
            open_all = input("Czy otworzyć wszystkie linki? [y/N]: ").strip().lower()
        except EOFError:
            open_all = "n"
        if open_all == "y":
            for l in sorted(all_links):
                webbrowser.open_new_tab(l)
    print(f"Źródło danych CSV instrumentów: {CSV_DATA_DIR}")
    return 1 if failures else 0

def _run_batch_search(mode: str, batch: list[str], ask_open_links: bool = True, force_cache_only: bool = False, strict_cache_only: bool = False) -> int:
    from scanner_search import run_ichimoku_search, run_fibo_search
    runner = run_ichimoku_search if mode=='ichimoku' else run_fibo_search
    os.environ['STOCKHELPER_BATCH_MODE']='1'; os.environ['STOCKHELPER_DEFER_OPEN_LINKS']='1'
    report_dir = ALL_REPORT_DIR / ("ichimoku_searches" if mode == "ichimoku" else "fibo_searches")
    report_dir.mkdir(parents=True, exist_ok=True)
    for old in report_dir.glob("*.txt"):
        try:
            old.unlink()
        except Exception:
            pass
    report = report_dir / f"{mode}_all_latest.md"
    report.write_text(f"{mode.upper()} ALL COMBO REPORT\n", encoding='utf-8')
    failures=0; all_links=set(); csv_refs: list[Path] = []
    for idx,scope in enumerate(batch,1):
        print(f"\n\033[1m\033[36m=== [{idx}/{len(batch)}] {mode.upper()} :: {scope.upper()} ===\033[0m")
        if force_cache_only:
            if strict_cache_only or _scope_has_complete_cache(scope):
                os.environ["STOCKHELPER_CACHE_ONLY"] = "1"
                os.environ.pop("STOCKHELPER_FORCE_REMOTE_REFRESH", None)
                label = "strict cache-only" if strict_cache_only else "cache-only"
                print(f"[cache-rule] {scope}: {label} mode ON for {mode} phase.")
            else:
                os.environ.pop("STOCKHELPER_CACHE_ONLY", None)
                print(f"[cache-rule] {scope}: cache-only overridden -> refresh mode ON (incomplete cache).")
        else:
            os.environ.pop("STOCKHELPER_CACHE_ONLY", None)
            os.environ.pop("STOCKHELPER_FORCE_REMOTE_REFRESH", None)
            print(f"[cache-rule] {scope}: standalone scope probe will decide refresh/cache mode.")
        csv_dir = ICHIMOKU_SEARCH_OUTPUT_DIR if mode=="ichimoku" else FIBO_SEARCH_OUTPUT_DIR
        before_mtime = {p.name: p.stat().st_mtime for p in csv_dir.glob("*.csv")}
        try: code=int(runner(scope))
        except Exception as exc: print(f"[batch] {mode} search failed for {scope}: {exc}"); code=1
        if code == 0:
            # Missing CSVs should be visible, but they should not abort allsearch.
            # Individual scanners already report per-instrument failures; continuing
            # allows the Fibo phase and final HTML report to be produced from the
            # instruments that did load successfully.
            _retry_missing_scope_csvs_once(scope)
        after = sorted(csv_dir.glob("*.csv"), key=lambda p: p.stat().st_mtime)
        new = [p for p in after if p.name not in before_mtime or p.stat().st_mtime > before_mtime[p.name]]
        with report.open("a", encoding="utf-8") as out:
            out.write(f"\n\n{_section_banner(f' {_scope_label(scope)} ', width=108, fill='■')}\n")
        normal = [p for p in new if not p.name.endswith("_flips.csv")]
        flips = [p for p in new if p.name.endswith("_flips.csv")]
        fibo_split_present = any(p.name.endswith("_w1.csv") or p.name.endswith("_w2.csv") for p in new)
        for p in normal + flips:
            if mode == 'ichimoku' and _is_ichimoku_csv(p.name):
                label = "WYNIKI 2" if p.name.endswith("_flips.csv") else "WYNIKI 1"
                _append_csv_section(report, label, p, all_links, csv_refs)
            if mode == 'fibo' and _is_fibo_csv(p.name):
                if fibo_split_present and not (p.name.endswith("_w1.csv") or p.name.endswith("_w2.csv")):
                    continue
                _append_csv_section(report, "FIBO", p, all_links, csv_refs)
        if code!=0:
            failures+=1
            print(f"[batch] aborting remaining scopes after {mode}::{scope} failed/stopped.")
            break
    with report.open("a", encoding="utf-8") as out:
        out.write(f"\n\nŹródło danych CSV instrumentów: {CSV_DATA_DIR}\n")
    print(f"\n[batch] combo report saved: {report}")
    if batch == DEFAULT_ALLSEARCH_SCOPES:
        print(f"[batch] reopen command: python run -{mode}_search all")
    elif len(batch) == 1:
        print(f"[batch] reopen command: python run -{mode}_search {batch[0]}")
    if ask_open_links and all_links:
        try: open_all=input('Czy otworzyć wszystkie linki? [y/N]: ').strip().lower()
        except EOFError: open_all='n'
        if open_all=='y':
            for l in sorted(all_links): webbrowser.open_new_tab(l)
    os.environ.pop('STOCKHELPER_BATCH_MODE',None); os.environ.pop('STOCKHELPER_DEFER_OPEN_LINKS',None)
    os.environ.pop('STOCKHELPER_CACHE_ONLY',None)
    os.environ.pop('STOCKHELPER_FORCE_REMOTE_REFRESH',None)
    return 1 if failures else 0

def main()->int:
    parser=argparse.ArgumentParser(prog='run',description='Ultra-short launcher. -c opens chart_program.')
    parser.add_argument('-ichimoku_search','-search',dest='search_target'); parser.add_argument('-fibo_search',dest='fibo_search_target',nargs='?',const='single')
    parser.add_argument('-allsearch', dest='allsearch_target', nargs='?', const='all', help='Run ichimoku+fibo combo batch report')
    parser.add_argument('-onlycache', '--onlycache', action='store_true', help='Use local CSV cache only; skip remote freshness probes/updates (works for commodities too).')
    parser.add_argument('-checkavg', dest='checkavg_target', nargs='?', help='Print Avg10d PLN liquidity metric for one instrument')
    parser.add_argument('--open-allsearch-report', dest='open_allsearch_report', nargs='?', const='all', help='Open existing allsearch HTML report via local server')
    parser.add_argument('--journal-html', action='store_true', help='Open the transaction journal HTML only.')
    parser.add_argument('--journal-pdf', action='store_true', help='Open the transaction journal HTML and use the PDF button/print dialog to save it as PDF.')
    parser.add_argument('-explain',dest='fibo_explain_target'); parser.add_argument('-d','--search-debug',action='store_true'); parser.add_argument('target',nargs='?'); parser.add_argument('chart_modifier', nargs='?', choices=['cfd', 'CFD'], help='Use after -c target to open a stock as CFD/commodity mode.')
    parser.add_argument('-c','--chart',action='store_true'); parser.add_argument('--debug-stooq',dest='debug_stooq'); parser.add_argument('--debug-stooq-fetch',action='store_true',help='When used with --debug-stooq, merge fetched visible Stooq rows into the matching commodity CSV.'); parser.add_argument('-inspector','--inspector',action='store_true')
    parser.add_argument('--ichimoku-mode', choices=['on', 'off'], default='off')
    parser.add_argument('--fibo-lines', type=int, default=0)
    parser.add_argument('--fibo-anchor-start')
    parser.add_argument('--fibo-anchor-end')
    parser.add_argument('--fibo-right', action='store_true')
    parser.add_argument('--wedge-lines', action='store_true')
    parser.add_argument('--wedge-upper-start')
    parser.add_argument('--wedge-upper-end')
    parser.add_argument('--wedge-lower-start')
    parser.add_argument('--wedge-lower-end')
    parser.add_argument('--wedge-right', action='store_true')
    parser.add_argument('--journal-close-mode', action='store_true', help='Open chart in journal close-adjust mode.')
    parser.add_argument('--journal-entry-id')
    parser.add_argument('--journal-entry-price')
    parser.add_argument('--journal-direction', choices=['long', 'short'])
    parser.add_argument('--journal-close-price')
    parser.add_argument('--journal-stop-loss')
    parser.add_argument('--fetch-older-data', action='store_true', help='Fetch an additional older window (up to ~364+180 days total span target) before current oldest cached date.')
    parser.add_argument('--fetch-older-data-scope', choices=['all', 'commodities', 'stocks', 'forex'], default='all', help='Limit older-data fetch to one instrument group.')
    parser.add_argument('--xdist-worker-index', type=int, help='Optional explicit worker index (0-based) for --fetch-older-data sharding.')
    parser.add_argument('--xdist-worker-count', type=int, help='Optional explicit total worker count for --fetch-older-data sharding.')
    parser.add_argument('--fetch-workers', type=int, default=1, help='Local parallel workers for --fetch-older-data when xdist shard is not active.')
    parser.add_argument('--scan-workers', type=int, help='Override scanner worker count for search/allsearch phases (use 1 for sequential scanning).')
    parser.add_argument('--download-wig-bulk', action='store_true', help='Download Stooq d_pl_txt bulk archive and replace WSE stock CSVs plus WSE index CSVs such as data/csv/commodities/WIG20.csv.')
    parser.add_argument('--stooq-bulk-zip', help='Import an already-downloaded Stooq d_pl_txt zip instead of downloading it.')
    parser.add_argument('--trim-wig-csvs', action='store_true', help='Trim local data/csv/stocks/*_WA.csv files to the last --wig-trim-years years without downloading bulk data.')
    parser.add_argument('--wig-trim-years', type=int, default=2, help='Years to keep when trimming WIG stock CSVs (default: 2).')
    args=parser.parse_args()
    if args.inspector:
        os.environ['STOCKHELPER_STOOQ_BULK_INSPECTOR'] = '1'
    else:
        os.environ.pop('STOCKHELPER_STOOQ_BULK_INSPECTOR', None)
    if args.scan_workers is not None:
        os.environ['STOCKHELPER_SCAN_WORKERS'] = str(max(1, int(args.scan_workers)))
    else:
        os.environ.pop('STOCKHELPER_SCAN_WORKERS', None)
    if args.journal_html or args.journal_pdf:
        from journal import write_html
        path = write_html()
        url = _serve_report_locally(path)
        if url:
            webbrowser.open_new_tab(url)
            print(f"[journal] opened HTML: {url}")
            print("[journal] update/delete/review actions are served by the local report server.")
        else:
            webbrowser.open(path.resolve().as_uri())
            print(f"[journal] opened HTML: {path}")
            print("[journal] warning: local report server unavailable; update/delete/review buttons need the served URL.")
        if args.journal_pdf:
            print("[journal] click Download PDF in the opened HTML, or use browser Print → Save as PDF.")
        return 0
    if args.trim_wig_csvs:
        from utilities.stooq_playwright import trim_wig_stock_csvs
        result = trim_wig_stock_csvs(stocks_dir=CSV_DATA_DIR / 'stocks', years=args.wig_trim_years)
        print(
            f"[stooq-bulk] trim completed scanned={result['scanned']} trimmed={result['trimmed']} "
            f"skipped={result['skipped']} rows={result['rows_before']}->{result['rows_after']} "
            f"cutoff={result['cutoff']} stocks_dir={result['stocks_dir']}"
        )
        return 0
    if args.download_wig_bulk or args.stooq_bulk_zip:
        from utilities.stooq_playwright import download_and_import_stooq_wig_bulk_data, import_stooq_wig_bulk_zip
        if args.stooq_bulk_zip:
            result = import_stooq_wig_bulk_zip(
                Path(args.stooq_bulk_zip),
                stocks_dir=CSV_DATA_DIR / 'stocks',
                commodities_dir=CSV_DATA_DIR / 'commodities',
            )
        else:
            result = download_and_import_stooq_wig_bulk_data(
                stocks_dir=CSV_DATA_DIR / 'stocks',
                commodities_dir=CSV_DATA_DIR / 'commodities',
                interactive=args.inspector,
            )
        print(
            f"[stooq-bulk] completed written={result['written']} skipped={result['skipped']} "
            f"members={result['members']} indices_written={result.get('indices_written', 0)} "
            f"trimmed={result.get('trimmed', 0)}/{result.get('trim_scanned', 0)} "
            f"cutoff={result.get('trim_cutoff', '-')} stocks_dir={result['stocks_dir']}"
        )
        return 0
    if args.onlycache:
        os.environ['STOCKHELPER_CACHE_ONLY'] = '1'
        os.environ['STOCKHELPER_USER_ONLYCACHE'] = '1'
        os.environ.pop('STOCKHELPER_FORCE_REMOTE_REFRESH', None)
        print('[cache-rule] onlycache requested -> cache-only mode ON; skipping refresh probes.')
    if args.fetch_older_data:
        from chart_program.chart_loader import load_or_update_daily_data
        import pandas as pd
        def _commodity_symbol_to_stooq_ticker(symbol: str) -> str:
            raw = (symbol or "").strip().upper()
            if not raw:
                return raw
            # Already stooq-like ticker in file naming style (e.g. CB_F).
            if raw.endswith("_F"):
                return raw.replace("_", ".")
            # Already stooq ticker with dot.
            if raw.endswith(".F"):
                return raw
            if raw in YAHOO_PRIMARY_COMMODITIES:
                return raw
            mapped = COMMODITY_STOOQ_MAP.get(raw)
            if mapped:
                return str(mapped).upper()
            return raw.replace("^", "")
        def _dedup_key(instrument: str, symbol: str) -> tuple[str, str]:
            s = (symbol or "").strip().upper()
            if instrument == "commodity":
                # Avoid duplicates like AEX.csv and ^AEX.csv and unify *.F ticker notation.
                s = s.replace("^", "").replace("_", ".")
            return instrument, s
        def _xdist_worker_slot() -> tuple[int, int] | None:
            if args.xdist_worker_index is not None and args.xdist_worker_count is not None:
                idx = int(args.xdist_worker_index)
                total = int(args.xdist_worker_count)
                if total > 0 and 0 <= idx < total:
                    return idx, total
                return None

            # pytest-xdist convention: PYTEST_XDIST_WORKER=gw0 and PYTEST_XDIST_WORKER_COUNT=<N>
            worker = (os.getenv("PYTEST_XDIST_WORKER") or os.getenv("XDIST_WORKER") or "").strip()
            total_raw = (os.getenv("PYTEST_XDIST_WORKER_COUNT") or os.getenv("XDIST_WORKER_COUNT") or "").strip()
            if not worker:
                return None
            m = re.fullmatch(r"gw(\d+)", worker)
            if not m:
                return None
            try:
                idx = int(m.group(1))
                total = int(total_raw) if total_raw else 0
            except Exception:
                return None
            if total <= 0:
                return None
            if idx < 0 or idx >= total:
                return None
            return idx, total
        targets: list[tuple[str, str, Path]] = []
        # Commodities are intentionally excluded from older-data mode (UI/table issues + unreliable backfill path).
        groups = [("stock", CSV_DATA_DIR / "stocks"), ("forex", CSV_DATA_DIR / "forex")]
        scope = (args.fetch_older_data_scope or "all").lower()
        if scope == "commodities":
            print("[fetch-older-data] commodities are excluded in older-data mode; nothing to do for scope=commodities.")
            groups = []
        elif scope == "stocks":
            groups = [("stock", CSV_DATA_DIR / "stocks")]
        elif scope == "forex":
            groups = [("forex", CSV_DATA_DIR / "forex")]
        for instrument, folder in groups:
            if not folder.exists():
                continue
            for p in sorted(folder.glob("*.csv")):
                sym = p.stem.replace("_", ".").upper()
                if instrument == "commodity":
                    sym = _commodity_symbol_to_stooq_ticker(sym)
                targets.append((instrument, sym, p))
        deduped: dict[tuple[str, str], tuple[str, str, Path]] = {}
        for instrument, symbol, csv_path in targets:
            # Keep first discovered file as source of truth to avoid alias/duplicate csv paths.
            deduped.setdefault(_dedup_key(instrument, symbol), (instrument, symbol, csv_path))
        targets = sorted(deduped.values(), key=lambda t: (0 if t[0] == "stock" else 1, t[1]))
        xslot = _xdist_worker_slot()
        if xslot:
            worker_idx, worker_total = xslot
            print(f"[fetch-older-data] xdist detected: workers_total={worker_total}, this_worker={worker_idx+1}")
            sharded = [t for i, t in enumerate(targets) if i % worker_total == worker_idx]
            print(f"[fetch-older-data] xdist shard active: worker={worker_idx+1}/{worker_total}, assigned={len(sharded)}/{len(targets)}")
            targets = sharded
        else:
            print(
                "[fetch-older-data] xdist not detected (single-worker mode). "
                f"PYTEST_XDIST_WORKER={os.getenv('PYTEST_XDIST_WORKER','')!r} "
                f"PYTEST_XDIST_WORKER_COUNT={os.getenv('PYTEST_XDIST_WORKER_COUNT','')!r} "
                f"XDIST_WORKER={os.getenv('XDIST_WORKER','')!r} "
                f"XDIST_WORKER_COUNT={os.getenv('XDIST_WORKER_COUNT','')!r}."
            )
            print("[fetch-older-data] Tip: run with pytest -n N or pass --xdist-worker-index/--xdist-worker-count explicitly.")
        if not targets:
            print("[fetch-older-data] No local CSV files found in data/csv/* folders.")
            return 0
        local_workers = max(1, int(args.fetch_workers or 1))
        print(f"[fetch-older-data] Starting older-window fetch for {len(targets)} instruments (local_workers={local_workers}).")
        failures = 0
        data_dir_by_instrument = {
            "commodity": CSV_DATA_DIR / "commodities",
            "stock": CSV_DATA_DIR / "stocks",
            "forex": CSV_DATA_DIR / "forex",
        }
        def _oldest_date_in_csv(path: Path) -> str:
            try:
                if not path.exists():
                    return "-"
                df = pd.read_csv(path)
                if "Date" not in df.columns or df.empty:
                    return "-"
                d = pd.to_datetime(df["Date"], errors="coerce").min()
                if pd.isna(d):
                    return "-"
                return d.date().isoformat()
            except Exception:
                return "-"
        target_span_days = 364 + 180
        skip_span_days = int(365 * 1.5)
        def _fetch_one(instrument: str, symbol: str, source_csv_path: Path) -> tuple[bool, bool, str]:
            try:
                oldest_before = _oldest_date_in_csv(source_csv_path)
                aim_date = "-"
                if source_csv_path.exists():
                    try:
                        local_df = pd.read_csv(source_csv_path)
                        dts = pd.to_datetime(local_df.get("Date"), errors="coerce").dropna().sort_values()
                        if not dts.empty:
                            span_days = int((dts.max() - dts.min()).days)
                            if span_days >= skip_span_days:
                                return True, False, (
                                    f"[fetch-older-data] skip {instrument}:{symbol} "
                                    f"last_found_data={oldest_before} span_days={span_days} reason=already_have_1_5y_or_more"
                                )
                    except Exception:
                        pass
                if oldest_before != "-":
                    try:
                        aim_date = (pd.Timestamp(oldest_before) - pd.Timedelta(days=target_span_days)).date().isoformat()
                    except Exception:
                        aim_date = "-"
                df, csv_path, meta = load_or_update_daily_data(symbol=symbol, instrument_type=instrument, persist=True, fetch_older_data=True)
                oldest_after = _oldest_date_in_csv(csv_path)
                backfill_added = False
                if oldest_before != "-" and oldest_after != "-":
                    try:
                        backfill_added = pd.Timestamp(oldest_after) < pd.Timestamp(oldest_before)
                    except Exception:
                        backfill_added = False
                return True, backfill_added, (
                    f"[fetch-older-data] ok {instrument}:{symbol} "
                    f"last_found_data={oldest_before} aim_date={aim_date} "
                    f"rows={len(df)} source={meta.get('source')} "
                    f"oldest_after={oldest_after} backfill_added={backfill_added} "
                    f"src_csv={source_csv_path} -> {csv_path}"
                )
            except Exception as exc:
                return False, False, f"[fetch-older-data] fail {instrument}:{symbol}: {exc}"
        fetch_timeout_s = max(15, int(os.getenv("STOCKHELPER_FETCH_ONE_TIMEOUT_S", "90")))
        vpn_pause_s = max(0, int(os.getenv("STOCKHELPER_FETCH_VPN_PAUSE_S", "120")))
        retry_on_zero_backfill = os.getenv("STOCKHELPER_FETCH_RETRY_ON_ZERO_BACKFILL", "1") != "0"

        def _run_pass(pass_targets: list[tuple[str, str, Path]], pass_label: str) -> tuple[int, int]:
            pass_failures = 0
            pass_backfilled = 0
            if local_workers == 1:
                def _timeout_handler(_signum, _frame):
                    raise TimeoutError("fetch_one_timeout")
                try:
                    for instrument, symbol, source_csv_path in pass_targets:
                        if hasattr(signal, "SIGALRM"):
                            prev = signal.signal(signal.SIGALRM, _timeout_handler)
                            signal.alarm(fetch_timeout_s)
                        try:
                            ok, backfill_added, line = _fetch_one(instrument, symbol, source_csv_path)
                        except TimeoutError:
                            ok, backfill_added, line = False, False, (
                                f"[fetch-older-data] fail {instrument}:{symbol}: timeout>{fetch_timeout_s}s "
                                f"(set STOCKHELPER_FETCH_ONE_TIMEOUT_S to adjust)"
                            )
                        finally:
                            if hasattr(signal, "SIGALRM"):
                                signal.alarm(0)
                                signal.signal(signal.SIGALRM, prev)
                        print(f"{line} pass={pass_label}")
                        if backfill_added:
                            pass_backfilled += 1
                        if not ok:
                            pass_failures += 1
                except KeyboardInterrupt:
                    print("[fetch-older-data] Interrupted by user (Ctrl+C).")
                    print("[fetch-older-data] Already written CSV updates are kept (no rollback).")
                    return -1, pass_backfilled
            else:
                from concurrent.futures import ThreadPoolExecutor, as_completed
                try:
                    with ThreadPoolExecutor(max_workers=min(local_workers, len(pass_targets))) as ex:
                        fut_map = {
                            ex.submit(_fetch_one, instrument, symbol, source_csv_path): (instrument, symbol)
                            for instrument, symbol, source_csv_path in pass_targets
                        }
                        for fut in as_completed(fut_map):
                            ok, backfill_added, line = fut.result()
                            print(f"{line} pass={pass_label}")
                            if backfill_added:
                                pass_backfilled += 1
                            if not ok:
                                pass_failures += 1
                except KeyboardInterrupt:
                    print("[fetch-older-data] Interrupted by user (Ctrl+C).")
                    print("[fetch-older-data] Already written CSV updates are kept (no rollback).")
                    return -1, pass_backfilled
            return pass_failures, pass_backfilled

        first_failures, first_backfilled = _run_pass(targets, "1")
        if first_failures < 0:
            return 130
        failures += first_failures

        if retry_on_zero_backfill and first_backfilled == 0 and targets:
            print(
                "[fetch-older-data] No symbol was extended with older rows in pass=1. "
                f"Pausing {vpn_pause_s}s for VPN switch, then retrying once."
            )
            if vpn_pause_s > 0:
                time.sleep(vpn_pause_s)
            second_failures, second_backfilled = _run_pass(targets, "2")
            if second_failures < 0:
                return 130
            failures += second_failures
            print(
                f"[fetch-older-data] retry summary pass1_backfilled={first_backfilled} "
                f"pass2_backfilled={second_backfilled}"
            )
        exit_code = 1 if failures else 0
        print(f"[fetch-older-data] completed assigned={len(targets)} failures={failures} exit_code={exit_code}")
        _hard_exit(exit_code)
    if args.search_debug: os.environ['STOCKHELPER_STOOQ_DEBUG']='1'
    if args.open_allsearch_report is not None:
        return _open_existing_allsearch_report(args.open_allsearch_report)
    if args.debug_stooq:
        from utilities.stooq_playwright import debug_stooq_page
        raw = args.debug_stooq.strip(); upper_raw = raw.upper(); mapped = COMMODITY_STOOQ_MAP.get(upper_raw)
        if mapped: symbol_for_debug = str(mapped).lower()
        else:
            values = {str(v).lower() for v in COMMODITY_STOOQ_MAP.values()}
            symbol_for_debug = raw.lower() if raw.lower() in values else raw
        csv_path = None
        if args.debug_stooq_fetch:
            safe = symbol_for_debug.replace('/', '').replace('.', '_').upper()
            csv_path = CSV_DATA_DIR / "commodities" / f"{safe}.csv"
        path = debug_stooq_page(symbol_for_debug, interactive_captcha=args.inspector, csv_path=csv_path)
        print(f"Stooq debug zapisany: {path}")
        if csv_path is not None:
            print(f"Stooq debug rows merged into CSV: {csv_path}")
        else:
            print("Stooq debug mode does not update CSV files. Add --debug-stooq-fetch to merge visible rows into the commodity CSV.")
        return 0
    if args.search_target:
        if args.search_target.strip().lower()=='all': return _run_batch_search('ichimoku', DEFAULT_ALLSEARCH_SCOPES, force_cache_only=args.onlycache, strict_cache_only=args.onlycache)
        if not args.onlycache:
            os.environ.pop("STOCKHELPER_CACHE_ONLY", None)
        os.environ.pop("STOCKHELPER_FORCE_REMOTE_REFRESH", None)
        from scanner_search import run_ichimoku_search; return run_ichimoku_search(args.search_target)
    if args.checkavg_target:
        from scanner_search import run_checkavg; return run_checkavg(args.checkavg_target)
    if args.allsearch_target:
        normalized = args.allsearch_target.strip().lower()
        if normalized == "all":
            return _run_allsearch_combo(DEFAULT_ALLSEARCH_SCOPES, force_cache_only=args.onlycache)
        return _run_allsearch_combo([normalized], force_cache_only=args.onlycache)
    if args.fibo_explain_target:
        from scanner_search import run_fibo_explain; return run_fibo_explain(args.fibo_search_target or 'single', args.fibo_explain_target)
    if args.fibo_search_target:
        if args.fibo_search_target.strip().lower()=='all': return _run_batch_search('fibo', DEFAULT_ALLSEARCH_SCOPES, force_cache_only=args.onlycache, strict_cache_only=args.onlycache)
        if not args.onlycache:
            os.environ.pop("STOCKHELPER_CACHE_ONLY", None)
        os.environ.pop("STOCKHELPER_FORCE_REMOTE_REFRESH", None)
        from scanner_search import run_fibo_search; return run_fibo_search(args.fibo_search_target)
    target=(args.target or '').strip()
    chart_modifier = (args.chart_modifier or '').strip().lower()
    if not target: parser.error('target is required unless -ichimoku_search is used')
    cfd_chart_mode = args.chart and chart_modifier == 'cfd'
    target_base = re.sub(r'\s+cfd$', '', target, flags=re.IGNORECASE).strip() if cfd_chart_mode else target
    resolved_path=_resolve_existing_config_path(target_base)
    if args.chart:
        if cfd_chart_mode:
            # A trailing `cfd` qualifier intentionally routes the symbol through
            # commodity/CFD mode, even when a stock config exists for it.
            cmd=[sys.executable,'-m','chart_program',f'{target_base} cfd','--instrument','commodity']
        elif resolved_path:
            cmd=[sys.executable,'-m','chart_program',resolved_path.stem,'--config',str(resolved_path)]
            instrument_type = _instrument_type_from_path(resolved_path)
            if instrument_type:
                cmd.extend(['--instrument', instrument_type])
        else:
            cmd=[sys.executable,'-m','chart_program',target]
        if args.ichimoku_mode:
            cmd.extend(['--ichimoku-mode', args.ichimoku_mode])
        if args.fibo_lines:
            cmd.extend(['--fibo-lines', str(args.fibo_lines)])
        if args.fibo_anchor_start:
            cmd.extend(['--fibo-anchor-start', args.fibo_anchor_start])
        if args.fibo_anchor_end:
            cmd.extend(['--fibo-anchor-end', args.fibo_anchor_end])
        if args.fibo_right:
            cmd.append('--fibo-right')
        if args.wedge_lines:
            cmd.append('--wedge-lines')
        if args.wedge_upper_start:
            cmd.extend(['--wedge-upper-start', args.wedge_upper_start])
        if args.wedge_upper_end:
            cmd.extend(['--wedge-upper-end', args.wedge_upper_end])
        if args.wedge_lower_start:
            cmd.extend(['--wedge-lower-start', args.wedge_lower_start])
        if args.wedge_lower_end:
            cmd.extend(['--wedge-lower-end', args.wedge_lower_end])
        if args.wedge_right:
            cmd.append('--wedge-right')
        if args.journal_close_mode:
            cmd.append('--journal-close-mode')
        if args.journal_entry_id:
            cmd.extend(['--journal-entry-id', args.journal_entry_id])
        if args.journal_entry_price:
            cmd.extend(['--journal-entry-price', args.journal_entry_price])
        if args.journal_direction:
            cmd.extend(['--journal-direction', args.journal_direction])
        if args.journal_close_price:
            cmd.extend(['--journal-close-price', args.journal_close_price])
        if args.journal_stop_loss:
            cmd.extend(['--journal-stop-loss', args.journal_stop_loss])
    else:
        if chart_modifier:
            parser.error('chart modifier cfd can be used only together with -c/--chart')
        instrument_type=_instrument_type_from_path(resolved_path) or detect_instrument_type(target,None)
        if resolved_path is None: print(f'Instrument config not found: {target}.'); return 1
        cmd=[sys.executable,str(PROJECT_ROOT/_resolve_runner(instrument_type)),str(resolved_path)]
    return subprocess.call(cmd)
if __name__=='__main__': raise SystemExit(main())
