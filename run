def _liquidity_legend_text() -> str:
    base = GDP_PPP_VALUE["PL"]
    multipliers = {
        "WIG/PL": GDP_PPP_VALUE["PL"] / base,
        "DAX/DE": GDP_PPP_VALUE["DE"] / base,
        "US100/US": GDP_PPP_VALUE["US"] / base,
    }
    def _fmt(v: float) -> str:
        return f"{v:,.0f}".replace(",", " ")
    fibo_examples = ", ".join([f"{k}: ×{m:.2f} = {_fmt(500000*m)} PLN" for k, m in multipliers.items()])
    ichi_examples = ", ".join([f"{k}: ×{m:.2f} = {_fmt(700000*m)} PLN" for k, m in multipliers.items()])
    low20_examples = ", ".join([f"{k}: ×{m:.2f} = {_fmt(300000*m)} PLN" for k, m in multipliers.items()])
    return (
        "Legenda (progi): "
        f"🟨 Fibo: próg płynności Th10d (ostatnie 10 świeczek) = bazowo 500000 PLN × mnożnik PKB kraju ({fibo_examples}). "
        f"☁️ Ichimoku: próg płynności = 700000 PLN × mnożnik PKB kraju ({ichi_examples}). "
        f"🧪 Low<Th20: liczba dni z ostatnich 20 poniżej progu 300000 PLN × mnożnik kraju ({low20_examples}) — nie może być więcej niż 2.\n"
    )

def _normalize_key(value: str) -> str: return "".join(ch for ch in (value or "").lower() if ch.isalnum())
def _match_in_dir(directory: Path, target: str) -> list[Path]:
    key=_normalize_key(target.replace('.py','')); exact=[p for p in directory.glob('*.py') if _normalize_key(p.stem)==key]
    if exact:
        return exact
    # Do not let partial 3-letter currency codes (e.g. EUR) resolve to a
    # configured forex pair such as EURCHF; the full 6-letter pair is required.
    if directory.name == 'forex' and len(key) < 6:
        return []
    return [p for p in directory.glob('*.py') if _normalize_key(p.stem).startswith(key)]
def _resolve_existing_config_path(target: str) -> Path | None:
    raw = (target or '').strip()
    if not raw:
        return None
    direct = Path(raw).expanduser()
    if direct.is_file():
        return direct.resolve()
    project_direct = (PROJECT_ROOT / raw).resolve()
    if project_direct.is_file():
        return project_direct
    groups=[PROJECT_ROOT/'configs'/'stocks',PROJECT_ROOT/'configs'/'forex',PROJECT_ROOT/'configs'/'commodities']; found=[]
    for d in groups:
        m=_match_in_dir(d,raw)
        if m: found.append(m[0])
    return found[0] if len(found)==1 else None
def _instrument_type_from_path(path: Path | None) -> str | None:
    if not path: return None
    parts=[p.lower() for p in path.parts]
    return 'stock' if 'stocks' in parts else 'forex' if 'forex' in parts else 'commodity' if 'commodities' in parts else None
def _resolve_runner(instrument_type: str) -> str: return 'main_stock.py' if instrument_type=='stock' else 'main.py'
def _stooq_chart_url(ticker: str) -> str:
    raw = (ticker or "").strip().upper()
    mapped = COMMODITY_STOOQ_MAP.get(raw)
    if mapped:
        symbol = "al.f" if raw == "ALUMINIUM" else "hg.f" if raw == "COPPER" else str(mapped).lower()
    else:
        symbol = raw.lower()
        cfg = _resolve_existing_config_path(raw)
        instrument = _instrument_type_from_path(cfg)
        if instrument == "stock" and "." not in symbol and len(raw) <= 5:
            symbol = f"{symbol}.wa"
    return f"https://stooq.pl/q/a2/?s={symbol}&i=d&t=c&a=ln&z=224&ft=20251204&l=234&d=1&ch=0&f=1&lt=56&r=0&o=1"

def _is_number_text(value: str) -> bool:
    txt = (value or "").strip().replace(",", "")
    if not txt:
        return False
    try:
        float(txt)
        return True
    except Exception:
        return False

def _format_row(cells: list[str], widths: list[int], right_align: list[bool] | None = None) -> str:
    out_cells: list[str] = []
    right_align = right_align or [False] * len(cells)
    for i, (cell, width) in enumerate(zip(cells, widths)):
        txt = str(cell)
        out_cells.append(txt.rjust(width) if right_align[i] else txt.ljust(width))
    return "│ " + " │ ".join(out_cells) + " │"

def _is_http_url(value: str) -> bool:
    return value.startswith("http://") or value.startswith("https://")


def _write_table(out, title: str, rows: list[dict[str, str]], columns: list[tuple[str, str]]) -> None:
    out.write(f"\n### {title}\n")
    if not rows:
        out.write("Brak wyników.\n")
        return
    headers = [h for h, _ in columns]
    keys = [k for _, k in columns]
    link_idx = headers.index("Link") if "Link" in headers else None
    rows_data = []
    for row in rows:
        vals = []
        for col_idx, key in enumerate(keys):
            val = str(row.get(key, "")).replace("\n", " ")
            if link_idx is not None and col_idx == link_idx and _is_http_url(val):
                val = f"[📈]({val})"
            vals.append(val)
        rows_data.append(vals)
    if tabulate is not None:
        out.write(tabulate(rows_data, headers=headers, tablefmt="github") + "\n")
    else:
        out.write("| " + " | ".join(headers) + " |\n")
        out.write("| " + " | ".join(["---"] * len(headers)) + " |\n")
        for vals in rows_data:
            out.write("| " + " | ".join(vals) + " |\n")

def _append_csv_section(fp: Path, section: str, csv_path: Path, links: set[str], csv_refs: list[Path]) -> None:
    if not csv_path.exists(): return
    with csv_path.open(newline='', encoding='utf-8') as fh: rows=list(csv.DictReader(fh))
    csv_refs.append(csv_path)
    with fp.open('a', encoding='utf-8') as out:
        for r in rows:
            t=r.get('ticker','').strip(); link=_stooq_chart_url(t) if t else ''
            if link:
                links.add(link)
                r["stooq_link"] = f"[stooq]({link})"
            else:
                r["stooq_link"] = ""

        if csv_path.name.endswith("_flips.csv"):
            for r in rows:
                retest_dates = [str(v).strip() for k, v in r.items() if str(k).startswith("retest_date_") and str(v).strip()]
                r["last_valid_retest_pattern_date"] = retest_dates[-1] if retest_dates else "-"
                last_pattern = [str(v).strip() for k, v in r.items() if str(k).startswith("formation_") and str(v).strip()]
                r["last_valid_retest_pattern_name"] = last_pattern[-1] if last_pattern else "-"
                r["jest_marker"] = f"{GRAY_DOT} above" if str(r.get("current_side", "")) == "above" else f"{RED_DOT} below"
            cols = [
                ("Ticker", "ticker"),
                ("Było", "previous_side"),
                ("Jest", "jest_marker"),
                ("Data wybicia", "flip_date"),
                ("Mies. od wybicia", "months_since_flip"),
                ("Retest status", "latest_retest_status"),
                ("Retest count", "valid_retests_count"),
                ("Last valid retest", "last_valid_retest_pattern_date"),
                ("Pattern", "last_valid_retest_pattern_name"),
                ("Link", "stooq_link"),
            ]
            rows = sorted(rows, key=lambda r: (str(r.get("current_side", "")) != "below", -float(str(r.get("months_since_flip", "0") or "0"))))
            title = "WYNIKI 2 ICHIMOKU (po flipie chmury: retest/pattern po wybiciu)" if section == "WYNIKI 2" else "WYNIKI 1 ICHIMOKU (poza chmurą, z warunkami płynności)"
            _write_table(out, title, rows, cols)
        elif csv_path.name.startswith("fibo_search_"):
            for r in rows:
                status = str(r.get("status", ""))
                if status == "valid_reversal":
                    r["status_marker"] = "🟢 valid_reversal"
                elif status == "reached_23_6_waiting_for_61_8":
                    r["status_marker"] = "reached_23_6_waiting_for_61_8"
                elif status == "touched_61_8_no_pattern":
                    r["status_marker"] = "🟡 touched_61_8_no_pattern"
                else:
                    r["status_marker"] = f"🔴 {status}"
            for r in rows:
                r["incline"] = f"{r.get('incline_start_date','')}->{r.get('incline_end_date','')}"
                try:
                    ratio = float(str(r.get("incline_decline_duration_ratio", "0") or "0"))
                except Exception:
                    ratio = 0.0
                i_d = str(r.get("incline_duration_days", "0") or "0")
                d_d = str(r.get("decline_duration_days", "0") or "0")
                r["ratio_txt"] = f"{i_d}/{d_d} ({ratio:.2f}:1)"
                r["avg10turn"] = r.get("avg_turnover_10d_pln", "-")
                r["ratio_raw"] = ratio
                try:
                    cur = float(str(r.get("current_close", "0") or "0"))
                    f23 = float(str(r.get("fib_23_6", "0") or "0"))
                    f61 = float(str(r.get("fib_61_8", "0") or "0"))
                    band = max(abs(f23 - f61), 1e-9)
                    direction = str(r.get("direction", r.get("Dir", "long"))).lower()
                    progress_pct = ((cur - f23) / band * 100.0) if direction == "short" else ((f23 - cur) / band * 100.0)
                    marker = "🟢" if progress_pct >= 70.0 else ("🟡" if progress_pct >= 35.0 else "🔴")
                    r["near61"] = f"{marker} {progress_pct:5.1f}%"
                    r["near61_raw"] = progress_pct
                except Exception:
                    r["near61"] = "-"
                    r["near61_raw"] = -1.0
            cols_w1 = [
                ("Ticker", "ticker"),
                ("Dir", "direction"),
                ("Status", "status_marker"),
                ("Pattern", "reversal_pattern_name"),
                ("Incline", "incline"),
                ("Ratio(d)", "ratio_txt"),
                ("Touched_61.8_date", "first_61_8_touch_date"),
                ("Avg10d PLN", "avg10turn"),
                ("Near61.8", "near61"),
                ("Link", "stooq_link"),
            ]
            cols_w2 = [
                ("Ticker", "ticker"),
                ("Dir", "direction"),
                ("Pattern", "reversal_pattern_name"),
                ("Incline", "incline"),
                ("Ratio(d)", "ratio_txt"),
                ("Touched_61.8_date", "first_61_8_touch_date"),
                ("Avg10d PLN", "avg10turn"),
                ("Link", "stooq_link"),
            ]
            if csv_path.name.endswith("_w1.csv"):
                rows_w1 = rows
                rows_w2 = []
            elif csv_path.name.endswith("_w2.csv"):
                rows_w1 = []
                rows_w2 = rows
            else:
                rows_w1 = [r for r in rows if str(r.get("status", "")) == "reached_23_6_waiting_for_61_8"]
                rows_w2 = [r for r in rows if str(r.get("status", "")) == "valid_reversal"]
            def _dedupe(items):
                seen = set()
                out = []
                for it in items:
                    k = (it.get("ticker"), it.get("direction"), it.get("incline"))
                    if k in seen:
                        continue
                    seen.add(k)
                    out.append(it)
                return out
            rows_w1 = _dedupe(rows_w1)
            rows_w2 = _dedupe(rows_w2)
            top_near_ids = {id(x) for x in sorted(rows_w1, key=lambda r: float(r.get("near61_raw", -1.0)), reverse=True)[:3]}
            top_ratio_ids = {id(x) for x in sorted(rows_w1 + rows_w2, key=lambda r: float(r.get("ratio_raw", 0.0)), reverse=True)[:3]}
            for r in rows_w1:
                if id(r) in top_near_ids:
                    r["near61"] = f"{GOLD_DOT} {r.get('near61')}"
                if id(r) in top_ratio_ids:
                    r["ratio_top"] = "1"
            for r in rows_w2:
                if id(r) in top_ratio_ids:
                    r["ratio_top"] = "1"
            if rows_w1:
                _write_table(out, "WYNIKI FIBO #1 (Waiting 23.6→61.8 and patterns)", rows_w1, cols_w1)
            if rows_w2:
                _write_table(out, "WYNIKI FIBO #2 (valid pattern up to 2 weeks)", rows_w2, cols_w2)
        else:
            for r in rows:
                side = str(r.get("side", ""))
                r["side_marker"] = f"{GRAY_DOT} above" if side == "above" else (f"{RED_DOT} below" if side == "below" else side)
            th10_vals = {str(r.get("threshold_10d_pln", "")).strip() for r in rows if str(r.get("threshold_10d_pln", "")).strip()}
            th20_vals = {str(r.get("threshold_20d_pln", "")).strip() for r in rows if str(r.get("threshold_20d_pln", "")).strip()}
            low20_desc = "Liczba dni (z ostatnich 20), gdy obrót był poniżej progu 20d."
            # PROGI block is rendered by orchestration layer once per scope.
            cols = [
                ("Ticker", "ticker"),
                ("Pozycja", "side_marker"),
                ("Świece", "respect_days"),
                ("Mies.", "respect_months"),
                ("Start", "start_date"),
                ("Link", "stooq_link"),
            ]
            is_stock_like = any(str(r.get("avg_turnover_10d_pln", "")).strip() for r in rows)
            if is_stock_like:
                cols.insert(6, ("Avg10d PLN", "avg_turnover_10d_pln"))
                cols.insert(7, ("Ichimoku status", "ichimoku_status"))
            if is_stock_like and not (len(th10_vals) == 1 and len(th20_vals) == 1):
                cols.extend([("Th10d PLN", "threshold_10d_pln"), ("Th20d PLN", "threshold_20d_pln")])
            rows = sorted(rows, key=lambda r: (str(r.get("side", "")) != "below", -float(str(r.get("respect_months", "0") or "0"))))
            top3 = sorted([r for r in rows if str(r.get("avg_turnover_10d_pln", "")).strip()], key=lambda r: float(str(r.get("avg_turnover_10d_pln", "0")).replace(",", "")), reverse=True)[:3]
            top_keys = {r.get("ticker") for r in top3}
            for r in rows:
                if r.get("ticker") in top_keys:
                    r["avg_turnover_10d_pln"] = f"{GOLD_DOT} {r.get('avg_turnover_10d_pln')}"
            title = "WYNIKI 2 ICHIMOKU (po flipie chmury: retest/pattern po wybiciu)" if section == "WYNIKI 2" else "WYNIKI 1 ICHIMOKU (poza chmurą, z warunkami płynności)"
            _write_table(out, title, rows, cols)

def _extract_progi_from_csv(csv_path: Path) -> tuple[str | None, str | None]:
    if not csv_path.exists():
        return None, None
    with csv_path.open(newline="", encoding="utf-8") as fh:
        rows = list(csv.DictReader(fh))
    th10_vals = {str(r.get("threshold_10d_pln", "")).strip() for r in rows if str(r.get("threshold_10d_pln", "")).strip()}
    th20_vals = {str(r.get("threshold_20d_pln", "")).strip() for r in rows if str(r.get("threshold_20d_pln", "")).strip()}
    if len(th10_vals) == 1 and len(th20_vals) == 1:
        return next(iter(th10_vals)), next(iter(th20_vals))
    return None, None

def _is_ichimoku_csv(name: str) -> bool:
    return name.startswith("search_") and name.endswith(".csv")

def _is_fibo_csv(name: str) -> bool:
    return name.startswith("fibo_search_") and name.endswith(".csv")

def _latest_scope_md(prefix: str, scope: str) -> Path | None:
    keys = _scope_file_keys(scope)
    candidates: list[Path] = []
    for key in keys:
        search_dir = FIBO_SEARCH_OUTPUT_DIR if prefix.startswith("fibo") else ICHIMOKU_SEARCH_OUTPUT_DIR
        candidates.extend([p for p in search_dir.glob(f"{prefix}_{key}_*.md") if p.is_file()])
    if not candidates:
        return None
    return max(candidates, key=lambda p: p.stat().st_mtime)

def _scope_file_keys(scope: str) -> list[str]:
    key = (scope or "").strip().lower()
    aliases = {
        "us100": ["us100", "ndx100", "ndx", "nasdaq100"],
        "dax": ["dax", "dax40"],
        "wig": ["wig"],
        "forex": ["forex", "fx"],
        "commodities": ["commodities", "commodity"],
        "indexes": ["indexes", "indices", "index"],
        "indices": ["indexes", "indices", "index"],
        "index": ["indexes", "indices", "index"],
    }
    return aliases.get(key, [key])

def _allsearch_report_stem(scopes: list[str]) -> str:
    if not scopes:
        return "allsearch_latest"
    normalized = [s.strip().lower() for s in scopes if s.strip()]
    if normalized == DEFAULT_ALLSEARCH_SCOPES or normalized == ["all"]:
        return "allsearch_latest_all"
    if len(normalized) == 1:
        return f"allsearch_latest_{normalized[0]}"
    return "allsearch_latest_" + "_".join(normalized)

def _open_existing_allsearch_report(scope: str) -> int:
    normalized = (scope or "all").strip().lower()
    scopes = DEFAULT_ALLSEARCH_SCOPES if normalized == "all" else [normalized]
    stem = _allsearch_report_stem(scopes)
    report_html = ALL_REPORT_DIR / "allsearch" / f"{stem}.html"
    if not report_html.exists():
        print(f"[allsearch] report not found: {report_html}")
        return 1
    print(f"[allsearch] opening existing html report: {report_html}")
    report_url = _open_html_report(report_html)
    return _wait_for_report_server(report_url)

def _drop_markdown_section(text: str, title_prefix: str) -> str:
    lines = text.splitlines()
    kept: list[str] = []
    skipping = False
    for line in lines:
        is_heading = line.startswith("## ")
        if is_heading:
            skipping = line[3:].strip().startswith(title_prefix)
        if not skipping:
            kept.append(line)
    return "\n".join(kept).strip()


def _append_md_sections(report: Path, source_md: Path, header: str) -> None:
    if not source_md or not source_md.exists():
        return
    text = source_md.read_text(encoding="utf-8")
    if header.upper().startswith("FIBO SOURCE"):
        text = _drop_markdown_section(text, "WYNIKI FIBO #0")
    if not text.strip():
        return
    with report.open("a", encoding="utf-8") as out:
        out.write("\n" + text.strip() + "\n")



def _csv_has_data(path: Path) -> bool:
    try:
        if not path.exists() or path.stat().st_size <= 32:
            return False
        with path.open('r', encoding='utf-8') as fh:
            lines = 0
            for _ in fh:
                lines += 1
                if lines >= 2:
                    return True
        return False
    except Exception:
        return False


def _csv_has_fresh_year(path: Path) -> bool:
    if not _csv_has_data(path):
        return False
    try:
        import pandas as pd
        df = pd.read_csv(path)
        if df.empty or 'Date' not in df.columns:
            return False
        dts = pd.to_datetime(df['Date'], errors='coerce').dropna()
        if dts.empty:
            return False
        latest = dts.max().date()
        oldest = dts.min().date()
        today = datetime.now(UTC).date()
        # Accept latest candle from today or yesterday.
        if latest < (today - timedelta(days=1)):
            return False
        # Must cover roughly one year window.
        if (latest - oldest).days < 360:
            return False
        return True
    except Exception:
        return False


def _scope_has_complete_cache(scope: str) -> bool:
    paths = _expected_scope_csv_paths(scope) if "_expected_scope_csv_paths" in globals() else []
    if not paths:
        return True
    scope_n = (scope or '').strip().lower()
    missing: list[str] = []
    for fp in paths:
        ok = _csv_has_fresh_year(fp) if scope_n == 'commodities' else _csv_has_data(fp)
        if not ok:
            missing.append(fp.name)
    if missing:
        print(f"[cache-rule] {scope} cache not ready ({len(missing)} missing/stale): {', '.join(missing[:6])}{' ...' if len(missing)>6 else ''}")
        return False
    return True


def _enable_cache_only_if_recent(scope: str, hours: int = 6) -> bool:
    keys = _scope_file_keys(scope)
    candidates: list[Path] = []
    for key in keys:
        candidates += [p for p in ICHIMOKU_SEARCH_OUTPUT_DIR.glob(f"search_{key}_*.md") if p.is_file()]
        candidates += [p for p in FIBO_SEARCH_OUTPUT_DIR.glob(f"fibo_search_{key}_*.md") if p.is_file()]
    if not candidates:
        os.environ.pop("STOCKHELPER_CACHE_ONLY", None)
        return False

    if not _scope_has_complete_cache(scope):
        os.environ.pop("STOCKHELPER_CACHE_ONLY", None)
        print(f"[cache-rule] {scope}: incomplete local CSV cache -> refresh mode ON")
        return False
    latest = max(candidates, key=lambda p: p.stat().st_mtime)
    now_utc = datetime.now(UTC)
    latest_dt = datetime.fromtimestamp(latest.stat().st_mtime, UTC)
    age_h = (now_utc.timestamp() - latest.stat().st_mtime) / 3600.0
    # Extra guardrails:
    # 1) if a search finished in the last hour -> always use cache
    # 2) if a search was completed today after 18:00 UTC ("market closed") -> cache for the rest of day
    if age_h <= 1.0:
        os.environ["STOCKHELPER_CACHE_ONLY"] = "1"
        print(f"[cache-rule] {scope}: last search {age_h:.2f}h ago ({latest.name}) -> cache-only mode ON (<=1h)")
        return True
    if latest_dt.date() == now_utc.date() and latest_dt.hour >= 18:
        os.environ["STOCKHELPER_CACHE_ONLY"] = "1"
        print(
            f"[cache-rule] {scope}: last search today at {latest_dt.strftime('%H:%M UTC')} ({latest.name})"
            " -> cache-only mode ON (after 18:00)"
        )
        return True
    if age_h <= float(hours):
        os.environ["STOCKHELPER_CACHE_ONLY"] = "1"
        print(f"[cache-rule] {scope}: last search {age_h:.2f}h ago ({latest.name}) -> cache-only mode ON")
        return True
    os.environ.pop("STOCKHELPER_CACHE_ONLY", None)
    print(f"[cache-rule] {scope}: last search {age_h:.2f}h ago ({latest.name}) -> refresh mode ON")
    return False

def _safe_int(v: str, default: int = 0) -> int:
    try:
        return int(float(str(v or default).replace(",", "")))
    except Exception:
        return default

def _format_avg10d_value(value: str) -> str:
    txt = (value or "").strip()
    if not txt or txt == "-":
        return txt
    try:
        number = float(txt.replace(" ", "").replace(",", ""))
    except Exception:
        return txt
    return f"{number:,.0f}".replace(",", ".")


def _report_open_chart_js() -> str:
    return """async function openStockhelperChart(btn){const c=btn.dataset.cmd||'';if(!c)return;const endpoint=new URL('/open-chart?command='+encodeURIComponent(c),window.location.href).href;window.open(endpoint,'_blank');setButtonText(btn,'Opened');}"""


def _patch_report_runtime_js(path: Path) -> None:
    """Update existing generated reports so old tabs/buttons get current chart-opening JS."""
    if path.suffix.lower() != ".html" or not path.exists():
        return
    try:
        text = path.read_text(encoding="utf-8")
    except Exception:
        return
    replacement = _report_open_chart_js()
    patched, count = re.subn(
        r"async function openStockhelperChart\(btn\)\{.*?\}function _tableLinks",
        replacement + "function _tableLinks",
        text,
        count=1,
        flags=re.S,
    )
    grouped_replacement = "async function _openStockhelperButtons(buttons,labelOverride){const uniq=[...new Map(buttons.map(b=>[b.dataset.cmd,b])).values()];const items=uniq.map(b=>({command:b.dataset.cmd||'',label:(b.dataset.groupLabel||b.closest('tr')?.querySelector('td,th')?.innerText||b.dataset.cmd||'').trim(),section:(b.dataset.groupSection||'').trim()})).filter(x=>x.command);if(!items.length)return;const first=uniq[0];const autoLabel=(first?.closest('section.top-choice')?'Top choices from Allsearch Report':(first?.closest('.top-choice')?.querySelector('h3')?.childNodes?.[0]?.textContent||first?.closest('.subhead')?.childNodes?.[0]?.textContent||first?.closest('h3')?.childNodes?.[0]?.textContent||first?.closest('.market')?.querySelector('h2')?.textContent||'Quick charts'));const label=(labelOverride||autoLabel).trim();const popup=window.open('about:blank','_blank');try{const res=await fetch('/chart-group',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({items,label})});if(!res.ok)throw new Error('chart-group '+res.status);const data=await res.json();const url=data.url||new URL('/open-chart?command='+encodeURIComponent(items[0].command)+'&group='+encodeURIComponent(data.group||''),window.location.href).href;if(popup){popup.location=url;}else{window.open(url,'_blank');}uniq.forEach(b=>setButtonText(b,'Grouped'));}catch(e){const url=new URL('/open-chart?command='+encodeURIComponent(items[0].command),window.location.href).href;if(popup){popup.location=url;}else{window.open(url,'_blank');}uniq.forEach(b=>setButtonText(b,'Opened'));}}"
    patched, group_count = re.subn(
        r"async function _openStockhelperButtons\(buttons(?:,[^)]*)?\)\{.*?\}function openClosestStockhelperCharts",
        grouped_replacement + "function openClosestStockhelperCharts",
        patched,
        count=1,
        flags=re.S,
    )
    patched = patched.replace(
        "fetch('/run-command?command=python%20run%20--journal-html').then(()=>setButtonText(this,'Opened'))",
        "window.open('/journal-html','_blank')"
    )
    patched = patched.replace(
        "fetch(&quot;/run-command?command=python%20run%20--journal-html&quot;).then(()=>setButtonText(this,&quot;Opened&quot;))",
        "window.open('/journal-html','_blank')"
    )
    if count or group_count or patched != text:
        path.write_text(patched, encoding="utf-8")

def _open_html_report(path: Path) -> str | None:
    _patch_report_runtime_js(path)
    report_url = _serve_report_locally(path)
    file_url = report_url or path.resolve().as_uri()
    chrome = shutil.which("google-chrome") or shutil.which("chromium") or shutil.which("chromium-browser")
    if chrome:
        try:
            print(f"[allsearch] opening report: {path}")
            subprocess.Popen([chrome, "--new-window", "--app=" + file_url], stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)
            return report_url
        except Exception:
            pass
    firefox = shutil.which("firefox")
    if firefox:
        try:
            print(f"[allsearch] opening report: {path}")
            subprocess.Popen([firefox, "--new-window", file_url], stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)
            return report_url
        except Exception:
            pass
    print(f"[allsearch] opening report via xdg-open: {file_url}")
    subprocess.Popen(["xdg-open", file_url], stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)
    return report_url

def _should_keep_report_server_foreground() -> bool:
    value = os.environ.get("STOCKHELPER_REPORT_SERVER_FOREGROUND", "").strip().lower()
    if value in {"1", "true", "yes", "on"}:
        return True
    if value in {"0", "false", "no", "off"}:
        return False
    return Path("/.dockerenv").exists()

def _wait_for_report_server(report_url: str | None) -> int:
    if not report_url or not _should_keep_report_server_foreground():
        return 0
    print(f"[allsearch] report server is running. Open this URL in your browser: {report_url}")
    print("[allsearch] keeping Docker container alive for the report server. Press Ctrl+C to stop.")
    try:
        while True:
            time.sleep(3600)
    except KeyboardInterrupt:
        print("\n[allsearch] stopping report server.")
        return 0

def _serve_report_locally(path: Path) -> str | None:
    report_server_protocol = "stockhelper-report-server-v19"
    rel = path.resolve().relative_to(PROJECT_ROOT.resolve())
    report_url_path = "/".join(rel.parts)
    host = "127.0.0.1"
    candidate_ports = list(range(8765, 8795))

    console_stdout = f"/proc/{os.getpid()}/fd/1"
    console_stderr = f"/proc/{os.getpid()}/fd/2"
    console_key = hashlib.sha1(str(PROJECT_ROOT.resolve()).encode("utf-8")).hexdigest()[:10]

    def _console_log_path(port: int) -> Path:
        return Path(os.environ.get("TMPDIR", "/tmp")) / f"stockhelper_report_console_{console_key}_{port}.log"

    def _trim_stale_console_logs() -> None:
        tmp = Path(os.environ.get("TMPDIR", "/tmp"))
        for old in tmp.glob(f"stockhelper_report_console_{console_key}_*.log"):
            try:
                if old.stat().st_size > 5 * 1024 * 1024:
                    old.write_text("", encoding="utf-8")
            except Exception:
                pass

    _trim_stale_console_logs()

    def _start_console_sink(log_path: Path) -> None:
        try:
            log_path.parent.mkdir(parents=True, exist_ok=True)
            # Keep the relay log bounded. A stale or feedback-looped log should
            # never be inherited by a fresh report open.
            if log_path.exists() and log_path.stat().st_size > 5 * 1024 * 1024:
                log_path.write_text("", encoding="utf-8")
            else:
                log_path.touch(exist_ok=True)
            subprocess.Popen(
                [
                    sys.executable,
                    str(PROJECT_ROOT / "utilities" / "report_console_sink.py"),
                    "--log",
                    str(log_path),
                ],
                cwd=str(PROJECT_ROOT),
                stdin=subprocess.DEVNULL,
                stdout=None,
                stderr=None,
                start_new_session=True,
            )
        except Exception:
            pass

    def _server_info(base_url: str) -> dict | None:
        try:
            info_url = base_url.rstrip("/") + "/__stockhelper_report_server_info"
            with urlopen(info_url, timeout=0.6) as resp:
                if not (200 <= int(getattr(resp, "status", 200)) < 500):
                    return None
                payload = json.loads(resp.read().decode("utf-8") or "{}")
            if (
                payload.get("protocol") == report_server_protocol
                and Path(str(payload.get("project_root", ""))).resolve() == PROJECT_ROOT.resolve()
            ):
                return payload
        except Exception:
            return None
        return None

    def _attach_console(base_url: str) -> bool:
        try:
            body = json.dumps({"stdout": console_stdout, "stderr": console_stderr}).encode("utf-8")
            req = Request(
                base_url.rstrip("/") + "/attach-console",
                data=body,
                headers={"Content-Type": "application/json"},
                method="POST",
            )
            with urlopen(req, timeout=0.8) as resp:
                return 200 <= int(getattr(resp, "status", 200)) < 300
        except Exception:
            return False

    def _port_occupied(port: int) -> bool:
        try:
            import socket
            with socket.create_connection((host, port), timeout=0.25):
                return True
        except OSError:
            return False

    for port in candidate_ports:
        base = f"http://{host}:{port}/"
        if _server_info(base):
            if _attach_console(base):
                return f"http://{host}:{port}/{report_url_path}"
            continue
        if _port_occupied(port):
            # Something else (or an older report_server protocol) owns this port.
            # Do not spawn onto it; try the next candidate instead.
            continue
        try:
            env = os.environ.copy()
            log_path = _console_log_path(port)
            _start_console_sink(log_path)
            # Keep report-launched chart calculations visible in the terminal
            # that opened the report. report_server writes to a console log that
            # a tiny sink process follows from this terminal, and it also refreshes
            # direct console handles via /attach-console when reused.
            env["STOCKHELPER_REPORT_CONSOLE_LOG"] = str(log_path)
            env.setdefault("STOCKHELPER_REPORT_CONSOLE_LOG_MAX_BYTES", str(5 * 1024 * 1024))
            env["STOCKHELPER_REPORT_CONSOLE_STDOUT"] = console_stdout
            env["STOCKHELPER_REPORT_CONSOLE_STDERR"] = console_stderr
            subprocess.Popen(
                [
                    sys.executable,
                    str(PROJECT_ROOT / "utilities" / "report_server.py"),
                    "--root",
                    str(PROJECT_ROOT),
                    "--project-root",
                    str(PROJECT_ROOT),
                    "--host",
                    host,
                    "--port",
                    str(port),
                ],
                cwd=str(PROJECT_ROOT),
                env=env,
                stdin=subprocess.DEVNULL,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
        except Exception:
            continue
        for _ in range(10):
            if _server_info(base) and _attach_console(base):
                return f"http://{host}:{port}/{report_url_path}"
            time.sleep(0.1)
    return None


def _parse_markdown_tables(md_path: Path) -> dict[str, list[dict[str, str]]]:
    out: dict[str, list[dict[str, str]]] = {}
    if not md_path or not md_path.exists():
        return out
    lines = md_path.read_text(encoding="utf-8").splitlines()
    last_heading = ""
    i = 0
    while i < len(lines):
        line = lines[i].strip()
        if line.startswith("#"):
            last_heading = line.lstrip("#").strip()
        if i + 2 < len(lines) and lines[i].strip().startswith("|") and lines[i + 1].strip().startswith("|"):
            headers = [h.strip() for h in lines[i].strip().strip("|").split("|")]
            separator = [sep.strip() for sep in lines[i + 1].strip().strip("|").split("|")]
            if headers and separator and len(headers) == len(separator) and all(set(sep) <= {"-", ":"} and sep for sep in separator):
                rows: list[dict[str, str]] = []
                j = i + 2
                while j < len(lines) and lines[j].strip().startswith("|"):
                    vals = [v.strip() for v in lines[j].strip().strip("|").split("|")]
                    if len(vals) == len(headers):
                        row = {headers[k]: vals[k] for k in range(len(headers))}
                        for link_key in ("Link", "Links"):
                            link_cell = row.get(link_key, "")
                            inline_match = re.match(r"^\[[^\]]+\]\(([^)]+)\)$", link_cell)
                            if inline_match:
                                row[link_key] = inline_match.group(1)
                        rows.append(row)
                    j += 1
                out.setdefault(last_heading or "TABLE", []).extend(rows)
                i = j
                continue
        i += 1
    return out


def _market_icon(scope: str, ticker: str = "") -> str:
    scope_n = (scope or "").strip().lower()
    ticker_u = (ticker or "").upper()
    if ticker_u.endswith(".WA"):
        return "🇵🇱"
    if ticker_u.endswith(".DE"):
        return "🇩🇪"
    if ticker_u.endswith(".US"):
        return "🇺🇸"
    if scope_n == "wig":
        return "🇵🇱"
    if scope_n == "dax":
        return "🇩🇪"
    if scope_n in {"us100", "us"}:
        return "🇺🇸"
    if scope_n == "forex":
        return "💱"
    if scope_n == "commodities":
        return "🛢️"
    return "📊"



def _market_order(scope: str, ticker: str = "") -> int:
    icon = _market_icon(scope, ticker)
    return {"🇵🇱": 0, "🇩🇪": 1, "🇺🇸": 2, "💱": 3, "🛢️": 4}.get(icon, 9)


def _market_sort_key(row: ScannerRow) -> tuple[int, str]:
    return (_market_order(row.market, row.ticker), str(row.ticker or ""))

def _parse_float_text(value: str, default: float = 0.0) -> float:
    txt = str(value or "").replace("%", "").replace("🟨", "").replace("🟢", "").replace("🟡", "").replace("🔴", "").strip()
    txt = txt.replace(" ", "").replace(",", "")
    try:
        return float(txt)
    except Exception:
        return default


def _wedge_slope_strength(value: str) -> str:
    txt = str(value or "").strip()
    low = txt.lower()
    for label in ("very strong", "strong", "moderate", "mild"):
        if label in low:
            return label
    raw = _parse_float_text(txt, 0.0)
    if raw >= 0.40:
        return "very strong"
    if raw >= 0.20:
        return "strong"
    if raw >= 0.08:
        return "moderate"
    return "mild"


def _ratio_value(row: dict[str, str]) -> float:
    txt = str(row.get("Ratio(d)") or row.get("ratio_txt") or row.get("incline_decline_duration_ratio") or "")
    m = re.search(r"\(([-+0-9.]+):1\)", txt)
    if m:
        return _parse_float_text(m.group(1), 0.0)
    return _parse_float_text(txt, 0.0)


def _incline_duration_days(row: dict[str, str]) -> int:
    txt = str(row.get("Ratio(d)") or "")
    m = re.match(r"\s*(\d+)\s*/", txt)
    if m:
        return int(m.group(1))
    return int(_parse_float_text(str(row.get("incline_duration_days") or "0"), 0.0))


def _extract_start_date(row: dict[str, str]) -> str:
    incline = str(row.get("Incline") or row.get("incline") or "")
    if "->" in incline:
        return incline.split("->", 1)[0].strip() or "-"
    return str(row.get("incline_start_date") or row.get("Start") or row.get("Data wybicia") or "-").strip() or "-"


def _near61_pct(row: dict[str, str]) -> float:
    near = str(row.get("Near61.8") or row.get("near61") or "")
    if near and near != "-":
        return _parse_float_text(near, -1.0)
    return -1.0


def _markdown_link(label: str, url: str | None) -> str:
    txt = str(url or "").strip()
    if not txt:
        return "-"
    return f"[{label}]({txt})"


def _stockhelper_chart_url(command: str | None) -> str | None:
    cmd = str(command or "").strip()
    if not cmd:
        return None
    return f"http://127.0.0.1:8765/run-command?command={quote(cmd, safe='')}"


def _links_for_troj(row: ScannerRow) -> str:
    return _stooq_link_for_troj(row)


def _stooq_link_for_troj(row: ScannerRow) -> str:
    return _markdown_link("🔗 stooq", row.chart_url or (_stooq_chart_url(row.ticker) if row.ticker else ""))


def _metric_from_row(row: dict[str, str], *names: str) -> str:
    for name in names:
        value = str(row.get(name, "")).strip()
        if value:
            return value
    return "-"


def _read_allsearch_rows(scopes: list[str]) -> list[ScannerRow]:
    rows: list[ScannerRow] = []
    for scope in scopes:
        market = scope.upper()
        i_md = _latest_scope_md("search", scope)
        f_md = _latest_scope_md("fibo_search", scope)
        i_tables = _parse_markdown_tables(i_md) if i_md else {}
        f_tables = _parse_markdown_tables(f_md) if f_md else {}
        i_w2 = next((v for k, v in i_tables.items() if "WYNIKI 2" in k.upper()), [])
        i_w1 = next((v for k, v in i_tables.items() if k.upper().strip() == "WYNIKI" or "WYNIKI 1" in k.upper()), [])
        f_w0 = next((v for k, v in f_tables.items() if "WYNIKI FIBO #0" in k.upper()), [])
        f_w2 = next((v for k, v in f_tables.items() if "WYNIKI FIBO #2" in k.upper()), [])
        f_w1 = next((v for k, v in f_tables.items() if "WYNIKI FIBO #1" in k.upper()), [])
        w_wedge = next((v for k, v in f_tables.items() if "WYNIKI KLINY" in k.upper()), [])
        for r in i_w2:
            t = str(r.get("Ticker", "")).strip()
            rows.append(ScannerRow(
                market=market, scanner="ICHIMOKU", category="retest_breakout", ticker=t,
                status=str(r.get("Latest Retest status", "")), dates={"flip_date": str(r.get("Data wybicia", ""))},
                metrics={
                    "months": str(r.get("Mies. od wybicia", "")), "previous_respect_months": str(r.get("Mies. respektu przed wybiciem", "")), "retest_count": str(r.get("Retest count", "")),
                    "avg10d": str(r.get("Avg10d PLN", "")), "latest_retest_date": str(r.get("Latest Retest date", "")),
                    "latest_retest_pattern": str(r.get("Latest Retest pattern", "")), "latest_data": str(r.get("Latest data?", "")),
                    "latest_date": str(r.get("Latest date", "")), "expected_date": str(r.get("Expected date", "")),
                    "raw_status": str(r.get("Latest Retest status", "")),
                    "previous_side": str(r.get("Poprzednia", "") or r.get("Było", "")),
                    "current_side": str(r.get("Jest", "") or r.get("Current", "")),
                    "ichimoku_status": str(r.get("Ichimoku status", "")),
                    "risk": _metric_from_row(r, "Risk"), "tk_cross": _metric_from_row(r, "TK cross"),
                    "dynamic": _metric_from_row(r, "Dynamic"), "cloud": _metric_from_row(r, "Cloud"),
                    "chikou": _metric_from_row(r, "Chikou"), "twist": _metric_from_row(r, "Twist"),
                    "tk_plus": _metric_from_row(r, "TK plus"), "tenkan_in_cloud": _metric_from_row(r, "Tenkan in cloud"),
                },
                chart_url=str(r.get("Link", "")), python_command=str(r.get("Python command", "")), priority="MEDIUM"
            ))
        for r in i_w1:
            t = str(r.get("Ticker", "")).strip()
            rows.append(ScannerRow(
                market=market, scanner="ICHIMOKU", category="position", ticker=t,
                status=str(r.get("Pozycja", "")), dates={"start_date": str(r.get("Start", ""))},
                metrics={
                    "candles": str(r.get("Świece", "")), "months": str(r.get("Mies.", "")), "close": str(r.get("Close", "")),
                    "avg10d": str(r.get("Avg10d PLN", "")), "ichimoku_status": str(r.get("Ichimoku status", "")),
                    "latest_retest_count": str(r.get("Retest count", "")), "latest_retest_date": str(r.get("Latest Retest date", "")),
                    "latest_retest_pattern": str(r.get("Latest Retest pattern", "")), "latest_data": str(r.get("Latest data?", "")),
                    "latest_date": str(r.get("Latest date", "")), "expected_date": str(r.get("Expected date", "")),
                    "raw_status": str(r.get("Ichimoku status", "")),
                    "risk": _metric_from_row(r, "Risk"), "tk_cross": _metric_from_row(r, "TK cross"),
                    "dynamic": _metric_from_row(r, "Dynamic"), "cloud": _metric_from_row(r, "Cloud"),
                    "chikou": _metric_from_row(r, "Chikou"), "twist": _metric_from_row(r, "Twist"),
                    "tk_plus": _metric_from_row(r, "TK plus"), "tenkan_in_cloud": _metric_from_row(r, "Tenkan in cloud"),
                },
                chart_url=str(r.get("Link", "")), python_command=str(r.get("Python command", "")), priority="LOW"
            ))
        for r in w_wedge:
            t = str(r.get("Ticker", "")).strip()
            upper = str(r.get("Upper line", ""))
            lower = str(r.get("Lower line", ""))
            def _line_parts(value: str) -> tuple[str, str]:
                if "->" not in value:
                    return "", ""
                a, b = value.split("->", 1)
                return a.replace("@", ",").strip(), b.replace("@", ",").strip()
            upper_start, upper_end = _line_parts(upper)
            lower_start, lower_end = _line_parts(lower)
            rows.append(ScannerRow(
                market=market, scanner="WEDGE", category="falling", ticker=t, status=str(r.get("Status", "falling_wedge_unbroken")),
                dates={"wedge": str(r.get("Wedge", ""))},
                metrics={
                    "days": str(r.get("Days", "")), "months": str(r.get("Months", "")), "upper_touches": str(r.get("Upper touches", "")), "lower_touches": str(r.get("Lower touches", "")),
                    "start_width": str(r.get("Start width", "")), "end_width": str(r.get("End width", "")), "slope": str(r.get("Slope", "")), "breakout_date": str(r.get("Breakout date", "-")), "breakout_direction": str(r.get("Breakout direction", "-")), "score": str(r.get("Score", "")), "avg10d": str(r.get("Avg10d PLN", "")),
                    "upper_start": upper_start, "upper_end": upper_end, "lower_start": lower_start, "lower_end": lower_end,
                    "latest_data": str(r.get("Latest data?", "")), "latest_date": str(r.get("Latest date", "")), "expected_date": str(r.get("Expected date", "")),
                },
                chart_url=str(r.get("Link", "")), python_command=str(r.get("Python command", "")), priority="HIGH"
            ))
        for r in f_w0:
            t = str(r.get("Ticker", "")).strip()
            rows.append(ScannerRow(market=market, scanner="FIBO", category="steep", ticker=t, status=str(r.get("Status", "3p_steep_incline")), pattern="none", direction=str(r.get("Dir", "long")), dates={"incline": str(r.get("Incline", "")), "start": _extract_start_date(r)}, metrics={"ratio": str(r.get("Ratio(d)", "")), "near61": str(r.get("Near61.8", "")), "avg10d": str(r.get("Avg10d PLN", "")), "latest_data": str(r.get("Latest data?", "")), "latest_date": str(r.get("Latest date", "")), "expected_date": str(r.get("Expected date", "")), "ratio_raw": str(_ratio_value(r)), "incline_days": str(_incline_duration_days(r)), "near61_raw": str(_near61_pct(r))}, chart_url=str(r.get("Link", "")), python_command=str(r.get("Python command", "")), priority="HIGH"))
        for r in f_w2:
            t = str(r.get("Ticker", "")).strip()
            rows.append(ScannerRow(market=market, scanner="FIBO", category="valid", ticker=t, status="valid_reversal", pattern=str(r.get("Pattern", "")), direction=str(r.get("Dir", "")), dates={"touch_61": str(r.get("Touched_61.8_date", "")), "incline": str(r.get("Incline", "")), "start": _extract_start_date(r)}, metrics={"ratio": str(r.get("Ratio(d)", "")), "near61": str(r.get("Near61.8", "")), "avg10d": str(r.get("Avg10d PLN", "")), "latest_data": str(r.get("Latest data?", "")), "latest_date": str(r.get("Latest date", "")), "expected_date": str(r.get("Expected date", "")), "ratio_raw": str(_ratio_value(r)), "incline_days": str(_incline_duration_days(r))}, chart_url=str(r.get("Link", "")), python_command=str(r.get("Python command", "")), priority="HIGH"))
        for r in f_w1:
            t = str(r.get("Ticker", "")).strip()
            rows.append(ScannerRow(market=market, scanner="FIBO", category="waiting", ticker=t, status=str(r.get("Status", "")), pattern=str(r.get("Pattern", "")), direction=str(r.get("Dir", "")), dates={"touch_61": str(r.get("Touched_61.8_date", "")), "incline": str(r.get("Incline", "")), "start": _extract_start_date(r)}, metrics={"ratio": str(r.get("Ratio(d)", "")), "near61": str(r.get("Near61.8", "")), "avg10d": str(r.get("Avg10d PLN", "")), "latest_data": str(r.get("Latest data?", "")), "latest_date": str(r.get("Latest date", "")), "expected_date": str(r.get("Expected date", "")), "ratio_raw": str(_ratio_value(r)), "incline_days": str(_incline_duration_days(r)), "near61_raw": str(_near61_pct(r))}, chart_url=str(r.get("Link", "")), python_command=str(r.get("Python command", "")), priority="MEDIUM"))
    return rows


def _fibo_item(row: ScannerRow, include_near: bool = False) -> str:
    direction = "↘️" if str(row.direction).lower() == "short" else "↗️"
    start = row.dates.get("start") or _extract_start_date({"Incline": row.dates.get("incline", "")})
    parts = [f"{_market_icon(row.market, row.ticker)} {row.ticker} {direction} ({start})"]
    if include_near:
        near = _parse_float_text(str(row.metrics.get("near61_raw") or row.metrics.get("near61") or ""), -1.0)
        if near >= 0:
            parts.append(f"{near:.1f}%")
    parts.append(_stooq_link_for_troj(row))
    return "**" + " ".join(parts[:-1]) + "** " + parts[-1]


def _write_trojpolowki_fibo(rows: list[ScannerRow], out_dir: Path, timestamp: datetime) -> Path:
    fibo = [r for r in rows if r.scanner == "FIBO"]
    def _dedupe_same_fibo_start(items: list[ScannerRow]) -> list[ScannerRow]:
        # One instrument may have both a larger and a smaller valid formation, but
        # duplicate rows for the same bottom are noise (e.g. #0 steep + #1 waiting).
        # Keep one row per ticker/direction/start and prefer regular waiting rows
        # over synthetic steep rows when both describe the same formation.
        def priority(row: ScannerRow) -> tuple[int, float]:
            category_rank = {"waiting": 0, "steep": 1, "valid": 2}.get(row.category, 9)
            return (category_rank, -_parse_float_text(row.metrics.get("near61_raw", row.metrics.get("near61", "-1")), -1.0))
        picked: dict[tuple[str, str, str], ScannerRow] = {}
        for row in items:
            key = (str(row.ticker or "").upper(), str(row.direction or "").lower(), str(row.dates.get("start") or ""))
            prev = picked.get(key)
            if prev is None or priority(row) < priority(prev):
                picked[key] = row
        return list(picked.values())
    def _dedupe_nearby_same_scale_display(items: list[ScannerRow]) -> list[ScannerRow]:
        # Markdown rows do not carry fib anchor prices, so use a conservative
        # fallback for historical reports: when the same instrument/direction has
        # nearly identical near-61.8 values and starts only a few weeks apart, treat
        # it as the same-scale formation and keep the older/broader row.
        def parsed_start(row: ScannerRow) -> date | None:
            try:
                value = str(row.dates.get("start") or "")
                return datetime.strptime(value, "%Y-%m-%d").date()
            except Exception:
                return None
        picked: list[ScannerRow] = []
        for row in items:
            row_start = parsed_start(row)
            row_near = _parse_float_text(row.metrics.get("near61_raw", row.metrics.get("near61", "-1")), -1.0)
            duplicate_idx: int | None = None
            for idx, existing in enumerate(picked):
                existing_start = parsed_start(existing)
                existing_near = _parse_float_text(existing.metrics.get("near61_raw", existing.metrics.get("near61", "-1")), -1.0)
                if (
                    str(row.ticker or "").upper() == str(existing.ticker or "").upper()
                    and str(row.direction or "").lower() == str(existing.direction or "").lower()
                    and row_start is not None
                    and existing_start is not None
                    and abs((row_start - existing_start).days) <= 45
                    and row_near >= 0
                    and existing_near >= 0
                    and abs(row_near - existing_near) <= 5.0
                ):
                    duplicate_idx = idx
                    break
            if duplicate_idx is None:
                picked.append(row)
            else:
                existing = picked[duplicate_idx]
                category_rank = {"waiting": 0, "steep": 1, "valid": 2}
                row_rank = category_rank.get(row.category, 9)
                existing_rank = category_rank.get(existing.category, 9)
                row_strength = _parse_float_text(row.metrics.get("ratio_raw", "0"), 0.0)
                existing_strength = _parse_float_text(existing.metrics.get("ratio_raw", "0"), 0.0)
                if row_rank < existing_rank:
                    picked[duplicate_idx] = row
                elif row_rank == existing_rank and row_strength > existing_strength:
                    picked[duplicate_idx] = row
                elif row_rank == existing_rank and row_strength == existing_strength:
                    existing_start = parsed_start(existing)
                    if row_start is not None and existing_start is not None and row_start < existing_start:
                        picked[duplicate_idx] = row
        return picked
    fibo = _dedupe_nearby_same_scale_display(_dedupe_same_fibo_start(fibo))
    def _fibo_near(row: ScannerRow) -> float:
        return _parse_float_text(row.metrics.get("near61_raw", row.metrics.get("near61", "-1")), -1.0)
    def _fibo_steep(row: ScannerRow) -> bool:
        return int(_parse_float_text(row.metrics.get("incline_days", "0"), 0)) >= 21 and _parse_float_text(row.metrics.get("ratio_raw", "0"), 0) >= 1.0
    def _fibo_start(row: ScannerRow) -> str:
        return str(row.dates.get("start") or "")
    def _fibo_has_23_6_warning(row: ScannerRow) -> bool:
        status = str(row.status or "").lower()
        pattern = str(row.pattern or "").lower()
        # Do not treat the scanner's generic 23.6 waiting status as bearish by itself;
        # only explicit bearish/invalidated context should block the early steep column.
        return "bearish" in status or "bearish" in pattern
    def _fibo_steep_23_6_zone(row: ScannerRow) -> bool:
        return row.category == "steep" and "23_6_zone" in str(row.status or "").lower()
    def _fibo_allowed_deep_pullback(row: ScannerRow) -> bool:
        near = _fibo_near(row)
        if 75.0 <= near < 100.0:
            return True
        return str(row.pattern or "").strip().lower() not in {"", "-", "none"}
    def _fibo_touch_date(row: ScannerRow) -> date | None:
        try:
            txt = str(row.dates.get("touch_61", "") or "")[:10]
            return datetime.strptime(txt, "%Y-%m-%d").date()
        except Exception:
            return None
    col1 = [r for r in fibo if r.category == "steep" and _fibo_steep(r) and "invalidated" not in r.status.lower() and not _fibo_has_23_6_warning(r) and not _fibo_steep_23_6_zone(r) and (_fibo_near(r) < 0 or _fibo_near(r) < 15.0)]
    col2 = [r for r in fibo if ((r.category in {"waiting", "steep"} and 0.0 <= _fibo_near(r) < 75.0) or (_fibo_steep_23_6_zone(r) and 0.0 <= _fibo_near(r) < 75.0))]
    col3 = [r for r in fibo if r.category != "valid" and _fibo_near(r) >= 75.0 and _fibo_allowed_deep_pullback(r)]
    col4 = [r for r in fibo if r.category == "valid"]
    col1.sort(key=lambda r: (_market_sort_key(r)[0], -_parse_float_text(r.metrics.get("ratio_raw", "-1"), -1), _fibo_start(r), _market_sort_key(r)[1]))
    col2.sort(key=lambda r: (_market_sort_key(r)[0], -_parse_float_text(r.metrics.get("near61_raw", r.metrics.get("near61", "-1")), -1.0), _market_sort_key(r)[1]))
    col3.sort(key=lambda r: (_market_sort_key(r)[0], -_parse_float_text(r.metrics.get("near61_raw", r.metrics.get("near61", "-1")), -1.0), _market_sort_key(r)[1]))
    col4.sort(key=lambda r: (_market_sort_key(r)[0], _fibo_touch_date(r) or date.min, _market_sort_key(r)[1]), reverse=True)
    out_dir.mkdir(parents=True, exist_ok=True)
    path = out_dir / "fibo.md"
    max_len = max(len(col1), len(col2), len(col3), len(col4), 1)
    lines = ["# Trójpolówki — Fibo", "", f"Updated from allsearch: {timestamp.strftime('%Y-%m-%d %H:%M:%S')}", "", "| 🚀 Steep incline / no major bearish signal | ⚠️ Waiting 23.6→61.8 / bearish close | 🎯 Near 61.8 > 75% / deeper pullback | ✅ Pattern ≤14d / SL intact |", "|---|---|---|---|"]
    for idx in range(max_len):
        cells = [
            _fibo_item(col1[idx], include_near=False) if idx < len(col1) else "",
            _fibo_item(col2[idx], include_near=True) if idx < len(col2) else "",
            _fibo_item(col3[idx], include_near=True) if idx < len(col3) else "",
            _fibo_item(col4[idx], include_near=False) if idx < len(col4) else "",
        ]
        lines.append("| " + " | ".join(cell.replace("|", "\\|") for cell in cells) + " |")
    path.write_text("\n".join(lines) + "\n", encoding="utf-8")
    return path


def _status_plain(value: str) -> str:
    txt = re.sub(r"^[^A-Za-z0-9_]+\s*", "", str(value or "")).strip()
    return txt or "-"


def _is_missing(value: str | None) -> bool:
    return str(value or "").strip() in {"", "-"}


def _risk_value(value: str | None) -> int:
    if _is_missing(value):
        return -1
    return int(_parse_float_text(str(value), -1.0))


def _readable_breakout_note(status: str, ichimoku_status: str = "") -> str:
    norm = _status_plain(status).lower().replace(" ", "_")
    if "(" in norm:
        norm = norm.split("(", 1)[0].strip()
    if norm in TROJPOLLOWKI_RETEST_LABELS and norm != "no_breakout":
        return TROJPOLLOWKI_RETEST_LABELS[norm]
    text = _status_plain(ichimoku_status or status)
    low = text.lower()
    if "touch" in low and "cloud" in low:
        return "touched cloud"
    if "inside" in low and "cloud" in low:
        return "inside cloud"
    if "unsuccessful breakout" in low:
        return "unsuccessful breakout"
    return "-"


def _cloud_side_label(row: ScannerRow) -> str:
    text = f"{row.status} {row.metrics.get('current_side','')} {row.metrics.get('ichimoku_status','')} {row.metrics.get('raw_status','')}".lower()
    if "inside" in text and "cloud" in text:
        return "🟡 inside cloud"
    if "touch" in text and "cloud" in text:
        return "☁️ touched cloud"
    if "above" in text or "over kijun" in text:
        return "🟢 above cloud"
    if "below" in text or "under kijun" in text:
        return "🔴 below cloud"
    return "-"


def _bias_label(row: ScannerRow, note: str) -> str:
    if row.category == "retest_breakout" or note not in {"", "-"} and any(token in note for token in ("breakout", "retest", "returned")):
        return "🔁 retest"
    side = _cloud_side_label(row)
    status = f"{row.status} {row.metrics.get('ichimoku_status','')}".lower()
    if "below" in side or "under kijun" in status:
        return "↘️ short"
    if "above" in side or "over kijun" in status:
        return "↗️ long"
    if "inside" in side or "touched" in side:
        return "👀 watch"
    return "-"


def _source_metric(row: ScannerRow, key: str) -> str:
    value = str(row.metrics.get(key, "")).strip()
    return value if value else "-"


def _write_trojpolowki_ichimoku(rows: list[ScannerRow], out_dir: Path, timestamp: datetime) -> Path:
    candidates = [r for r in rows if r.scanner == "ICHIMOKU"]

    def _kijun_label(raw: str) -> str:
        low = str(raw or "").lower()
        if "over kijun" in low:
            return "over"
        if "under kijun" in low:
            return "under"
        if "touched" in low and "kijun" in low:
            return "touched"
        return "-"

    def _recent_ichimoku_date(value: str | None, max_days: int = 3) -> bool:
        match = re.search(r"\d{4}-\d{2}-\d{2}", str(value or ""))
        if not match:
            return False
        try:
            d = datetime.strptime(match.group(0), "%Y-%m-%d").date()
        except Exception:
            return False
        return 0 <= (timestamp.date() - d).days <= max_days

    def prepared(row: ScannerRow) -> tuple[ScannerRow, dict[str, str]]:
        raw_status = row.metrics.get("raw_status", row.status)
        raw_kijun = _source_metric(row, "ichimoku_status")
        kijun = _kijun_label(raw_kijun)
        cloud_side = _cloud_side_label(row)
        note = _readable_breakout_note(raw_status, raw_kijun)
        if note == "-":
            if "inside" in cloud_side:
                note = "inside cloud"
            elif "touched" in cloud_side:
                note = "touched cloud"
            elif "above" in cloud_side:
                note = "above cloud"
            elif "below" in cloud_side:
                note = "below cloud"
            elif raw_kijun != "-":
                note = raw_kijun
        latest_pattern = _source_metric(row, "latest_retest_pattern")
        latest_pattern_date = _source_metric(row, "latest_retest_date")
        active_latest_pattern = latest_pattern != "-" and _recent_ichimoku_date(latest_pattern_date, max_days=3)
        if active_latest_pattern and note in {"-", "inside cloud", "touched cloud"}:
            note = latest_pattern
        info = {
            "cloud_side": cloud_side,
            "kijun": kijun,
            "note": note,
            "current_side": _source_metric(row, "current_side"),
            "risk": _source_metric(row, "risk"),
            "tk_cross": _source_metric(row, "tk_cross"),
            "dynamic": _source_metric(row, "dynamic"),
            "cloud": _source_metric(row, "cloud"),
            "chikou": _source_metric(row, "chikou"),
            "twist": _source_metric(row, "twist"),
            "tk_plus": _source_metric(row, "tk_plus"),
            "tenkan_in_cloud": _source_metric(row, "tenkan_in_cloud"),
        }
        recent_breakout = note == "breakout confirmed" and _recent_ichimoku_date(row.dates.get("flip_date") or row.metrics.get("latest_date"))
        if note == "breakout confirmed" and not recent_breakout and (("above" in info["cloud_side"] and kijun == "over") or ("below" in info["cloud_side"] and kijun == "under")):
            info["note"] = "above cloud" if "above" in info["cloud_side"] else "below cloud"
            info["bias"] = "↗️ long" if "above" in info["cloud_side"] else "↘️ short"
        else:
            info["bias"] = _bias_label(row, info["note"])
        return row, info

    prepared_rows = [prepared(r) for r in candidates]

    def include(item: tuple[ScannerRow, dict[str, str]]) -> bool:
        row, info = item
        months = _parse_float_text(row.metrics.get("months", "0"), 0.0)
        risk = _risk_value(info["risk"])
        special = info["note"] != "-" or any(token in info["cloud_side"] for token in ("inside", "touched"))
        tk_cross_signal = info["tk_cross"] not in {"-", "none"}
        kijun_or_tk = info["kijun"] in {"over", "under", "touched"} or tk_cross_signal
        return risk >= 1 or months >= 4.0 or special or kijun_or_tk

    def is_short(info: dict[str, str]) -> bool:
        text = f"{info.get('bias', '')} {info.get('cloud_side', '')} {info.get('current_side', '')} {info.get('kijun', '')}".lower()
        if "short" in text or "below" in text or "under" in text:
            return True
        chikou_under = any(token in info.get("chikou", "").lower() for token in ("under", "below", "↓", "down"))
        bearish_breakout_context = (
            info.get("note", "") not in {"", "-", "above cloud", "below cloud"}
            and info.get("twist", "").lower() == "red"
            and chikou_under
            and _risk_value(info.get("risk", "-")) >= 2
        )
        return bearish_breakout_context

    def _is_fresh_retest_window(row: ScannerRow) -> bool:
        months = _parse_float_text(row.metrics.get("months", "0"), 0.0)
        return row.category == "retest_breakout" and months <= 4.0

    def _short_retest_trigger(row: ScannerRow, info: dict[str, str]) -> bool:
        touches_cloud = any(token in info["cloud_side"] for token in ("inside", "touched"))
        touches_kijun = info["kijun"] == "touched"
        return touches_cloud or touches_kijun

    def _is_retest_under_4m(item: tuple[ScannerRow, dict[str, str]]) -> bool:
        row, info = item
        latest_pattern = _source_metric(row, "latest_retest_pattern")
        latest_pattern_date = _source_metric(row, "latest_retest_date")
        active_pattern = latest_pattern != "-" and _recent_ichimoku_date(latest_pattern_date, max_days=3)
        return (_is_fresh_retest_window(row) or active_pattern) and _short_retest_trigger(row, info)

    def _touches_cloud(item: tuple[ScannerRow, dict[str, str]]) -> bool:
        _row, info = item
        return any(token in info["cloud_side"] for token in ("inside", "touched"))

    def _has_current_cloud_context(item: tuple[ScannerRow, dict[str, str]]) -> bool:
        row, info = item
        if _is_fresh_retest_window(row):
            return False
        if _touches_cloud(item):
            return True
        return info["note"] not in {"-", "above cloud", "below cloud"} and ("breakout" in info["note"] or "retest" in info["note"] or "returned" in info["note"] or "unsuccessful" in info["note"])

    def bucket(item: tuple[ScannerRow, dict[str, str]]) -> str:
        row, info = item
        if _is_retest_under_4m(item):
            return "short_retest"
        tk_cross_signal = info["tk_cross"] not in {"-", "none"}
        has_kijun_or_tk = info["kijun"] in {"over", "under", "touched"} or tk_cross_signal
        if _is_fresh_retest_window(row):
            if "breakout" in info["note"]:
                return "cloud"
            return "watch" if has_kijun_or_tk else "skip"
        if _has_current_cloud_context(item):
            return "cloud"
        months = _parse_float_text(row.metrics.get("months", "0"), 0.0)
        if months >= 4.0 and any(token in info["cloud_side"] for token in ("above", "below")) and info["kijun"] != "touched":
            return "strong"
        if info["kijun"] == "touched" or tk_cross_signal or (has_kijun_or_tk and months < 4.0):
            return "watch"
        if has_kijun_or_tk:
            return "watch"
        return "skip"

    def _risk_icon(risk: str) -> str:
        value = _risk_value(risk)
        if value >= 3:
            return "🟢"
        if value == 2:
            return "🟡"
        if value == 1:
            return "🔵"
        if value == 0:
            return "⚪"
        return "⚪"

    def _risk_text(risk: str) -> str:
        return risk if not _is_missing(risk) else "-"

    def _chikou_direction(info: dict[str, str]) -> str:
        value = info["chikou"].lower()
        if value == "yes":
            return "under" if is_short(info) else "over"
        if "under" in value or "below" in value or "↓" in value or "down" in value:
            return "under"
        if "over" in value or "above" in value or "↑" in value or "up" in value:
            return "over"
        if "equal" in value or "flat" in value or "↔" in value:
            return "equal"
        return "-"

    def _chikou_text(info: dict[str, str]) -> str:
        direction = _chikou_direction(info)
        if direction == "over":
            return "⬆️ Chikou over"
        if direction == "under":
            return "⬇️ Chikou under"
        if direction == "equal":
            return "↔️ Chikou equal"
        if info["chikou"].lower() == "no":
            return "Chikou -"
        return "Chikou -"

    def _twist_text(info: dict[str, str]) -> str:
        value = info["twist"].lower()
        if value == "green":
            return "🟢 kumo"
        if value == "red":
            return "🔴 kumo"
        if value == "neutral":
            return "⚪ kumo"
        return "kumo -"

    def _tk_cross_factor(info: dict[str, str]) -> str | None:
        tk_cross = info["tk_cross"].lower()
        if "bullish" in tk_cross:
            return "🟢 TK cross bullish"
        if "bearish" in tk_cross:
            return "🔴 TK cross bearish"
        if "neutral" in tk_cross:
            return "⚪ TK neutral"
        return None

    def _tk_cross_confirms_context(info: dict[str, str], tk: str) -> bool:
        # The same TK cross can be plus or minus depending on the setup:
        # bearish crosses support bearish breakout/retest contexts, while they
        # are a warning for long/reversal contexts. Bullish crosses are the
        # mirror image.
        bearish_context = is_short(info)
        is_bullish_cross = "bullish" in tk
        if "neutral" in tk:
            return True
        return is_bullish_cross != bearish_context

    def _factor_lists(info: dict[str, str]) -> tuple[list[str], list[str]]:
        plus: list[str] = []
        minus: list[str] = []
        tk = _tk_cross_factor(info)
        if tk:
            (plus if _tk_cross_confirms_context(info, tk) else minus).append(tk)
        tenkan = info["tenkan_in_cloud"].lower()
        if tenkan == "yes":
            plus.append("Tenkan_in_☁: yes")
        elif tenkan == "no":
            minus.append("Tenkan_in_☁: no")
        dynamic = info["dynamic"].lower()
        if dynamic in {"aggressive", "high", "mild"}:
            plus.append(f"dyn {dynamic}")
        elif dynamic in {"slow", "very slow"}:
            minus.append(f"dyn {dynamic}")
        cloud = info["cloud"].lower()
        if cloud in {"thick", "normal"}:
            plus.append(f"cloud {cloud}")
        elif cloud == "shallow":
            minus.append("cloud shallow")
        return plus, minus

    def item_text(row: ScannerRow, info: dict[str, str], detailed: bool) -> str:
        months = _parse_float_text(row.metrics.get("months", "0"), 0.0)
        months_txt = f"{months:.1f}m" if str(row.metrics.get("months", "")).strip() else "-"
        note = info["note"] if info["note"] != "-" else "-"
        if note != "-" and any(token in note.lower() for token in ("breakout", "retest", "pattern")):
            note_date = str(row.metrics.get("latest_retest_date") or row.dates.get("flip_date") or row.dates.get("start_date") or "").strip()
            if note_date and note_date != "-":
                note = f"{note} ({note_date})"
        lines = [f"**{_market_icon(row.market, row.ticker)} {row.ticker} {info['bias']} ({months_txt})**"]
        lines.append(f"🏷️ {note}")
        if detailed:
            plus, minus = _factor_lists(info)
            lines.append(f"{_risk_icon(info['risk'])} risk: {_risk_text(info['risk'])} · {_chikou_text(info)} · {_twist_text(info)}")
            if plus:
                lines.append("➕ " + " · ".join(plus))
            if minus:
                lines.append("➖ " + " · ".join(minus))
        elif info["kijun"] != "-":
            lines.append(f"Kijun: {info['kijun']}")
        lines.append(_links_for_troj(row))
        return "<br>".join(lines)

    prepared_rows = [item for item in prepared_rows if include(item) and bucket(item) != "skip"]
    prepared_rows.sort(key=lambda item: ({"cloud": 0, "short_retest": 1, "watch": 2, "strong": 3}.get(bucket(item), 9), _market_sort_key(item[0])[0], 0 if bucket(item) != "short_retest" or _touches_cloud(item) else 1, -max(_risk_value(item[1]["risk"]), 0), -_parse_float_text(item[0].metrics.get("months", "0"), 0.0), item[0].ticker))

    out_dir.mkdir(parents=True, exist_ok=True)
    path = out_dir / "ichimoku.md"
    headers = ["🟢 Strong / continuation", "👀 Kijun / watch", "☁️ Cloud / retest / breakout", "🔁 Retest <4m"]
    lines = [
        "# Trójpolówki — Ichimoku",
        "",
        f"Updated from allsearch: {timestamp.strftime('%Y-%m-%d %H:%M:%S')}",
        "",
        "Legenda:",
        "- ☁️ Cloud/retest/breakout rows have priority and appear in the third column.",
        "- 🔁 Retest <4m contains fresh valid breakouts from the last 4 months only when the newest candle touches Kijun, touches the cloud, or is inside the cloud; we wait for patterns in the last two cases.",
        "- Risk/grading details are shown only in the ☁️ Cloud / retest / breakout and 🔁 Retest <4m columns.",
        "- Risk icons: 🟢 3%, 🟡 2%, 🔵 1%, ⚪ 0% or missing.",
        "- Chikou uses arrow-only direction: ⬆️ over price and ⬇️ under price (under price supports bearish breakout/retest context).",
        "- TK values use the latest actionable Tenkan/Kijun direction (bullish/bearish, with neutral only when equal); the ➕/➖ placement is context-aware (bearish TK is ➕ for bearish breakout/retest, but ➖ for long/reversal context).",
        "- Tenkan_in_☁ shows whether Tenkan is inside the cloud; kumo color is the projected cloud to the right of the latest candle.",
        "- ➕/➖ lines are qualitative context only (TK cross, Tenkan_in_☁, dynamic, cloud thickness).",
        "- 🏷️ is the current scanner status/note; missing source fields stay as `-`.",
        "",
        "| " + " | ".join(headers) + " |",
        "|---|---|---|---|",
    ]
    columns = [[], [], [], []]
    for row, info in prepared_rows:
        b = bucket((row, info))
        if b == "cloud":
            columns[2].append(item_text(row, info, detailed=True))
        elif b == "short_retest":
            columns[3].append(item_text(row, info, detailed=True))
        elif b == "strong":
            columns[0].append(item_text(row, info, detailed=False))
        else:
            columns[1].append(item_text(row, info, detailed=False))
    max_rows = max([len(col) for col in columns] + [1])
    for idx in range(max_rows):
        cells = [columns[col_idx][idx] if idx < len(columns[col_idx]) else "" for col_idx in range(4)]
        lines.append("| " + " | ".join(str(v).replace("|", "\\|") for v in cells) + " |")
    path.write_text("\n".join(lines) + "\n", encoding="utf-8")
    return path


def _write_trojpolowki_reports(scopes: list[str], timestamp: datetime | None = None) -> tuple[Path, Path]:
    ts = timestamp or datetime.now()
    rows = _read_allsearch_rows(scopes)
    fibo_path = _write_trojpolowki_fibo(rows, TROJPOLLOWKI_DIR, ts)
    ichimoku_path = _write_trojpolowki_ichimoku(rows, TROJPOLLOWKI_DIR, ts)
    return fibo_path, ichimoku_path


def _build_html_report(scopes: list[str], output_path: Path) -> None:
    def _parse_md_tables(md_path: Path) -> dict[str, list[dict[str, str]]]:
        out: dict[str, list[dict[str, str]]] = {}
        if not md_path.exists():
            return out
        lines = md_path.read_text(encoding="utf-8").splitlines()
        last_heading = ""
        i = 0
        while i < len(lines):
            line = lines[i].strip()
            if line.startswith("#"):
                last_heading = line.lstrip("#").strip()
            if i + 2 < len(lines) and lines[i].strip().startswith("|") and lines[i + 1].strip().startswith("|"):
                headers = [h.strip() for h in lines[i].strip().strip("|").split("|")]
                separator = [s.strip() for s in lines[i + 1].strip().strip("|").split("|")]
                if headers and separator and all(set(s) <= {"-", ":"} and s for s in separator):
                    rows: list[dict[str, str]] = []
                    j = i + 2
                    while j < len(lines) and lines[j].strip().startswith("|"):
                        vals = [v.strip() for v in lines[j].strip().strip("|").split("|")]
                        if len(vals) == len(headers):
                            row = {headers[k]: vals[k] for k in range(len(headers))}
                            link_cell = row.get("Link", "")
                            inline_match = re.match(r"^\[[^\]]+\]\(([^)]+)\)$", link_cell)
                            if inline_match:
                                row["Link"] = inline_match.group(1)
                            rows.append(row)
                        j += 1
                    title = last_heading or "TABLE"
                    out.setdefault(title, []).extend(rows)
                    i = j
                    continue
            i += 1
        return out

    rows: list[ScannerRow] = []
    for scope in scopes:
        market = scope.upper()
        i_md = _latest_scope_md("search", scope)
        f_md = _latest_scope_md("fibo_search", scope)
        i_tables = _parse_md_tables(i_md) if i_md else {}
        f_tables = _parse_md_tables(f_md) if f_md else {}
        i_w2 = next((v for k, v in i_tables.items() if "WYNIKI 2" in k.upper()), [])
        i_w1 = next((v for k, v in i_tables.items() if k.upper().strip() == "WYNIKI" or "WYNIKI 1" in k.upper()), [])
        f_w0 = next((v for k, v in f_tables.items() if "WYNIKI FIBO #0" in k.upper()), [])
        f_w2 = next((v for k, v in f_tables.items() if "WYNIKI FIBO #2" in k.upper()), [])
        f_w1 = next((v for k, v in f_tables.items() if "WYNIKI FIBO #1" in k.upper()), [])
        w_wedge = next((v for k, v in f_tables.items() if "WYNIKI KLINY" in k.upper()), [])
        for r in i_w2:
            t = str(r.get("Ticker", "")).strip()
            rows.append(ScannerRow(
                market=market, scanner="ICHIMOKU", category="retest_breakout", ticker=t,
                status=str(r.get("Latest Retest status", "")), dates={"flip_date": str(r.get("Data wybicia", ""))},
                metrics={"months": str(r.get("Mies. od wybicia", "")), "previous_respect_months": str(r.get("Mies. respektu przed wybiciem", "")), "retest_count": str(r.get("Retest count", "")), "avg10d": str(r.get("Avg10d PLN", "")), "latest_retest_date": str(r.get("Latest Retest date", "")), "latest_retest_pattern": str(r.get("Latest Retest pattern", "")), "latest_data": str(r.get("Latest data?", "")), "latest_date": str(r.get("Latest date", "")), "expected_date": str(r.get("Expected date", "")), "raw_status": str(r.get("Latest Retest status", "")), "previous_side": str(r.get("Poprzednia", "") or r.get("Było", "")), "current_side": str(r.get("Jest", "") or r.get("Current", "")), "ichimoku_status": str(r.get("Ichimoku status", "")), "risk": str(r.get("Risk", "")), "tk_cross": str(r.get("TK cross", "")), "dynamic": str(r.get("Dynamic", "")), "cloud": str(r.get("Cloud", "")), "chikou": str(r.get("Chikou", "")), "twist": str(r.get("Twist", "")), "tk_plus": str(r.get("TK plus", "")), "tenkan_in_cloud": str(r.get("Tenkan in cloud", ""))},
                chart_url=str(r.get("Link", "")), python_command=str(r.get("Python command", "")), priority="MEDIUM"
            ))
        for r in i_w1:
            t = str(r.get("Ticker", "")).strip()
            rows.append(ScannerRow(
                market=market, scanner="ICHIMOKU", category="position", ticker=t,
                status=str(r.get("Pozycja", "")), dates={"start_date": str(r.get("Start", ""))},
                metrics={"candles": str(r.get("Świece", "")), "months": str(r.get("Mies.", "")), "close": str(r.get("Close", "")), "avg10d": str(r.get("Avg10d PLN", "")), "ichimoku_status": str(r.get("Ichimoku status", "")), "raw_status": str(r.get("Pozycja", "")), "latest_retest_count": str(r.get("Retest count", "")), "latest_retest_date": str(r.get("Latest Retest date", "")), "latest_retest_pattern": str(r.get("Latest Retest pattern", "")), "latest_data": str(r.get("Latest data?", "")), "latest_date": str(r.get("Latest date", "")), "expected_date": str(r.get("Expected date", "")), "risk": str(r.get("Risk", "")), "tk_cross": str(r.get("TK cross", "")), "dynamic": str(r.get("Dynamic", "")), "cloud": str(r.get("Cloud", "")), "chikou": str(r.get("Chikou", "")), "twist": str(r.get("Twist", "")), "tk_plus": str(r.get("TK plus", "")), "tenkan_in_cloud": str(r.get("Tenkan in cloud", ""))},
                chart_url=str(r.get("Link", "")), python_command=str(r.get("Python command", "")), priority="LOW"
            ))
        for r in w_wedge:
            t = str(r.get("Ticker", "")).strip()
            upper = str(r.get("Upper line", ""))
            lower = str(r.get("Lower line", ""))
            def _line_parts(value: str) -> tuple[str, str]:
                if "->" not in value:
                    return "", ""
                a, b = value.split("->", 1)
                return a.replace("@", ",").strip(), b.replace("@", ",").strip()
            upper_start, upper_end = _line_parts(upper)
            lower_start, lower_end = _line_parts(lower)
            rows.append(ScannerRow(
                market=market, scanner="WEDGE", category="falling", ticker=t, status=str(r.get("Status", "falling_wedge_unbroken")),
                dates={"wedge": str(r.get("Wedge", ""))},
                metrics={
                    "days": str(r.get("Days", "")), "months": str(r.get("Months", "")), "upper_touches": str(r.get("Upper touches", "")), "lower_touches": str(r.get("Lower touches", "")),
                    "start_width": str(r.get("Start width", "")), "end_width": str(r.get("End width", "")), "slope": str(r.get("Slope", "")), "breakout_date": str(r.get("Breakout date", "-")), "breakout_direction": str(r.get("Breakout direction", "-")), "score": str(r.get("Score", "")), "avg10d": str(r.get("Avg10d PLN", "")),
                    "upper_start": upper_start, "upper_end": upper_end, "lower_start": lower_start, "lower_end": lower_end,
                    "latest_data": str(r.get("Latest data?", "")), "latest_date": str(r.get("Latest date", "")), "expected_date": str(r.get("Expected date", "")),
                },
                chart_url=str(r.get("Link", "")), python_command=str(r.get("Python command", "")), priority="HIGH"
            ))
        for r in f_w0:
            t = str(r.get("Ticker", "")).strip()
            rows.append(ScannerRow(market=market, scanner="FIBO", category="steep", ticker=t, status=str(r.get("Status", "3p_steep_incline")), pattern="none", direction=str(r.get("Dir", "long")), dates={"incline": str(r.get("Incline", "")), "start": _extract_start_date(r)}, metrics={"ratio": str(r.get("Ratio(d)", "")), "near61": str(r.get("Near61.8", "")), "avg10d": str(r.get("Avg10d PLN", "")), "latest_data": str(r.get("Latest data?", "")), "latest_date": str(r.get("Latest date", "")), "expected_date": str(r.get("Expected date", "")), "ratio_raw": str(_ratio_value(r)), "incline_days": str(_incline_duration_days(r)), "near61_raw": str(_near61_pct(r))}, chart_url=str(r.get("Link", "")), python_command=str(r.get("Python command", "")), priority="HIGH"))
        for r in f_w2:
            t = str(r.get("Ticker", "")).strip()
            rows.append(ScannerRow(
                market=market, scanner="FIBO", category="valid", ticker=t, status="valid_reversal",
                pattern=str(r.get("Pattern", "")), direction=str(r.get("Dir", "")),
                dates={"touch_61": str(r.get("Touched_61.8_date", "")), "incline": str(r.get("Incline", "")), "start": _extract_start_date(r)},
                metrics={"ratio": str(r.get("Ratio(d)", "")), "near61": str(r.get("Near61.8", "")), "avg10d": str(r.get("Avg10d PLN", "")), "latest_data": str(r.get("Latest data?", "")), "latest_date": str(r.get("Latest date", "")), "expected_date": str(r.get("Expected date", "")), "ratio_raw": str(_ratio_value(r)), "incline_days": str(_incline_duration_days(r)), "near61_raw": str(_near61_pct(r))}, chart_url=str(r.get("Link", "")),
                python_command=str(r.get("Python command", "")), priority="HIGH"
            ))
        for r in f_w1:
            t = str(r.get("Ticker", "")).strip()
            rows.append(ScannerRow(
                market=market, scanner="FIBO", category="waiting", ticker=t, status=str(r.get("Status", "")),
                pattern=str(r.get("Pattern", "")), direction=str(r.get("Dir", "")),
                dates={"touch_61": str(r.get("Touched_61.8_date", "")), "incline": str(r.get("Incline", "")), "start": _extract_start_date(r)},
                metrics={"ratio": str(r.get("Ratio(d)", "")), "near61": str(r.get("Near61.8", "")), "avg10d": str(r.get("Avg10d PLN", "")), "latest_data": str(r.get("Latest data?", "")), "latest_date": str(r.get("Latest date", "")), "expected_date": str(r.get("Expected date", "")), "ratio_raw": str(_ratio_value(r)), "incline_days": str(_incline_duration_days(r)), "near61_raw": str(_near61_pct(r))}, chart_url=str(r.get("Link", "")),
                python_command=str(r.get("Python command", "")), priority="MEDIUM"
            ))

        if i_tables or f_tables:
            continue

        ichimoku_csv: list[Path] = []
        fibo_csv: list[Path] = []
        for key in _scope_file_keys(scope):
            ichimoku_csv.extend(ICHIMOKU_SEARCH_OUTPUT_DIR.glob(f"search_{key}_*.csv"))
            fibo_csv.extend(FIBO_SEARCH_OUTPUT_DIR.glob(f"fibo_search_{key}_*.csv"))
        ichimoku_csv = sorted([p for p in ichimoku_csv if p.is_file()], key=lambda p: p.stat().st_mtime)
        fibo_csv = sorted([p for p in fibo_csv if p.is_file()], key=lambda p: p.stat().st_mtime)
        if ichimoku_csv:
            base = [p for p in ichimoku_csv if not p.name.endswith("_flips.csv")]
            flips = [p for p in ichimoku_csv if p.name.endswith("_flips.csv")]
            for p, cat in ([(flips[-1], "retest_breakout")] if flips else []) + ([(base[-1], "position")] if base else []):
                with p.open(newline="", encoding="utf-8") as fh:
                    for r in csv.DictReader(fh):
                        status = str(r.get("latest_retest_status") or r.get("side") or "")
                        prio = "HIGH" if "returned_to_cloud_waiting_for_pattern" in status else ("MEDIUM" if cat == "retest_breakout" else "LOW")
                        rows.append(ScannerRow(
                            market=market, scanner="ICHIMOKU", category=cat, ticker=str(r.get("ticker", "")),
                            status=status, dates={"start_date": str(r.get("start_date", "")), "flip_date": str(r.get("flip_date", ""))},
                            metrics={"candles": str(r.get("respect_days", "")), "months": str(r.get("respect_months", "")), "close": str(r.get("last_close", "")),
                                     "avg10d": str(r.get("avg_turnover_10d_pln", "")), "ichimoku_status": str(r.get("ichimoku_status", "")),
                                     "latest_retest_count": str(r.get("latest_retest_count", "")), "latest_retest_date": str(r.get("last_valid_retest_pattern_date", "")), "latest_retest_pattern": str(r.get("last_valid_retest_pattern_name", ""))},
                            chart_url=_stooq_chart_url(str(r.get("ticker", ""))),
                            python_command=f"python run -c {r.get('ticker','')}",
                            priority=prio))
        if fibo_csv:
            w2 = [p for p in fibo_csv if p.name.endswith("_w2.csv")]
            w1 = [p for p in fibo_csv if p.name.endswith("_w1.csv")]
            generic = [p for p in fibo_csv if not p.name.endswith("_w1.csv") and not p.name.endswith("_w2.csv")]
            ordered_files: list[tuple[Path, str]] = []
            if w2 or w1:
                if w2: ordered_files.append((w2[-1], "valid"))
                if w1: ordered_files.append((w1[-1], "waiting"))
            elif generic:
                ordered_files.append((generic[-1], "mixed"))
            for p, cat in ordered_files:
                with p.open(newline="", encoding="utf-8") as fh:
                    for r in csv.DictReader(fh):
                        st = str(r.get("status", ""))
                        actual_cat = "valid" if st == "valid_reversal" else ("waiting" if st == "reached_23_6_waiting_for_61_8" else cat)
                        rows.append(ScannerRow(
                            market=market, scanner="FIBO", category=actual_cat, ticker=str(r.get("ticker", "")),
                            status=st, pattern=str(r.get("reversal_pattern_name", "")), direction=str(r.get("direction", "")),
                            dates={"touch_61": str(r.get("first_61_8_touch_date", "")), "incline_start": str(r.get("incline_start_date", "")), "incline_end": str(r.get("incline_end_date", ""))},
                            metrics={"ratio": str(r.get("incline_decline_duration_ratio", ""))},
                            chart_url=_stooq_chart_url(str(r.get("ticker", ""))),
                            python_command=str(r.get("python_command", "")),
                            priority="HIGH" if actual_cat == "valid" else "MEDIUM"))
    def key(r: ScannerRow):
        cat_order = {"valid": 0, "retest_breakout": 1, "waiting": 2, "position": 3}
        date = r.dates.get("touch_61") or r.dates.get("flip_date") or r.dates.get("incline_end") or ""
        return (cat_order.get(r.category, 9), date)
    rows = sorted(rows, key=key, reverse=False)
    counts = {
        "ichimoku_active": sum(1 for r in rows if r.scanner == "ICHIMOKU"),
        "ichimoku_retests": sum(1 for r in rows if r.category == "retest_breakout"),
        "fibo_waiting": sum(1 for r in rows if r.scanner == "FIBO" and r.category == "waiting"),
        "fibo_valid": sum(1 for r in rows if r.scanner == "FIBO" and r.category == "valid"),
    }
    by_market = {s.upper(): [r for r in rows if r.market == s.upper()] for s in scopes}
    empty_markets = sum(1 for _, vals in by_market.items() if not vals)


    def _is_recent_retest_date(val: str) -> bool:
        txt = str(val or "").strip()
        if not txt or txt == "-":
            return False
        try:
            d = datetime.strptime(txt[:10], "%Y-%m-%d").date()
        except Exception:
            return False
        today = datetime.now().date()
        return d == today or d == (today - timedelta(days=1))

    def _maybe_green_recent(val: str, highlight: bool) -> str:
        txt = str(val or "")
        if not highlight:
            return html.escape(txt)
        return f"<span style='color:#16a34a;font-weight:700'>{html.escape(txt)}</span>"

    def _color_ichimoku_status(val: str) -> str:
        txt = str(val or "")
        norm = txt.strip().lower()
        if "pattern" in norm:
            return f"<span style='color:#16a34a;font-weight:800'>{html.escape(txt)}</span>"
        if "inside the cloud" in norm:
            return f"<span style='color:#b45309;font-weight:700'>{html.escape(txt)}</span>"
        if "unsuccessful breakout to the other side" in norm:
            return f"<span style='color:#dc2626;font-weight:700'>{html.escape(txt)}</span>"
        return html.escape(txt)

    def _latest_data_cell(value: str) -> str:
        txt = str(value or "").strip()
        norm = txt.lower()
        if norm in {"yes", "true", "1", "ok"}:
            txt = "✅"
        return f"<td class='latest-data-cell'>{html.escape(txt)}</td>"

    def _color_fibo_metric(val: str) -> str:
        txt = str(val or "")
        if txt.endswith("%"):
            try:
                pct = float(txt.replace("%", "").replace("🟨", "").replace("🟢", "").replace("🟡", "").replace("🔴", "").strip())
                if pct >= 70.0:
                    return f"<span style='color:#16a34a;font-weight:700'>{html.escape(txt)}</span>"
                if pct >= 35.0:
                    return f"<span style='color:#ca8a04;font-weight:700'>{html.escape(txt)}</span>"
                return f"<span style='color:#dc2626;font-weight:700'>{html.escape(txt)}</span>"
            except Exception:
                pass
        if txt.startswith("🟨 "):
            return f"<span style='color:#b45309;font-weight:700'>{html.escape(txt)}</span>"
        if txt.startswith("🟢 "):
            return f"<span style='color:#166534;font-weight:700'>{html.escape(txt)}</span>"
        if txt.startswith("🟡 "):
            return f"<span style='color:#92400e;font-weight:700'>{html.escape(txt)}</span>"
        if txt.startswith("🔴 "):
            return f"<span style='color:#991b1b;font-weight:700'>{html.escape(txt)}</span>"
        return html.escape(txt)

    def _stockhelper_chart_button(cmd: str, label: str = "", section: str = "") -> str:
        attrs = ""
        if label:
            attrs += f" data-group-label='{html.escape(str(label), quote=True)}'"
        if section:
            attrs += f" data-group-section='{html.escape(str(section), quote=True)}'"
        return (
            f"<button class='btn stockhelper-chart-btn' onclick='openStockhelperChart(this)' data-cmd='{cmd}'{attrs} "
            "title='Open stockhelper chart' aria-label='Open stockhelper chart'>📊</button>"
        )

    def _google_sheets_hyperlink_formula(stooq_url: str, ticker: str) -> str:
        safe_url = str(stooq_url or "").replace('"', '""')
        safe_ticker = str(ticker or "").replace('"', '""')
        return f'=HYPERLINK("{safe_url}"; "{safe_ticker}")'

    def _sheets_cell_button(stooq_url: str | None, ticker: str | None) -> str:
        if not stooq_url or not ticker:
            return ""
        formula = _google_sheets_hyperlink_formula(str(stooq_url), str(ticker).strip().upper())
        return (
            "<button class='btn sheets-cell-btn' type='button' onclick='copySheetsCell(this)' "
            f"data-formula='{html.escape(formula, quote=True)}' "
            "title='Copy Google Sheets HYPERLINK formula' aria-label='Copy Google Sheets HYPERLINK formula'>📋</button>"
        )

    def _stooq_link_with_cell_button(stooq_url: str | None, ticker: str | None, extra_class: str = "") -> str:
        if not stooq_url:
            return ""
        class_attr = f"btn {extra_class}".strip()
        link = f"<a class='{html.escape(class_attr, quote=True)}' href='{html.escape(str(stooq_url), quote=True)}' target='_blank' title='Open stooq chart'>📈</a>"
        return link + _sheets_cell_button(str(stooq_url), ticker)

    troj_timestamp = datetime.now()
    troj_fibo_path = _write_trojpolowki_fibo(rows, TROJPOLLOWKI_DIR, troj_timestamp)
    troj_ichi_path = _write_trojpolowki_ichimoku(rows, TROJPOLLOWKI_DIR, troj_timestamp)
    troj_row_by_ticker = {r.ticker: r for r in rows if r.ticker}
    troj_ichi_row_by_ticker = {r.ticker: r for r in rows if r.ticker and r.scanner == "ICHIMOKU"}
    troj_fibo_row_by_ticker = {r.ticker: r for r in rows if r.ticker and r.scanner == "FIBO"}

    def _md_inline_to_html(text: str) -> str:
        rendered = html.escape(str(text or ""))
        rendered = re.sub(r"\*\*(.*?)\*\*", r"<strong>\1</strong>", rendered)
        rendered = re.sub(
            r"\[([^\]]+)\]\(([^)]+)\)",
            lambda m: f"<a class='btn' href='{html.escape(m.group(2), quote=True)}' target='_blank'>{html.escape(m.group(1))}</a>",
            rendered,
        )
        return rendered.replace("&lt;br&gt;", "<br>")

    def _split_md_row(line: str) -> list[str]:
        return [cell.strip().replace("\\|", "|") for cell in line.strip().strip("|").split("|")]

    def _direction_icon(text: str) -> str:
        low = str(text or "").lower()
        if any(token in low for token in ("below", "bear", "down", "short")):
            return "🔻"
        if any(token in low for token in ("above", "bull", "up", "long")):
            return "🔺"
        return "⚪"

    def _troj_group_button_label(row: ScannerRow | None, ticker: str, section_id: str) -> str:
        if row is None:
            return ticker
        icon = _market_icon(row.market, row.ticker)
        if "fibo" in section_id:
            incline = str(row.dates.get("incline", "") or "")
            start = incline.split("->", 1)[0].strip() if "->" in incline else (row.dates.get("start_date", "") or "")
            return " ".join(part for part in [icon, row.ticker, start] if part)
        if "ichimoku" in section_id:
            months = str(row.metrics.get("months", "") or "").strip()
            months_label = f"{months}m" if months else ""
            return " ".join(part for part in [icon, row.ticker, _direction_icon(row.direction or row.status), months_label] if part)
        return " ".join(part for part in [icon, row.ticker] if part)

    def _troj_cell_to_html(cell: str, section_id: str = "") -> str:
        raw = str(cell or "")
        stooq_match = re.search(r"\[🔗 stooq\]\(([^)]+)\)", raw)
        stooq_url = stooq_match.group(1) if stooq_match else ""
        without_stooq = re.sub(r"\s*·?\s*\[🔗 stooq\]\([^)]+\)", "", raw).strip()
        rendered = _md_inline_to_html(without_stooq)
        ticker_match = re.search(r"\*\*[^A-Za-z0-9]*(?:[^\s]+\s+)?([A-Z0-9][A-Z0-9._]{0,24})(?=\s)", raw)
        if not ticker_match:
            return rendered
        ticker = ticker_match.group(1)
        if "ichimoku" in section_id:
            row = troj_ichi_row_by_ticker.get(ticker) or troj_row_by_ticker.get(ticker)
        elif "fibo" in section_id:
            row = troj_fibo_row_by_ticker.get(ticker) or troj_row_by_ticker.get(ticker)
        else:
            row = troj_row_by_ticker.get(ticker)
        cmd = html.escape(_chart_command_for_row(row)) if row else html.escape(f"python run -c {ticker}")
        stooq = stooq_url or (row.chart_url if row and row.chart_url else _stooq_chart_url(ticker))
        stooq_btn = _stooq_link_with_cell_button(stooq, ticker, "troj-name-btn")
        group_label = _troj_group_button_label(row, ticker, section_id)
        chart_btn = _stockhelper_chart_button(cmd, group_label) if cmd else ""
        controls = f" <span class='troj-name-actions'>{stooq_btn}{chart_btn}</span>"
        if "</strong>" in rendered:
            rendered = rendered.replace("</strong>", controls + "</strong>", 1)
        else:
            rendered = controls + rendered
        if "ichimoku" in section_id and "<br>" in rendered:
            first, rest = rendered.split("<br>", 1)
            return first + "<span class='troj-extra-info'><br>" + rest + "</span>"
        return rendered

    def _read_troj_md_table(md_path: Path, fallback_title: str) -> dict[str, object]:
        parsed: dict[str, object] = {"title": fallback_title, "updated": "", "legend": [], "headers": [], "rows": []}
        if not md_path.exists():
            return parsed
        md_lines = md_path.read_text(encoding="utf-8").splitlines()
        table_idx: int | None = None
        for idx, line in enumerate(md_lines):
            stripped = line.strip()
            if stripped.startswith("# "):
                parsed["title"] = stripped.lstrip("# ").strip()
            elif stripped.startswith("Updated from allsearch:"):
                parsed["updated"] = stripped
            elif stripped.startswith("- "):
                parsed["legend"].append(stripped[2:])
            elif stripped.startswith("|") and idx + 1 < len(md_lines) and md_lines[idx + 1].strip().startswith("|"):
                table_idx = idx
                break
        if table_idx is None:
            return parsed
        headers = _split_md_row(md_lines[table_idx])
        rows_out: list[list[str]] = []
        idx = table_idx + 2
        while idx < len(md_lines) and md_lines[idx].strip().startswith("|"):
            cells = _split_md_row(md_lines[idx])
            if len(cells) == len(headers) and any(cells):
                rows_out.append(cells)
            idx += 1
        parsed["headers"] = headers
        parsed["rows"] = rows_out
        return parsed

    def _date_from_text(value: str) -> date | None:
        match = re.search(r"\d{4}-\d{2}-\d{2}", str(value or ""))
        if not match:
            return None
        try:
            return datetime.strptime(match.group(0), "%Y-%m-%d").date()
        except Exception:
            return None

    def _is_recent_choice_date(value: str | None, reference: str | None = None, max_days: int = 3) -> bool:
        d = _date_from_text(value or "")
        if d is None:
            return False
        ref = _date_from_text(reference or "") or datetime.now().date()
        return 0 <= (ref - d).days <= max_days

    def _top_choice_rank(cell: str, source: str = "") -> tuple[int, int, float, str]:
        text = f"{source} {cell}"
        low = text.lower()
        pct_values = [float(v) for v in re.findall(r"(\d+(?:\.\d+)?)%", low)]
        pct_value = max(pct_values) if pct_values else None
        if "pattern" in low and not re.search(r"pattern\s*[:=]?\s*-", low):
            return (0, 0, 0.0, text)
        if "61.8" in low and any(token in low for token in ("reached", "touched", "valid")):
            return (1, 0, 0.0, text)
        if pct_value is not None and pct_value >= 75.0:
            return (2, 0, -pct_value, text)
        d = _date_from_text(text)
        today = datetime.now().date()
        if d is not None:
            days = (today - d).days
            return (3 if 0 <= days <= 3 else 4, -d.toordinal(), 999.0, text)
        months_match = re.search(r"\((\d+(?:\.\d+)?)m\)", text)
        months = float(months_match.group(1)) if months_match else 999.0
        return (5, 0, months, text)

    def _fibo_top_choice_reason(cell: str, source: str = "") -> str | None:
        text = f"{source} {cell}".lower()
        pct_match = re.search(r"(\d+(?:\.\d+)?)%", cell)
        pattern_match = re.search(r"pattern\s*[:=]?\s*([^·<|]+)", cell, re.IGNORECASE)
        if pattern_match and pattern_match.group(1).strip().lower() not in {"", "-", "none"}:
            return f"Fibo pattern: {pattern_match.group(1).strip()}"
        if "61.8" in text and any(token in text for token in ("reached", "touched", "valid")):
            return "61.8 reached"
        if pct_match and float(pct_match.group(1)) >= 75.0:
            return f"near 61.8: {float(pct_match.group(1)):.1f}%"
        return None

    def _ichimoku_top_choice_reason(cell: str, source: str = "") -> str | None:
        text = str(cell or "").lower()
        d = _date_from_text(cell)
        date_suffix = f" ({d.isoformat()})" if d is not None else ""
        if "breakout" in text:
            if d is None or _is_recent_choice_date(cell):
                return f"breakout / recent breakout{date_suffix}"
            return None
        if "retest" in text or "pattern" in text:
            if d is not None and not _is_recent_choice_date(cell) and "inside cloud" not in text and "touched cloud" not in text:
                return None
            pattern_match = re.search(r"(?:🏷️|pattern[:=]?|retest pattern[:=]?)\s*([^·<|]+)", cell, re.IGNORECASE)
            pattern = pattern_match.group(1).strip() if pattern_match else "retest pattern"
            pattern = re.sub(r"\s*\(\d{4}-\d{2}-\d{2}\)\s*$", "", pattern)
            return f"pattern/retest: {pattern}{date_suffix}"
        if "inside cloud" in text or "inside the cloud" in text:
            return "candle deep/inside cloud"
        return None

    def _top_choice_reason(cell: str, source: str = "") -> str | None:
        text = f"{source} {cell}"
        fibo_reason = _fibo_top_choice_reason(cell, source)
        if fibo_reason:
            return fibo_reason
        ichi_reason = _ichimoku_top_choice_reason(cell, source)
        if ichi_reason:
            return ichi_reason
        d = _date_from_text(text)
        today = datetime.now().date()
        if d is not None:
            days = (today - d).days
            if 0 <= days <= 3:
                return f"pattern/breakout in last 3 days ({d.isoformat()})"
        return None

    def _row_signal_dates(row: ScannerRow) -> list[date]:
        dates_out: list[date] = []
        def add(value: str | None) -> None:
            d = _date_from_text(value or "")
            if d is not None:
                dates_out.append(d)
        if row.scanner == "WEDGE":
            add(row.metrics.get("breakout_date"))
        elif row.scanner == "ICHIMOKU":
            status_text = " ".join(str(v) for v in [row.status, row.metrics.get("raw_status", ""), row.metrics.get("ichimoku_status", "")]).lower()
            pattern = str(row.metrics.get("latest_retest_pattern", "")).strip().lower()
            if pattern not in {"", "-", "none"}:
                add(row.metrics.get("latest_retest_date"))
            if "breakout" in status_text or "returned_to_cloud" in status_text or "returned to cloud" in status_text:
                add(row.dates.get("flip_date") or row.metrics.get("latest_date"))
        elif row.scanner == "FIBO":
            pattern = str(row.pattern or "").strip().lower()
            if pattern not in {"", "-", "none"}:
                add(row.dates.get("touch_61") or row.metrics.get("latest_date"))
            if row.dates.get("touch_61") and row.dates.get("touch_61") != "-":
                add(row.dates.get("touch_61"))
        return dates_out

    def _row_has_search_day_signal(row: ScannerRow) -> bool:
        signals = _row_signal_dates(row)
        if not signals:
            return False
        refs = [_date_from_text(row.metrics.get("latest_date", "")), _date_from_text(row.metrics.get("expected_date", "")), datetime.now().date()]
        ref_set = {d for d in refs if d is not None}
        return any(d in ref_set for d in signals)

    def _row_attrs(row: ScannerRow) -> str:
        cls = " class='today-signal'" if _row_has_search_day_signal(row) else ""
        return f" data-market='{html.escape(row.market)}' data-scanner='{html.escape(row.scanner)}' data-status='{html.escape(row.status)}'{cls}"

    def _top_choice_table_html(title: str, items: list[tuple[str, str, str]], section_id: str = "", limit: int | None = None) -> str:
        picked = sorted(items, key=lambda item: _top_choice_rank(item[1], item[0]))
        picked = picked if limit is None else picked[:limit]
        if not picked:
            return ""
        html_rows = "".join(f"<tr title='{html.escape(reason, quote=True)}'><td{_troj_cell_attrs(cell, section_id)}>{_troj_cell_to_html(cell, section_id)}</td></tr>" for _source, cell, reason in picked if str(cell).strip())
        if not html_rows:
            return ""
        open_btn = ' <button class=\'iconbtn\' title=\'Open stooq links from top choices\' onclick="_openLinks(_tableLinks(this.closest(\'.top-choice\').querySelector(\'table\')))">🔗</button> <button class=\'iconbtn\' title=\'Open stockhelper charts from top choices\' onclick="openClosestStockhelperCharts(this)">📊</button>'
        return f"<div class='top-choice'><h3>{html.escape(title)}{open_btn}</h3><table class='troj-table top-choice-compact'><thead><tr><th>Instrument <button class='iconbtn' title='Open stockhelper charts from this top-choice column' onclick=\"event.stopPropagation();openTrojColumnStockhelperCharts(this,0)\">📊</button></th></tr></thead><tbody>{html_rows}</tbody></table></div>"

    def _troj_top_choices(parsed: dict[str, object], preferred_cols: list[int], limit: int | None = None) -> list[tuple[str, str, str]]:
        headers = parsed.get("headers", [])
        rows_in = parsed.get("rows", [])
        items: list[tuple[str, str, str]] = []
        if not isinstance(headers, list) or not isinstance(rows_in, list):
            return items
        for col_idx in preferred_cols:
            if col_idx >= len(headers):
                continue
            source = str(headers[col_idx])
            for row in rows_in:
                if isinstance(row, list) and col_idx < len(row) and str(row[col_idx]).strip():
                    cell = str(row[col_idx])
                    reason = _top_choice_reason(cell, source)
                    if not reason:
                        continue
                    items.append((source, cell, reason))
                    if limit is not None and len(items) >= limit:
                        return items
        return items

    def _troj_row_for_cell(cell: str, section_id: str = "") -> ScannerRow | None:
        raw = str(cell or "")
        ticker_match = re.search(r"\*\*[^A-Za-z0-9]*(?:[^\s]+\s+)?([A-Z0-9][A-Z0-9._]{0,24})(?=\s)", raw)
        if not ticker_match:
            return None
        ticker = ticker_match.group(1)
        if "ichimoku" in section_id:
            return troj_ichi_row_by_ticker.get(ticker) or troj_row_by_ticker.get(ticker)
        if "fibo" in section_id:
            return troj_fibo_row_by_ticker.get(ticker) or troj_row_by_ticker.get(ticker)
        return troj_row_by_ticker.get(ticker)

    def _troj_cell_attrs(cell: str, section_id: str = "") -> str:
        row = _troj_row_for_cell(cell, section_id)
        return f" data-market='{html.escape(row.market)}' data-scanner='{html.escape(row.scanner)}'" if row else ""

    def _trojpolowki_html_section(parsed: dict[str, object], section_id: str, top_choice_cols: list[int] | None = None) -> str:
        headers = parsed.get("headers", [])
        body_rows = parsed.get("rows", [])
        if not headers or not body_rows:
            return ""
        legend = parsed.get("legend", [])
        legend_html = ""
        if isinstance(legend, list) and legend:
            legend_items = "".join(f"<li>{_md_inline_to_html(str(item))}</li>" for item in legend)
            if "ichimoku" in section_id:
                legend_html = f"<details class='legend troj-legend'><summary><b>Legenda</b> (kliknij, aby rozwinąć)</summary><ul>{legend_items}</ul></details>"
            else:
                legend_html = f"<div class='legend troj-legend'><ul>{legend_items}</ul></div>"
        toolbar_buttons = []
        if "ichimoku" in section_id:
            toolbar_buttons.append(f'<button class=\'btn compactbtn\' type=\'button\' onclick="toggleTrojExtra(\'{html.escape(section_id, quote=True)}\', this)">Hide additional info</button>')
        toolbar_buttons.append("<button class='btn compactbtn' type='button' title='Open all stockhelper charts from this table' onclick='openClosestStockhelperCharts(this)'>📊</button>")
        table_controls = f"<div class='troj-toolbar'>{' '.join(toolbar_buttons)}</div>"
        table_html = table_controls + "<div style='overflow:auto'><table class='troj-table'><thead><tr>"
        # Every Trójpolówki column can contain grouped instrument cells, so expose
        # the bulk open/copy controls on every header instead of only top-choice
        # columns. Empty columns are harmless: the JS helpers simply no-op.
        for idx, h in enumerate(headers):
            open_btn = (
                f" <button class='iconbtn' title='Open stockhelper charts from this column' onclick=\"event.stopPropagation();openTrojColumnStockhelperCharts(this,{idx})\">📊</button>"
                f" <button class='iconbtn' title='Open stooq links from this column' onclick=\"event.stopPropagation();openTrojColumnStooqLinks(this,{idx})\">🔗</button>"
                f" <button class='iconbtn' title='Copy Google Sheets cells from this column' onclick=\"event.stopPropagation();copyTrojColumnSheetsCells(this,{idx})\">📋</button>"
            )
            table_html += f"<th>{_md_inline_to_html(str(h))}{open_btn}</th>"
        table_html += "</tr></thead><tbody>"
        for row in body_rows:
            table_html += "<tr>" + "".join(f"<td{_troj_cell_attrs(str(cell), section_id)}>{_troj_cell_to_html(str(cell), section_id)}</td>" for cell in row) + "</tr>"
        table_html += "</tbody></table></div>"
        top_html = _top_choice_table_html("Top choices", _troj_top_choices(parsed, top_choice_cols or []), section_id) if top_choice_cols else ""
        return (
            f"<section class='market troj-section' id='{section_id}'>"
            f"<h2>{html.escape(str(parsed.get('title') or 'Trójpolówki'))}</h2>"
            f"<p class='muted'>{html.escape(str(parsed.get('updated') or ''))}</p>"
            f"{legend_html}{table_html}{top_html}</section>"
        )

    troj_fibo_parsed = _read_troj_md_table(troj_fibo_path, "Trójpolówki — Fibo")
    troj_ichi_parsed = _read_troj_md_table(troj_ichi_path, "Trójpolówki — Ichimoku")

    def _row_top_choice_info(row: ScannerRow) -> tuple[tuple[int, int, float, str], str] | None:
        status_text = " ".join(str(v) for v in [row.status, row.pattern, row.metrics.get("latest_retest_pattern", ""), row.metrics.get("latest_retest_date", ""), row.metrics.get("ichimoku_status", ""), row.dates.get("touch_61", ""), row.dates.get("flip_date", ""), row.dates.get("start_date", ""), row.metrics.get("near61", ""), row.metrics.get("latest_date", ""), row.ticker])
        if row.scanner == "WEDGE":
            score = _parse_float_text(row.metrics.get("score", "0"), 0.0)
            width = _parse_float_text(row.metrics.get("start_width", "0"), 0.0)
            months = _parse_float_text(row.metrics.get("months", "0"), 0.0)
            slope_label = _wedge_slope_strength(row.metrics.get("slope", ""))
            contacts = f"{row.metrics.get('upper_touches','?')}/{row.metrics.get('lower_touches','?')}"
            breakout_date = (row.metrics.get("breakout_date", "-") or "-").strip()
            breakout_direction = (row.metrics.get("breakout_direction", "-") or "-").strip()
            breakout_rank = 1 if breakout_direction in {"long", "short"} and breakout_date not in {"", "-"} else 0
            return ((0, -breakout_rank, -(score + width * 4.0 + months * 8.0), row.ticker), f"klin opadający: {months:.1f}m, kontakty U/D {contacts}, nachylenie {slope_label}, score {score:.0f}")
        if row.scanner == "FIBO":
            if row.category == "valid":
                return None
            pattern = str(row.pattern or "").strip()
            if pattern and pattern.lower() not in {"-", "none"}:
                return ((0, 0, 0.0, row.ticker), f"Fibo pattern: {pattern}")
            if row.dates.get("touch_61") and row.dates.get("touch_61") != "-":
                touch_date = row.dates.get("touch_61", "")
                return (_top_choice_rank(f"61.8 reached {touch_date}", row.category), f"61.8 reached ({touch_date})")
            near = _parse_float_text(str(row.metrics.get("near61") or row.metrics.get("near61_raw") or ""), -1.0)
            if near >= 75.0:
                label = "61.8 crossed" if near > 100.0 else "near 61.8"
                return (_top_choice_rank(f"{near}% {status_text}", row.category), f"{label}: {near:.1f}%")
            return None
        text_low = status_text.lower()
        recent_date = _date_from_text(status_text)
        latest_date = row.metrics.get("latest_date") or row.metrics.get("expected_date") or ""
        if "unsuccessful breakout" in text_low:
            return None
        if "breakout" in text_low:
            d = _date_from_text(row.dates.get("flip_date", "") or status_text)
            if d is not None and not _is_recent_choice_date(d.isoformat(), latest_date):
                return None
            suffix = f" ({d.isoformat()})" if d else ""
            return (_top_choice_rank(status_text, row.category), f"breakout / recent breakout{suffix}")
        if "pattern" in text_low and not re.search(r"pattern\s*[:=]?\s*-", text_low):
            pattern = row.metrics.get("latest_retest_pattern") or row.status or "retest pattern"
            d = _date_from_text(row.metrics.get("latest_retest_date", ""))
            cloud_context = any(token in text_low for token in ("inside cloud", "inside the cloud", "touched cloud", "touched the cloud", "unsuccessful breakout"))
            if d is not None and not _is_recent_choice_date(d.isoformat(), latest_date) and not cloud_context:
                return None
            suffix = f" ({d.isoformat()})" if d else ""
            return (_top_choice_rank(status_text, row.category), f"pattern/retest: {pattern}{suffix}")
        if "returned_to_cloud_waiting_for_pattern" in text_low or "returned to cloud" in text_low:
            d = _date_from_text(row.dates.get("flip_date", "") or row.metrics.get("latest_date", ""))
            suffix = f" ({d.isoformat()})" if d else ""
            return (_top_choice_rank(f"returned to cloud {status_text}", row.category), f"returned to cloud, waiting{suffix}")
        if "inside cloud" in text_low or "inside the cloud" in text_low:
            return (_top_choice_rank(status_text, row.category), "candle deep/inside cloud")
        if recent_date is not None and _is_recent_choice_date(recent_date.isoformat(), latest_date) and row.category == "retest_breakout":
            return (_top_choice_rank(status_text, row.category), f"recent retest/breakout date ({recent_date.isoformat()})")
        return None


    def _journal_tab_html() -> str:
        button = (
            '<button class="btn troj-cta" type="button" '
            'onclick="window.open(\'/journal-html\',\'_blank\')">'
            'Open transaction journal</button>'
        )
        return (
            "<section class='market'><h2>🧾 Open journal</h2>"
            "<p class='muted'>Open the live transaction journal in its own served window.</p>"
            + button +
            f"<p class='muted'><code>{html.escape(cmd)}</code></p></section>"
        )

    def _wedge_tab_html() -> str:
        def _wedge_breakout_rank(r: ScannerRow) -> int:
            direction = (r.metrics.get("breakout_direction", "-") or "-").strip()
            bdate = (r.metrics.get("breakout_date", "-") or "-").strip()
            return 1 if direction in {"long", "short"} and bdate not in {"", "-"} else 0

        def _wedge_status_label(r: ScannerRow) -> str:
            status = (r.status or "").lower()
            direction = (r.metrics.get("breakout_direction", "-") or "-").strip()
            if "breakout" in status or direction in {"long", "short"}:
                return "🚀 breakout"
            return "⏳ unbroken"

        wedge = sorted([r for r in rows if r.scanner == "WEDGE"], key=lambda r: (_market_order(r.market, r.ticker), -_wedge_breakout_rank(r), -_parse_float_text(r.metrics.get("score", "0"), 0.0)))
        if not wedge:
            return "<section class='market'><h2>🔻 Kliny opadające</h2><p class='muted'>Brak niewybitych klinów opadających.</p></section>"
        parts = ["<section class='market'><h2>🔻 Kliny opadające</h2><p class='muted'>Osobna lista klinów: w marketach najwyżej są świeże wybicia, a dalej formacje z dobrymi stykami linii, rozmiarem i nachyleniem.</p>"]
        top = sorted(wedge, key=lambda r: (-_wedge_breakout_rank(r), -_parse_float_text(r.metrics.get("score", "0"), 0.0)))[:5]
        top_rows = "".join(
            f"<tr{_row_attrs(r)}><td><strong>{html.escape(_market_icon(r.market, r.ticker))} {html.escape(r.ticker)}</strong></td><td>{html.escape(r.market)}</td><td>{html.escape(_wedge_status_label(r))}</td><td>{html.escape(r.metrics.get('months',''))}</td><td>{html.escape(r.metrics.get('upper_touches','?') + '/' + r.metrics.get('lower_touches','?'))}</td><td>{html.escape(_wedge_slope_strength(r.metrics.get('slope','')))}</td><td>{html.escape(r.metrics.get('breakout_date','-'))}</td><td>{html.escape(r.metrics.get('breakout_direction','-'))}</td><td>{html.escape(r.metrics.get('start_width',''))}</td><td>{html.escape(r.metrics.get('end_width',''))}</td><td>{html.escape(r.metrics.get('score',''))}</td><td>{html.escape(_format_avg10d_value(r.metrics.get('avg10d','')))}</td><td>{_stooq_link_with_cell_button(r.chart_url, r.ticker)}</td><td>{_stockhelper_chart_button(html.escape(_chart_command_for_row(r)), f"{_market_icon(r.market, r.ticker)} {r.ticker} {_wedge_status_label(r).split()[0]} {r.metrics.get('months','')}m")}</td></tr>"
            for r in top
        )
        parts.append(f"<div class='top-choice'><h3>Top choices <button class='iconbtn' title='Open stooq links from top choices' onclick='_openLinks(_tableLinks(this.closest(&quot;.top-choice&quot;).querySelector(&quot;table&quot;)))'>🔗</button> <button class='iconbtn' title='Copy Google Sheets links from top choices' onclick='copyClosestSheetsCells(this)'>📋</button> <button class='iconbtn' title='Open stockhelper charts from top choices' onclick='openClosestStockhelperCharts(this)'>📊</button></h3><table class='data'><thead><tr><th>Instrument</th><th>Market</th><th>Status</th><th>Months</th><th>Touches U/L</th><th>Slope</th><th>Breakout</th><th>Dir</th><th>Start width</th><th>End width</th><th>Score</th><th>Avg10d PLN</th><th>Stooq</th><th>Chart</th></tr></thead><tbody>{top_rows}</tbody></table></div>")
        for market in by_market:
            group = [r for r in wedge if r.market == market]
            if not group:
                continue
            parts.append(f"<div class='wedge-market-group' data-market-block='{html.escape(market)}'><h3>{html.escape(_scope_label(market.lower()))} ({len(group)}) <button class='iconbtn' title='Open stooq links from this table' onclick='openNextTableStooqLinks(this)'>🔗</button> <button class='iconbtn' title='Copy Google Sheets links from this table' onclick='copyNextTableSheetsCells(this)'>📋</button> <button class='iconbtn' title='Open stockhelper charts from this table' onclick='openNextTableStockhelperCharts(this)'>📊</button></h3><div style='overflow:auto'><table class='data'><thead><tr><th>Ticker</th><th>Status</th><th>Wedge</th><th>Months</th><th>Touches U/L</th><th>Start width</th><th>End width</th><th>Slope</th><th>Breakout</th><th>Dir</th><th>Score</th><th>Avg10d PLN</th><th>Open stooq chart</th><th>stockhelper_chart</th></tr></thead><tbody>")
            for r in group:
                touches = f"{r.metrics.get('upper_touches','')}/{r.metrics.get('lower_touches','')}"
                parts.append(f"<tr{_row_attrs(r)}><td><b>{html.escape(r.ticker)}</b></td><td>{html.escape(_wedge_status_label(r))}</td><td>{html.escape(r.dates.get('wedge',''))}</td><td>{html.escape(r.metrics.get('months',''))}</td><td>{html.escape(touches)}</td><td>{html.escape(r.metrics.get('start_width',''))}</td><td>{html.escape(r.metrics.get('end_width',''))}</td><td>{html.escape(_wedge_slope_strength(r.metrics.get('slope','')))}</td><td>{html.escape(r.metrics.get('breakout_date','-'))}</td><td>{html.escape(r.metrics.get('breakout_direction','-'))}</td><td>{html.escape(r.metrics.get('score',''))}</td><td>{html.escape(_format_avg10d_value(r.metrics.get('avg10d','')))}</td><td class='chart-link-cell'>{_stooq_link_with_cell_button(r.chart_url, r.ticker)}</td><td class='chart-action-cell'>{_stockhelper_chart_button(html.escape(_chart_command_for_row(r)), f"{_market_icon(r.market, r.ticker)} {r.ticker} {_wedge_status_label(r).split()[0]} {r.metrics.get('months','')}m")}</td></tr>")
            parts.append("</tbody></table></div></div>")
        parts.append("</section>")
        return "".join(parts)

    def _allsearch_top_choices(limit_per_group: int = 2) -> str:
        groups = [
            ("☁️ Ichimoku retest", [r for r in rows if r.scanner == "ICHIMOKU" and r.category == "retest_breakout"]),
            ("☁️ Ichimoku continuation", [r for r in rows if r.scanner == "ICHIMOKU" and r.category == "position"]),
            ("📐 Fibo", [r for r in rows if r.scanner == "FIBO" and r.category in {"waiting", "valid", "steep"}]),
            ("🔻 Kliny", [r for r in rows if r.scanner == "WEDGE"]),
        ]

        def _must_include_top_choice(rank: tuple[int, int, float, str], reason: str) -> bool:
            low = reason.lower()
            return rank[0] == 0 or "recent breakout" in low or "last 3 days" in low or "recent retest" in low or "returned to cloud" in low

        group_sections: list[str] = []
        seen_top_choice_tickers: set[tuple[str, str]] = set()
        for label, group_rows in groups:
            qualified: list[tuple[tuple[int, int, float, str], ScannerRow, str]] = []
            for r in group_rows:
                info = _row_top_choice_info(r)
                if info is not None:
                    rank, reason = info
                    qualified.append((rank, r, reason))
            ranked = sorted(qualified, key=lambda item: item[0])
            must = [item for item in ranked if _must_include_top_choice(item[0], item[2])]
            selected = must + [item for item in ranked if item not in must][:max(0, limit_per_group - len(must))]
            if label == "🔻 Kliny":
                selected = selected[:5]
            rows_html = ""
            for _rank, r, reason in selected:
                ticker_key = (label, (r.ticker or "").upper())
                if ticker_key in seen_top_choice_tickers:
                    continue
                seen_top_choice_tickers.add(ticker_key)
                cmd = html.escape(_chart_command_for_row(r))
                stooq = r.chart_url or _stooq_chart_url(r.ticker)
                stooq_btn = _stooq_link_with_cell_button(stooq, r.ticker)
                rows_html += f"<tr{_row_attrs(r)}><td><strong>{html.escape(_market_icon(r.market, r.ticker))} {html.escape(r.ticker)}</strong></td><td>{html.escape(reason)}</td><td>{stooq_btn}</td><td>{_stockhelper_chart_button(cmd, f'{_market_icon(r.market, r.ticker)} {r.ticker} {reason}', label)}</td></tr>"
            if rows_html:
                group_sections.append(
                    f"<div class='top-choice-group'><h3>{html.escape(label)} <button class='iconbtn' title='Open stooq links from this top group' onclick='_openLinks(_tableLinks(this.closest(&quot;.top-choice-group&quot;).querySelector(&quot;table&quot;)))'>🔗</button> <button class='iconbtn' title='Open stockhelper charts from this top group' onclick='openClosestStockhelperCharts(this)'>📊</button></h3>"
                    f"<table class='data top-choice-compact'><thead><tr><th>Instrument</th><th>Why top choice</th><th>Stooq</th><th>Chart</th></tr></thead><tbody>{rows_html}</tbody></table></div>"
                )
        if not group_sections:
            return ""
        open_btn = ' <button class=\'iconbtn\' title=\'Open stooq links from all top choices\' onclick="_openLinks(_tableLinks(this.closest(\'.top-choice\')))" >🔗</button> <button class=\'iconbtn\' title=\'Open stockhelper charts from all top choices\' onclick="openClosestStockhelperCharts(this)">📊</button>'
        return f"<section class='market top-choice'><h2>Top choices{open_btn}</h2>{''.join(group_sections)}</section>"


    html_parts = ["<html><head><meta charset='utf-8'><title>StockHelper Scanner Report</title>",
                  "<style>body{font-family:Inter,Arial;margin:0 auto;max-width:1400px;padding:16px;background:#f6f8fb}.cards{display:flex;gap:12px;flex-wrap:wrap}.card{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:10px 14px}.market{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:12px;margin-top:16px}table{width:100%;border-collapse:collapse;font-size:13px;border:1px solid #cbd5e1}th{position:sticky;top:0;background:#f1f5f9}th,td{border:1px solid #e5e7eb;padding:6px;text-align:left;vertical-align:top}tr:nth-child(even){background:#fafafa}.num{text-align:right}.badge{padding:2px 8px;border-radius:8px;font-size:11px}.high{background:#dcfce7}.medium{background:#fef9c3}.low{background:#e2e8f0}.btn{padding:4px 8px;border:1px solid #cbd5e1;border-radius:6px;text-decoration:none;display:inline-block;background:#fff;color:#0f172a}.muted{color:#64748b}.subhead{margin:12px 0 6px;font-size:14px;color:#334155;background:#eef2ff;padding:6px 8px;border-left:3px solid #6366f1;border-radius:6px}.legend{background:#fff;border:none;border-radius:8px;padding:10px 12px}.iconbtn{margin-left:8px;border:none;background:transparent;cursor:pointer;font-size:16px;vertical-align:middle}.chart-action-cell,.chart-link-cell,.latest-data-cell{text-align:center;white-space:nowrap}.today-signal td{background:#dcfce7!important}.today-signal td:first-child{box-shadow:inset 4px 0 #16a34a}.troj-hero{background:linear-gradient(90deg,#ff5f6d 0%,#ffc371 16%,#fff176 32%,#64dd17 48%,#40c4ff 64%,#7c4dff 80%,#ff5fd2 100%);color:#111827;border-radius:14px;padding:16px;margin:14px 0;box-shadow:0 8px 24px rgba(15,23,42,.18)}.troj-hero h2{margin:0 0 8px}.troj-nav{display:flex;gap:12px;flex-wrap:wrap}.troj-cta{font-size:16px;font-weight:800;padding:10px 14px;border-color:rgba(255,255,255,.6);background:#fff;color:#1e1b4b}.troj-section{border:2px solid #6366f1;box-shadow:0 8px 20px rgba(99,102,241,.12)}.troj-section h2{margin-top:0}.troj-table th{background:#dbeafe;color:#1e3a8a}.troj-table td{min-width:230px;line-height:1.45}.troj-legend{margin:8px 0 12px}.troj-legend ul{margin:8px 0 0;padding-left:20px}.troj-legend summary{cursor:pointer}.tabbar{display:flex;gap:10px;flex-wrap:wrap;margin:14px 0}.tabbtn{font-size:16px;font-weight:800;padding:10px 14px}.tabbtn.active{background:#1d4ed8;color:#fff;border-color:#1d4ed8}.tab-panel{display:none}.tab-panel.active{display:block}.troj-name-actions{display:inline-flex;gap:5px;margin-left:8px;vertical-align:middle}.troj-name-actions .btn{font-size:11px;padding:2px 6px}.top-choice{border-color:#f59e0b;background:#fffbeb}.top-choice h2,.top-choice h3{color:#92400e}.pdfbtn{font-size:12px;font-weight:700;padding:4px 7px;align-self:center}.compactbtn{font-size:12px;padding:3px 7px}.troj-toolbar{margin:8px 0 10px}.troj-hide-extra .troj-extra-info{display:none}@media print{@page{size:A4 landscape;margin:6mm}body{max-width:none;padding:0;zoom:.78;background:#fff}.troj-hero,.market{box-shadow:none}.btn,.iconbtn{display:none!important}table{font-size:9px}th,td{padding:3px}.troj-table td{min-width:120px;line-height:1.25}.tab-panel:not(.active){display:none!important}}</style>",
                  "</head><body>"]
    html_parts.append(f"<h1>StockHelper Scanner Report</h1><p>Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S %Z')}</p>")
    market_buttons_html = "".join([f"<button class='btn market-filter-btn' type='button' data-market='{html.escape(m)}'>{html.escape(_scope_label(m.lower()))}</button>" for m in by_market])
    search_toolbar_html = (
        "<div class='report-search-toolbar' style='display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin:10px 0 14px'>"
        "<label for='q'><b>Search</b></label><span class='searchbox' style='display:inline-flex;align-items:center;position:relative'><input id='q' style='padding-right:24px' placeholder='Search ticker/status/top choices on any tab'><button id='clear-q' type='button' title='Clear search' aria-label='Clear search' style='position:absolute;right:4px;border:0;background:transparent;cursor:pointer;color:#64748b;font-size:16px;line-height:1'>×</button></span>"
