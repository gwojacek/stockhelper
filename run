#!/usr/bin/env python3
import argparse
import subprocess
import sys
from pathlib import Path

from chart_program.instrument_detector import detect_instrument_type

PROJECT_ROOT = Path(__file__).resolve().parent


def _resolve_runner(instrument_type: str) -> str:
    return "main_stock.py" if instrument_type == "stock" else "main.py"


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="run",
        description="Ultra-short launcher: auto-picks main_stock/main by symbol; -c opens chart_program.",
    )
    parser.add_argument("target", help="Config slug/symbol/pair, e.g. ena, eurusd_long, cocoa_short")
    parser.add_argument("-c", "--chart", action="store_true", help="Open chart program instead of direct analysis")
    args = parser.parse_args()

    target = args.target.strip()

    if args.chart:
        cmd = [sys.executable, "-m", "chart_program", target]
    else:
        instrument_type = detect_instrument_type(target, None)
        runner = _resolve_runner(instrument_type)
        cmd = [sys.executable, str(PROJECT_ROOT / runner), target]

    return subprocess.call(cmd)


if __name__ == "__main__":
    raise SystemExit(main())
